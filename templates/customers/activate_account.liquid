{%- comment -%} SCAFFOLD — styled in Task 06. Reached via the invite email token. {%- endcomment -%}
{%- liquid
  # `t` is not evaluated inside render arguments — translate first.
  assign t_password = 'customer.activate.password' | t
  assign t_confirm = 'customer.activate.password_confirm' | t
  assign t_submit = 'customer.activate.submit' | t
-%}
<section class="w-full" style="background-color: var(--color-brand-beige);">
  <div class="container mx-auto px-4 py-14 md:!py-20">
    <div class="mx-auto w-full max-w-[535px]">
      <h1 class="font-kurdis-condensed font-extrabold uppercase text-espresso text-[45px] md:!text-[60px] leading-none text-center mb-8">
        {{ 'customer.activate.title' | t }}
      </h1>
      {%- form 'activate_customer_password', novalidate: 'novalidate', class: 'flex flex-col !gap-4' -%}
        {%- if form.errors -%}
          <div class="body text-sunrise_orange" role="alert">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        {%- render 'customer-input', name: 'customer[password]', type: 'password', label: t_password, id: 'ActivatePassword', autocomplete: 'new-password', required: true -%}
        {%- render 'customer-input', name: 'customer[password_confirmation]', type: 'password', label: t_confirm, id: 'ActivatePasswordConfirm', autocomplete: 'new-password', required: true -%}
        {%- render 'customer-form-button', label: t_submit, style: 'secondary-gold', class: '!w-full !h-[52px] !text-[20px] mt-1' -%}
        <button type="submit" name="decline" value="true" class="tag text-espresso hover:underline bg-transparent border-0 cursor-pointer text-center mt-2">{{ 'customer.activate.decline' | t }}</button>
      {%- endform -%}
    </div>
  </div>
</section>
