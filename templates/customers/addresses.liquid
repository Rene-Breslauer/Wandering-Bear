{%- comment -%} SCAFFOLD — full address book (CRUD) is built in Task 06. {%- endcomment -%}
<section class="w-full" style="background-color: var(--color-brand-beige);">
  <div class="container mx-auto px-4 py-10 md:!py-16">
    <h1 class="h1 text-espresso mb-4">{{ 'customer.nav.addresses' | t }}</h1>
    {%- paginate customer.addresses by 10 -%}
      {%- for address in customer.addresses -%}
        <div class="body text-espresso mb-2">{{ address | format_address }}</div>
      {%- else -%}
        <p class="body text-espresso">No saved addresses yet.</p>
      {%- endfor -%}
    {%- endpaginate -%}
  </div>
</section>
