{%- doc -%}
  Renders a default variant picker, used to display the variant picker in the variants block.

  @param {object} product_resource - The product object.
  @param {object} [block] - The block object
  @param {object} section - The section object.
  @param {object} product - The current product object (used to determine selected variant state).
{%- enddoc -%}

{% liquid
   assign selling_plan_keywords = blank
   assign multi_unit_product = false
   assign block_settings = block.settings
   assign bundle_collection = section.settings.bundle_collection
   assign first_product = bundle_collection.products.first
   assign product_object = product.metafields.custom.product_group

   assign bundle_placeholder_image = section.settings.bundle_placeholder_image

   if first_product.selected_or_first_available_variant.compare_at_price > first_product.selected_or_first_available_variant.price
    assign compare_at_price = first_product.selected_or_first_available_variant.compare_at_price
   else
    assign compare_at_price = first_product.selected_or_first_available_variant.price
   endif
   
   assign bundle_products = product_object.value.bundle_products.value
   assign bundle_products_count = bundle_products.size
   assign headline = product_object.value.headline
   assign headline_size = product_object.value.headline
   assign singular_label = product_object.value.singular_label
   assign plural_label = product_object.value.plural_label
   assign selling_plan_keywords = product_object.value.selling_plan_keywords.value
   assign discount_type = product_object.value.discount_type
   assign col_width = 63

   if product_object.value.multi_unit_product_quantity != blank and product_object.value.multi_unit_product_quantity > 1
    assign multi_unit_product = true
    assign multi_unit_quantity = product_object.value.multi_unit_product_quantity
    assign multi_unit_product_unit = product_object.value.multi_unit_product_unit
    assign col_width = 121
   endif

   ## Prices ##

   assign tier_one_unit_price_otp = first_product.variants[0].price
   assign tier_two_unit_price_otp = first_product.variants[1].price

   for selling_plan in first_product.selling_plan_groups
    for selling_plan_allocation in selling_plan.selling_plan_allocations
      if selling_plan_allocation.selling_plan.name contains '1 Month'
        assign tier_one_unit_price_autoship = selling_plan_allocation.selling_plan.price
      endif
    endfor
   endfor

   for variant in first_product.variants
    assign variant_title = variant.title | downcase | split: ' discount' | first
    assign variant_title = variant_title | split: ' ' | first
  
    for allocation in variant.selling_plan_allocations
      assign plan = allocation.selling_plan
      assign plan_name = plan.name | downcase
  
      if plan_name contains '1 month' and plan_name contains 'bundle'

          assign adjustment = plan.price_adjustments[0]
          assign discount_amount = adjustment.value
          assign value_type = adjustment.value_type
          if value_type == 'percentage'
            assign difference = variant.price | times: discount_amount | divided_by: 100.0
            assign autoship_price = variant.price | minus: difference
          else
          assign autoship_price = variant.price | minus: discount_amount
          endif
  
          case variant_title
            when '3'
              assign tier_one_unit_price_autoship = autoship_price
            when '6'
              assign tier_two_unit_price_autoship = autoship_price
          endcase
      endif
    endfor
  endfor
%}

{% capture col_width_styles %}
  --col-width: {{ col_width }}px;
{% endcapture %}

{% style %}
  .col-width {
    width: var(--col-width);
  }
{% endstyle %}


<div class="flex flex-col gap-2.5 mb-6">
    <div class="flex flex-col">
    <span class="font-bold font-gothic_condensed text-bear-black block uppercase">Choose Quantity</span>
        <div class="wb-grid grid-cols-2 w-full h-[74px] border border-[#CFBDB1] rounded-[5px]">
            {% for i in (1..bundle_products_count) %}
              {%- case i -%}
                {%- when 1 -%}
                  {%- assign autoship_price = tier_one_unit_price_autoship -%}
                {%- when 2 -%}
                  {%- assign autoship_price = tier_two_unit_price_autoship -%}
              {%- endcase -%}
              {% assign qty = i | times: 3 %}
              {% if discount_type == 'Percentage' %}
                {% assign difference = compare_at_price | minus: autoship_price %}
                {% assign savings = difference | times: 100.0 | divided_by: compare_at_price | round | append: '%' %}
              {% else %}
                {% assign savings = compare_at_price | minus: autoship_price_qty | money %}
              {% endif %}

              <fieldset class="flex flex-col h-full w-full justify-center items-center">
                <input
                 @change="changeBundleQuantity({{ qty }})"
                 class="absolute top-0 left-0 w-0 h-0 opacity-0 hidden peer"
                 x-model="bundleQty"
                 type="radio" name="bundle-qty" id="bundle-qty-{{ i }}" value="{{ qty }}" {% if forloop.first %}checked{% endif %}>
                <label class="{% if forloop.first %}rounded-tl-[5px] rounded-bl-[5px]{% else %}rounded-tr-[5px] rounded-br-[5px]{% endif %} peer-checked:bg-[#F9F3ED] peer-checked:border peer-checked:border-espresso h-full w-full wb-flex flex-col justify-center items-center" for="bundle-qty-{{ i }}">
                  <span class="font-gothic_condensed text-bear-black text-base font-bold uppercase">{{ qty }} Cartons</span>
                  <span class="font-kurdis-semi-condensed text-[12px] text-bear-black font-semibold">From {{ autoship_price | money }}/carton</span>
                  <span class="font-kurdis-semi-condensed text-[10px] text-kraft font-semibold">Save {{ savings }}</span>
                </label>
            </fieldset>
            {% endfor %}
        </div>
    </div>
    <div class="flex flex-col">
    <span class="font-bold font-gothic_condensed text-bear-black block uppercase">Choose Flavors</span>
        <div class="wb-grid grid-cols-2 w-full h-[74px] border border-[#CFBDB1] rounded-[5px] overflow-hidden">
            <fieldset class="flex flex-col h-full w-full justify-center items-center">
                <input
                 @change="changeFlavorType('mix')"
                 x-model="flavorType"
                 class="absolute top-0 left-0 w-0 h-0 opacity-0 hidden peer"
                 type="radio" name="bundle-flavor" id="bundle-flavor-mix" value="mix">
                <label class="rounded-tl-[5px] rounded-bl-[5px] peer-checked:bg-[#F9F3ED] peer-checked:border peer-checked:border-espresso h-full w-full wb-flex flex-col justify-center items-center" for="bundle-flavor-mix">
                  <span class="font-gothic_condensed text-bear-black text-base font-bold uppercase">Mix & Match</span>
                  <span class="font-kurdis-semi-condensed text-[12px] text-bear-black font-semibold">Pick up to <span x-text="bundleQty">3</span> flavors</span>
                </label>
            </fieldset>
            <fieldset class="flex flex-col h-full w-full justify-center items-center">
                <input
                 @change="changeFlavorType('single')"
                 x-model="flavorType"
                 class="absolute top-0 left-0 w-0 h-0 opacity-0 hidden peer"
                 type="radio" name="bundle-flavor" id="bundle-flavor-single" value="single" checked>
                <label class="rounded-tr-[5px] rounded-br-[5px] peer-checked:bg-[#F9F3ED] peer-checked:border peer-checked:border-espresso h-full w-full wb-flex flex-col justify-center items-center" for="bundle-flavor-single">
                  <span class="font-gothic_condensed text-bear-black text-base font-bold uppercase">Single Flavor</span>
                  <span class="font-kurdis-semi-condensed text-[10px] text-kraft font-semibold">Save an additional 5%</span>

                </label>
            </fieldset>
        </div>
    </div>
    <div x-show="flavorType == 'mix'" x-cloak class="wb-flex justify-center gap-2 lg:!gap-2.5 h-[87px] mt-1.5 max-w-full">
      <template x-for="(product, index) in bundleSlots" :key="index">
        <div class="flex flex-col gap-2.5 py-5 px-1 md:!px-4 justify-center items-center border border-[#CFBDB1] rounded-[5px] !max-w-[50px] lg:!max-w-[62px] !aspect-[51/72] lg:!aspect-[62/87]"
        :class="{ 'bg-[#F9F3ED] !px-1 md:!px-2 !py-1.5 md:!py-5': product }"
        >
          <template x-if="product">
            <div class="h-full wb-flex flex-col justify-center items-center gap-1">
              <img :class="index % 2 === 0 ? 'rotate-[9.03deg]' : '-rotate-[9.03deg]'"
              :src="product.image" alt="Product Image" class="!max-w-5 !h-10 md:!w-6 md:!h-12 object-cover mx-auto">
              <span class="font-kurdis-semi-condensed whitespace-nowrap text-[10px] text-bear-black font-semibold text-center mx-auto w-fit block" x-text="product.flavorName"></span>
            </div>
          </template>
    
          <template x-if="!product">
            <div class="w-fit mx-auto" :class="index % 2 === 0 ? 'rotate-[9.03deg]' : '-rotate-[9.03deg]'">
              {% if bundle_placeholder_image != blank %}
                {{ bundle_placeholder_image | image_url: width: 100 | image_tag: class: '!max-w-5 !h-10 md:!w-6 md:!h-12 object-cover mx-auto' }}
              {% endif %}
            </div>
          </template>
    
        </div>
      </template>
    </div>
</div>


<div class="flex flex-col gap-2.5">
    {% render 'product-selector-group', bundle_collection: bundle_collection, bundle_type: '32oz' %}
</div>


{% render 'purchase-option-selector' %}

<script x-ref="bundleParentProducts" type="application/json">
  [
    {%- for bundle_product in bundle_products -%}
      {%- assign bundle_parent_variant = bundle_product.selected_or_first_available_variant -%}
      {
        "id": {{ bundle_product.id | json }},
        "handle": {{ bundle_product.handle | json }},
        "variant_id": {{ bundle_parent_variant.id | json }}{% if bundle_parent_variant.selling_plan_allocations.size > 0 %},{% endif %}
        {% for allocation in bundle_parent_variant.selling_plan_allocations %}
          {%- assign selling_plan_name = allocation.selling_plan.name -%}
          {%- if selling_plan_name contains '1 Month' -%}
              "selling_plan_id": {{ allocation.selling_plan.id | json }}
          {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
</script>

<script x-ref="productObject" type="application/json">
  {
    {%- for child_product in bundle_collection.products -%}
        "{{- child_product.id -}}": {
            "id": {{- child_product.id -}},
            "title": "{{- child_product.title -}}",
            "handle": "{{- child_product.handle -}}",
            {% if child_product.metafields.custom.bundle_image != blank %}
              "image": "{{- child_product.metafields.custom.bundle_image | image_url: width: 200 -}}",
            {% endif %}
            {% if child_product.metafields.custom.flavor_name != blank %}
              "flavor_name": "{{- child_product.metafields.custom.flavor_name -}}",
            {% endif %}
            "variants": {
                {% for child_variant in child_product.variants %}
                    "{{- forloop.index0 -}}": {
                        {% liquid
                          assign product_object = child_product.metafields.custom.product_group

                          if product_object.value.discount_type == 'Percentage'
                            assign discount_type = 'Percentage'
                          else
                            assign discount_type = 'Fixed'
                          endif

                          if child_variant.compare_at_price > child_variant.price
                            assign compare_at_price = child_variant.compare_at_price
                          else
                            assign compare_at_price = child_variant.price
                          endif
                        %}

                        {% if child_product.metafields.custom.product_group.value.multi_unit_product_quantity != blank and child_product.metafields.custom.product_group.value.multi_unit_product_quantity > 0 %}
                          "multi_unit_product": true,
                          "multi_unit_product_unit": "{{- child_product.metafields.custom.product_group.value.multi_unit_product_unit -}}",
                          "multi_unit_quantity": {{- child_product.metafields.custom.product_group.value.multi_unit_product_quantity -}},
                        {% endif %}
                        "compare_at_price": {{- compare_at_price -}},
                        "discount_type": "{{- discount_type -}}",
                        "title": "{{- child_variant.title -}}",
                        "price": {{- child_variant.price -}},
                        {%- assign printed_allocation = false -%}
                        {%- for allocation in child_variant.selling_plan_allocations -%}
                          {%- assign selling_plan_name = allocation.selling_plan.name -%}
                          {%- if selling_plan_name contains '1 Month' -%}
                            {% if selling_plan_keywords != blank %}
                              {% for word in selling_plan_keywords %}
                                {% if selling_plan_name contains word %}
                                  {% continue %}
                                {% endif %}
                              {% endfor %}
                            {% endif %}
                            {% if forloop.first %}
                              {% continue %}
                            {% endif %}
                            {%- if printed_allocation -%},{%- endif -%}
                              "selling_plan_id": {{ allocation.selling_plan.id | json }},
                              "selling_plan_name": {{ allocation.selling_plan.name | json }},
                              "selling_plan_price": {{ allocation.price | json }},
                              "selling_plan_savings": {{ child_product.variants[0].price | minus: allocation.price | json }},
                            {%- assign printed_allocation = true -%}
                          {%- endif -%}
                        {%- endfor -%}
                        "id": {{- child_variant.id -}}
                    }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
            }
        }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  }
</script>

{% stylesheet %}
  /* Variant picker container styles - unique to main variant picker */
  .variant-picker {
    width: 100%;
  }

  .variant-picker__form {
    width: 100%;
  }

  .variant-picker[data-shopify-visual-preview] {
    min-width: 300px;
    padding-inline-start: max(4px, var(--padding-inline-start));
  }

  /* Dropdown variant option styles */
  .variant-option__select-wrapper {
    display: flex;
    position: relative;
    border: var(--style-border-width-inputs) solid var(--color-border);
    border-radius: var(--style-border-radius-inputs);
    align-items: center;
    margin-top: var(--margin-2xs);
    overflow: clip;
  }

  .variant-option__select-wrapper:has(.swatch) {
    --variant-picker-swatch-width: 20px;
    --variant-picker-swatch-height: 20px;
  }

  .variant-option__select-wrapper:hover {
    border-color: var(--color-variant-hover-border);
  }

  .variant-option__select:focus-visible {
    outline: var(--focus-outline-width) solid currentcolor;
    outline-offset: var(--focus-outline-offset);
  }

  .variant-option__select {
    padding-block: var(--padding-md);
    padding-inline: var(--padding-lg) calc(var(--padding-lg) + var(--icon-size-2xs));
    appearance: none;
    border: 0;
    width: 100%;
    margin: 0;
    cursor: pointer;
  }

  .variant-option__select-wrapper .icon {
    position: absolute;
    right: var(--padding-md);
    top: 50%;
    transform: translateY(-50%);
    width: var(--icon-size-2xs);
    height: var(--icon-size-2xs);
    pointer-events: none;
  }

  .variant-option__select--has-swatch {
    padding-inline-start: calc((2 * var(--padding-sm)) + var(--variant-picker-swatch-width));
  }

  .variant-option__select-wrapper .swatch {
    position: absolute;
    top: 50%;
    left: var(--padding-md);
    transform: translateY(-50%);
  }

  /* Variant picker alignment modifiers */
  .variant-picker--center,
  .variant-picker--center .variant-option {
    text-align: center;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .variant-picker--right,
  .variant-picker--right .variant-option {
    text-align: right;
    justify-content: right;
  }
{% endstylesheet %}
