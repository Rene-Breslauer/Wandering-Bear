{%- doc -%}
    Renders a picture element with the given source and sources.
    @param {object} source - The source image
    @param {object} [sources] - The sources for the picture element (optional)
    @param {object} [tablet_source] - The tablet source image (optional)
    @param {object} [mobile_source] - The mobile source image (optional)
    @param {string} [class] - The class for the picture element (optional)
    @param {string} [loading] - The loading attribute for the picture element (optional)
    @param {string} [preload] - The preload attribute for the picture element (optional)
    @param {number} [width] - The width of the image (optional)
    @param {number} [height] - The height of the image (optional)
    @param {string} [alt] - The alt text for the image (optional)
{%- enddoc -%}

{% liquid
    assign desktop_source = source
    assign resolved_mobile = mobile_source
    if resolved_mobile == blank
        assign resolved_mobile = desktop_source
    endif
    assign resolved_tablet = tablet_source
    if resolved_tablet == blank
        assign resolved_tablet = mobile_source
    endif
    if resolved_tablet == blank
        assign resolved_tablet = desktop_source
    endif
%}

{% capture picture_sources %}
{% if sources %}
    {{ sources }}
{% else %}
    <source srcset="{{ source | image_url: width: 1920 }}" media="(min-width: 1920px)">
    <source srcset="{{ source | image_url: width: 1440 }}" media="(min-width: 1440px)">
    <source srcset="{{ source | image_url: width: 1200 }}" media="(min-width: 1200px)">
    <source srcset="{{ source | image_url: width: 1920 }}" media="(min-width: 1024px)">
    {% if tablet_source %}
        <source srcset="{{ tablet_source | image_url: width: 768 }}" media="(min-width: 768px)">
    {% else %}
        <source srcset="{{ source | image_url: width: 768 }}" media="(min-width: 768px)">
    {% endif %}
    {% if mobile_source %}
        <source srcset="{{ mobile_source | image_url: width: 500 }}" media="(max-width: 480px)">
        <source srcset="{{ mobile_source | image_url: width: 767 }}" media="(max-width: 767px)">
      {% else %}
        <source srcset="{{ source | image_url: width: 500 }}" media="(max-width: 480px)">
        <source srcset="{{ source | image_url: width: 767 }}" media="(max-width: 767px)">
      {% endif %}
{% endif %}
{% endcapture %}

{% if loading %}
    {% assign loading = loading %}
{% else %}
    {% assign loading = 'lazy' %}
{% endif %}

{% if alt %}
    {% assign alt = alt %}
{% else %}
    {% assign alt = desktop_source.alt %}
{% endif %}

{% if width %}
    {% assign width = width %}
{% else %}
    {% assign width = image.width %}
{% endif %}

{% if height %}
    {% assign height = height %}
{% else %}
    {% assign height = image.height %}
{% endif %}

{% capture img_parameters %}
    loading="{{ loading }}"
    {% if preload %}
      preload="{{ preload }}"
    {% endif %}
    alt="{{ alt }}"
    class="{{ class }}"
{% endcapture %}

<picture>
    {{ picture_sources }}
    <img src="{{ resolved_mobile | image_url: width: 1920 }}" height="1080" width="1920" {{ img_parameters }}>
</picture>