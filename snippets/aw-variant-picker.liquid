{%- doc -%}
  Renders a default variant picker, used to display the variant picker in the variants block.

  @param {object} product_resource - The product object.
  @param {object} [block] - The block object
  @param {object} section - The section object.
  @param {object} product - The current product object (used to determine selected variant state).
{%- enddoc -%}

{% liquid 
    assign one_month_allocation = blank
    assign product_object = product_resource.metafields.custom.product_group.value
    assign is_concentrate_template = false
    assign is_landing_page_template = false
    assign selected_index = 0

    if template.suffix == 'concentrate'
      assign is_concentrate_template = true
    endif
    if template.suffix == 'overview-2'
      assign is_landing_page_template = true
      assign selected_index = 1
    endif
    assign quantified = false
    if variant.metafields.custom.quantified_units != blank
      if is_concentrate_template or product_object.quantified or is_landing_page_template
        assign quantified = true
      endif
    endif

    for allocation in variant.selling_plan_allocations
        if allocation.selling_plan.name contains '1 Month'
            assign one_month_allocation = allocation
            assign selling_plan_price = allocation.price
            if quantified
                assign selling_plan_price = selling_plan_price | times: variant.metafields.custom.quantified_units
            endif
            break
        endif
    endfor

    if variant.compare_at_price > variant.price
        assign compare_at_price = variant.compare_at_price
    else
        assign compare_at_price = variant.price
    endif

    assign price = variant.price 
    if quantified
        assign price = price | times: variant.metafields.custom.quantified_units
    endif

    assign choose_quantity_text = 'products.product.choose_quantity' | t
    assign box_text = 'products.product.box' | t

    assign savings_display = block.settings.savings_display | default: 'percent'
%}

{% assign block_settings = block.settings %}

{% style %}
  .variant-picker label:has(input[type='radio']:focus-visible) {
    outline: 2px solid currentColor;
    outline-offset: -2px;
    border-radius: 5px;
  }
{% endstyle %}

{% unless product_resource.has_only_default_variant %}
  {% liquid
    assign selling_plan_id = product_resource.selected_or_first_available_variant.selling_plan_id
  %}

  <variant-picker
    class="variant-picker spacing-style variant-picker--{{ block_settings.alignment }}"
    style="--color-strikethrough-mix: {{ strikethrough_color_mix }}; {% render 'spacing-style', settings: block_settings %}"
    data-section-id="{{ section.id }}"
    data-product-id="{{ product_resource.id }}"
    data-block-id="{{ block.id }}"
    data-product-url="{{ product_resource.url }}"
    ref="mainVariantPicker"
    {% if product.id == product_resource.id %}
      data-template-product-match="true"
    {% endif %}
    {{ block.shopify_attributes }}
    {% if request.visual_preview_mode %}
      data-shopify-visual-preview
    {% endif %}
  >
    <form class="variant-picker__form">
      {%- for product_option in product_resource.options_with_values -%}
        {%- liquid
          assign swatch_count = product_option.values | map: 'swatch' | compact | size
          assign variant_style = block_settings.variant_style

          if swatch_count > 0 and block_settings.show_swatches
            if block_settings.variant_style == 'dropdown'
              assign variant_style = 'swatch_dropdown'
            else
              assign variant_style = 'swatch'
            endif
          endif

          assign fieldset_id = section.id | append: '-' | append: product_resource.id | append: '-' | append: product_option.name | handleize
          assign option_id_attribute = 'data-option-id="' | append: fieldset_id | append: '"'
          assign longest_value = 0
        -%}

          {%- assign fieldset_index = forloop.index0 -%}
          <fieldset
            class="variant-option variant-option--buttons{% if variant_style == 'swatch' %} variant-option--swatches{% else %} variant-option--{{ settings.variant_button_width }}{% endif %}"
            data-fieldset-index="{{ fieldset_index }}"
            ref="fieldsets[]"
            {{ option_id_attribute }}
          >
            <legend class="text-base font-bold font-gothic_condensed uppercase text-bear-black">
              {{ product_option.name | escape |  replace: 'Pack Size', choose_quantity_text -}}
              {%- if variant_style == 'swatch' -%}
                <span class="variant-option__swatch-value">{{ product_option.selected_value }}</span>
              {%- endif %}
            </legend>
            <div class="wb-flex rounded-[5px] outline outline-[#CFBDB1] bg-transparent relative">
            {%- for product_option_value in product_option.values -%}
              {% if product_option_value.size > longest_value and option_id_attribute %}
                {% assign longest_value = product_option_value.size %}
              {% endif %}
              <label
                data-variant-id="{{ product_option_value.variant.id }}"
                class="bg-transparent p-0 m-0 flex !items-start justify-center relative w-full h-full py-1.75 hover:[&_.variant-option-name]:text-dark-gold hover:bg-foam! transition-colors duration-300 md:pb-2.5 md:pt-1.5 {% if variant_style == 'swatch' %} variant-option__button-label--has-swatch{% endif %}"
              >
                {% if is_landing_page_template and forloop.index0 == selected_index %}
                  <div
                  class="absolute bottom-[calc(100%+2px)] w-fit mx-auto px-2 font-kurdis-semi-condensed font-bold py-1 rounded-tl-[5px] rounded-tr-[5px] text-[11px] !leading-[100%] text-center flex items-center justify-center uppercase"
                   style="background-color: {{ section.settings.color_scheme.settings.foreground }}; color: {{ section.settings.color_scheme.settings.background }};">
                    <span class="text-xs font-bold font-kurdis-semi-condensed">Most Popular</span>
                  </div>
                {% endif %}
                <input
                  type="radio"
                  class="flex !h-[0px] !w-[0px] opacity-0 absolute top-0 left-0"
                  name="{{ product_option.name | escape }}-{{ block.id }}-{{ product_resource.id }}"
                  value="{{ product_option_value | escape }}"
                  aria-label="{{ product_option_value.name | escape }}{% if is_landing_page_template and forloop.index0 == selected_index %} - {{ 'products.product.most_popular' | t: default: 'Most Popular' }}{% endif %}{% if product_option_value.available == false %} - {{ 'products.product.sold_out' | t }}{% endif %}"
                  {% if product_option_value.available == false %}
                    aria-disabled="true"
                  {% endif %}
                  data-previous-checked="false"
                  data-variant-id="{{ product_option_value.variant.id }}"
                  data-fieldset-index="{{ fieldset_index }}"
                  data-input-index="{{ forloop.index0 }}"
                  data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                  data-option-value-id="{{ product_option_value.id }}"
                  data-option-available="{{ product_option_value.available }}"
                  data-connected-product-url="{{ product_option_value.product_url }}"
                  {% if product_option_value.variant.id %}
                    data-variant-id="{{ product_option_value.variant.id }}"
                  {% endif %}
                  {% if is_landing_page_template and forloop.index0 == selected_index %}
                    data-current-checked="true"
                    checked
                  {% elsif product_option_value.selected %}
                    data-current-checked="true"
                    checked
                  {% else %}
                    data-current-checked="false"
                  {% endif %}
                >
                  <div
                    class="wb-flex flex-col gap-0.5 items-center justify-start"
                    data-key="variant-option-text"
                  >
                  {% liquid 
                    assign option_name = product_option_value
                    for variant in product_resource.variants
                    if variant.id == product_option_value.variant.id
                      assign option_name = variant.metafields.airf.boxes | default: variant.title
                      assign option_price = variant.price
                      assign discount = product_resource.variants[0].compare_at_price | minus: variant.price
                      assign option_savings = discount | times: 100.0 | divided_by: product_resource.variants[0].compare_at_price | round: 0

                      if savings_display == 'amount'
                        assign discount_remainder = discount | modulo: 100
                        if discount_remainder == 0
                          assign option_savings_amount = discount | money_without_trailing_zeros
                        else
                          assign option_savings_amount = discount | money
                        endif
                        assign option_savings_text = 'Save' | append: ' ' | append: option_savings_amount
                      else
                        assign option_savings_text = 'Save' | append: ' ' | append: option_savings | append: '%'
                      endif
                    endif
                    endfor
                  %}
                    <span class="variant-option-name transition-colors duration-300 text-base text-bear-black font-bold font-gothic_condensed uppercase">{{- option_name | escape -}}</span>
                    <span x-text="variantPriceFormatted('{{ product_option_value.variant.id }}', '/{{ box_text }}')" class="text-xs text-bear-black font-kurdis-semi-condensed font-semibold">{{- option_price | money -}}/{{ box_text }}</span>
                    <span x-text="{% if savings_display == 'amount' %}variantSavingsAmountFormatted{% else %}variantSavingsFormatted{% endif %}('{{ product_option_value.variant.id }}')"
                    :class="variantSavingsPercentage('{{ product_option_value.variant.id }}') > 0 ? '!block' : '!hidden'"
                    class="font-kurdis-semi-condensed font-semibold text-kraft text-xs/none md:text-[10px] {% if option_savings > 0 %}block{% else %}hidden{% endif %}">{{- option_savings_text | escape -}}</span>
                  </div>
              </label>
            {%- endfor -%}
            </div>
            {% if option_id_attribute %}
              {% style %}
                [data-option-id="{{ fieldset_id }}"] {
                  --variant-ch: {{ longest_value | times: 0.65 }}em;
                }
              {% endstyle %}
            {% endif %}
          </fieldset>
        
      {%- endfor -%}

      <script type="application/json">
        {{ product_resource.selected_or_first_available_variant | json }}
      </script>
    </form>
  </variant-picker>


  {% render 'purchase-options', product_resource: product_resource, section: section, variant_picker_blocks: variant_picker_blocks %}

{% if template.suffix == 'overview-2' %}
  <script x-ref="productObject" type="application/json">
  {
    {% for grouped_product in product_resource.metafields.custom.product_group.value.collection_handle.value.products %}
      "{{ grouped_product.id }}": {
            {% for variant in grouped_product.variants %}
              {% liquid 
                  assign one_month_allocation = blank
                  assign product_object = product_resource.metafields.custom.product_group.value
                  assign quantified = true
                  assign quantified_units = variant.metafields.custom.quantified_units

                  if quantified_units != blank and quantified_units > 0
                    if is_concentrate_template or product_object.quantified
                      assign quantified = true
                    endif
                  endif

                  for allocation in variant.selling_plan_allocations
                      if allocation.selling_plan.name contains '1 Month'
                          assign one_month_allocation = allocation
                          assign selling_plan_price = allocation.price
                          if quantified
                              assign selling_plan_price = selling_plan_price
                          endif
                          break
                      endif
                  endfor

                  if variant.compare_at_price > variant.price
                      assign compare_at_price = variant.compare_at_price
                  else
                      assign compare_at_price = variant.price
                  endif

                  assign price = variant.price 
                  #if quantified
                  #    assign price = price | times: variant.metafields.custom.quantified_units
                  #endif
              %}

              "{{ variant.id }}": {
                "available": {{ variant.available | json }},
                "title": {{ variant.title | json }},
                "id": {{ variant.id | json }},
                "flavor_name": "{{- grouped_product.metafields.custom.flavor_name -}}",
                "quantified": {{ quantified | json }},
                {% if quantified %}
                  "quantified_units": {{ quantified_units | json }},
                {% endif %}
                "price": {{ price | json }},
                {% if compare_at_price %}
                  "compare_at_price": {{ compare_at_price | json }},
                {% endif %}
                "featured_media_position": {{ variant.featured_media.position | default: 1 | json }}
                {% if one_month_allocation != blank %}
                  ,
                  "selling_plan_id": {{ one_month_allocation.selling_plan.id | json }},
                  "selling_plan_name": {{ one_month_allocation.selling_plan.name | json }},
                  "selling_plan_price": {{ selling_plan_price | json }},
                  "selling_plan_savings": {{ variant.price | minus: one_month_allocation.price | json }}
                {% endif %}
              }{% unless forloop.last %},{% endunless %}
            {% endfor %}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    }
  </script>
{% else %}
  <script x-ref="productObject" type="application/json">
  {
        {% for variant in product_resource.variants %}
          
          {% liquid 
              assign one_month_allocation = blank
              assign product_object = product_resource.metafields.custom.product_group.value
              assign quantified = false
              assign quantified_units = variant.metafields.custom.quantified_units

              if quantified_units != blank and quantified_units > 0
                if is_concentrate_template or product_object.quantified
                  assign quantified = true
                endif
              endif

              for allocation in variant.selling_plan_allocations
                  if allocation.selling_plan.name contains '1 Month'
                      assign one_month_allocation = allocation
                      assign selling_plan_price = allocation.price
                      if quantified
                          assign selling_plan_price = selling_plan_price
                      endif
                      break
                  endif
              endfor

              if variant.compare_at_price > variant.price
                  assign compare_at_price = variant.compare_at_price
              else
                  assign compare_at_price = variant.price
              endif

              assign price = variant.price 
              #if quantified
              #    assign price = price | times: variant.metafields.custom.quantified_units
              #endif
          %}

          "{{ variant.id }}": {
            "available": {{ variant.available | json }},
            "title": {{ variant.title | json }},
            "id": {{ variant.id | json }},
            "flavor_name": "{{- product_resource.metafields.custom.flavor_name -}}",
            "quantified": {{ quantified | json }},
            {% if quantified %}
              "quantified_units": {{ quantified_units | json }},
            {% endif %}
            "price": {{ price | json }},
            {% if compare_at_price and quantified %}
              "compare_at_price": {{ compare_at_price | divided_by: quantified_units | json }},
            {% elsif compare_at_price %}
              "compare_at_price": {{ compare_at_price | json }},
            {% endif %}
            "featured_media_position": {{ variant.featured_media.position | default: 1 | json }}
            {% if one_month_allocation != blank %}
              ,
              "selling_plan_id": {{ one_month_allocation.selling_plan.id | json }},
              "selling_plan_name": {{ one_month_allocation.selling_plan.name | json }},
              "selling_plan_price": {{ selling_plan_price | json }},
              "selling_plan_savings": {{ variant.price | minus: one_month_allocation.price | json }}
            {% endif %}
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
  }
  </script>
{% endif %}
{% endunless %}

{% stylesheet %}
  .variant-option label {
    border: 1px solid transparent;
  }

  .variant-option label:has(input:checked) {
    background-color: #F9F3ED;
    border-color: transparent;
  }

  .variant-option label:has(input:checked)::before {
    content: '';
    position: absolute;
    inset: -2px;
    border: 1px solid var(--color-espresso);
    pointer-events: none;
    z-index: 1;
  }

  .variant-option label:not(:first-of-type):not(:last-of-type):not(:has(input:checked)) {
    border-left-color: #CFBDB1;
    border-right-color: #CFBDB1;
  }

  .variant-option label:first-of-type {
    border-top-left-radius: 5px;
    border-bottom-left-radius: 5px;
  }

  .variant-option label:last-of-type {
    border-top-right-radius: 5px;
    border-bottom-right-radius: 5px;
  }

  .variant-option label:first-of-type:has(input:checked)::before {
    border-top-left-radius: 5px;
    border-bottom-left-radius: 5px;
  }

  .variant-option label:last-of-type:has(input:checked)::before {
    border-top-right-radius: 5px;
    border-bottom-right-radius: 5px;
  }

  /* Variant picker container styles - unique to main variant picker */
  .variant-picker {
    width: 100%;
  }

  .variant-picker__form {
    width: 100%;
  }

  .variant-picker[data-shopify-visual-preview] {
    min-width: 300px;
    padding-inline-start: max(4px, var(--padding-inline-start));
  }

  /* Dropdown variant option styles */
  .variant-option__select-wrapper {
    display: flex;
    position: relative;
    border: var(--style-border-width-inputs) solid var(--color-border);
    border-radius: var(--style-border-radius-inputs);
    align-items: center;
    margin-top: var(--margin-2xs);
    overflow: clip;
  }

  .variant-option__select-wrapper:has(.swatch) {
    --variant-picker-swatch-width: 20px;
    --variant-picker-swatch-height: 20px;
  }

  .variant-option__select-wrapper:hover {
    border-color: var(--color-variant-hover-border);
  }

  .variant-option__select:focus-visible {
    outline: var(--focus-outline-width) solid currentcolor;
    outline-offset: var(--focus-outline-offset);
  }

  .variant-option__select {
    padding-block: var(--padding-md);
    padding-inline: var(--padding-lg) calc(var(--padding-lg) + var(--icon-size-2xs));
    appearance: none;
    border: 0;
    width: 100%;
    margin: 0;
    cursor: pointer;
  }

  .variant-option__select-wrapper .icon {
    position: absolute;
    right: var(--padding-md);
    top: 50%;
    transform: translateY(-50%);
    width: var(--icon-size-2xs);
    height: var(--icon-size-2xs);
    pointer-events: none;
  }

  .variant-option__select--has-swatch {
    padding-inline-start: calc((2 * var(--padding-sm)) + var(--variant-picker-swatch-width));
  }

  .variant-option__select-wrapper .swatch {
    position: absolute;
    top: 50%;
    left: var(--padding-md);
    transform: translateY(-50%);
  }

  /* Variant picker alignment modifiers */
  .variant-picker--center,
  .variant-picker--center .variant-option {
    text-align: center;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .variant-picker--right,
  .variant-picker--right .variant-option {
    text-align: right;
    justify-content: right;
  }
{% endstylesheet %}
