{%- doc -%}
  Submit button that matches the theme's `.btn` blob styling (wb-button is an <a>,
  so forms need this <button type="submit"> variant).

  @param {string} label - Button text.
  @param {string} [style] - primary | secondary-gold | secondary-cream (default: secondary-gold).
  @param {string} [class] - Extra classes (e.g. '!w-full !h-[52px]').
  @param {string} [type] - Button type (default: submit).
{%- enddoc -%}
{%- assign btn_style = style | default: 'secondary-gold' -%}
{%- assign btn_type = type | default: 'submit' -%}
<button type="{{ btn_type }}" class="btn {{ btn_style }} {% if class %}{{ class }}{% endif %}">
  <span class="mt-0.5">{{ label }}</span>
  <svg preserveAspectRatio="none" class="btn-svg w-full h-full drop-shadow-[4px_4px_4px_rgba(0,0,0,0.25)]" width="280" height="47" viewBox="0 0 280 47" fill="none" aria-hidden="true">
