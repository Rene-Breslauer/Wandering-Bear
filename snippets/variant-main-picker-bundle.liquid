          </div>
        </label>
    </fieldset>
</div>

<button
:class="bundleSize >= 1 ? '!pointer-events-auto' : 'pointer-events-none mt-4'"
class="group relative flex items-center justify-center shadow-button cursor-pointer h-[61px] w-[402px] max-w-full uppercase pointer-events-auto mb-4" @click.prevent="addToCart">
