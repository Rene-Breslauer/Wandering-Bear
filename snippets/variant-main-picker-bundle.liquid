{%- doc -%}
  Renders a default variant picker, used to display the variant picker in the variants block.

  @param {object} product_resource - The product object.
  @param {object} [block] - The block object
  @param {object} section - The section object.
  @param {object} product - The current product object (used to determine selected variant state).
{%- enddoc -%}

{% liquid
   assign selling_plan_keywords = blank
   assign multi_unit_product = false
   assign block_settings = block.settings
   assign bundle_collection = section.settings.bundle_collection
   assign first_product = bundle_collection.products.first
   assign product_object = product.metafields.custom.product_group

   if first_product.selected_or_first_available_variant.compare_at_price > first_product.selected_or_first_available_variant.price
    assign compare_at_price = first_product.selected_or_first_available_variant.compare_at_price
   else
    assign compare_at_price = first_product.selected_or_first_available_variant.price
   endif
   
   assign bundle_products = product_object.value.bundle_products.value
   assign bundle_products_count = bundle_products.size
   assign headline = product_object.value.headline
   assign headline_size = product_object.value.headline
   assign singular_label = product_object.value.singular_label
   assign plural_label = product_object.value.plural_label
   assign selling_plan_keywords = product_object.value.selling_plan_keywords.value
   assign discount_type = product_object.value.discount_type
   assign col_width = 63

   if product_object.value.multi_unit_product_quantity != blank and product_object.value.multi_unit_product_quantity > 1
    assign multi_unit_product = true
    assign multi_unit_quantity = product_object.value.multi_unit_product_quantity
    assign multi_unit_product_unit = product_object.value.multi_unit_product_unit
    assign col_width = 121
   endif

   ## Prices ##

   assign tier_one_unit_price_otp = first_product.variants[0].price
   assign tier_two_unit_price_otp = first_product.variants[1].price
   assign tier_three_unit_price_otp = first_product.variants[2].price

   for selling_plan in first_product.selling_plan_groups
    for selling_plan_allocation in selling_plan.selling_plan_allocations
      if selling_plan_allocation.selling_plan.name contains '1 Month'
        assign tier_one_unit_price_autoship = selling_plan_allocation.selling_plan.price
      endif
    endfor
   endfor

   for variant in first_product.variants
    assign variant_title = variant.title | downcase | split: ' discount' | first
    assign variant_title = variant_title | split: ' ' | first
  
    for allocation in variant.selling_plan_allocations
      assign plan = allocation.selling_plan
      assign plan_name = plan.name | downcase
  
      if plan_name contains '1 month' and plan_name contains variant_title
     
        unless plan_name contains 'bundle'
          assign adjustment = plan.price_adjustments[0]
          assign discount_amount = adjustment.value
          assign autoship_price = variant.price | minus: discount_amount
  
          case variant_title
            when '1'
              assign tier_one_unit_price_autoship = autoship_price
            when '2'
              assign tier_two_unit_price_autoship = autoship_price
            when '3'
              assign tier_three_unit_price_autoship = autoship_price
          endcase
        endunless
      endif
    endfor
  endfor
%}

{% capture col_width_styles %}
  --col-width: {{ col_width }}px;
{% endcapture %}

{% style %}
  .col-width {
    width: var(--col-width);
  }
{% endstyle %}

<div class="flex flex-col gap-2.5">
    <span class="text-base font-bold font-gothic_condensed uppercase text-gold">Build Your Bundle</span>

    <div class="wb-flex gap-1 flex-col w-full bg-white/50 p-4.5 rounded-[5px] font-kurdis relative button-shadow uppercase">
      <div class="absolute -top-5 -right-2 rotate-[1.993deg] w-[96px]">
        {% render 'badge', text: 'Most Popular', text_class: 'text-white text-[12px] font-kurdis-semi-condensed uppercase font-bold leading-[175%]', svg_class: 'text-gold'%}
      </div>
      <div class="flex items-center justify-between">
        {% for i in (1..bundle_products_count) %}
            {% assign tier = i %}
            {% if forloop.last %}
              {% assign tier = i | append: '+' %}
            {% endif %}
            {% if i == 1 %}
              {% assign tier_label = singular_label %}
            {% else %}
              {% assign tier_label = plural_label %}
            {% endif %}
            <div class="col-width flex flex-col items-center justify-center font-gothic_condensed uppercase font-bold" style="{{ col_width_styles }} text-bear-black">
                <span>{{ tier }} {{ tier_label }}</span>
            </div>
        {% endfor %}
      </div>
      <div>
        <div class="flex items-center justify-between relative">
          {% for i in (1..bundle_products_count) %}
              <div class="col-width flex items-center justify-center" style="{{ col_width_styles }}">
                <div class="flex items-center justify-center h-4.5 w-4.5 rounded-full mx-auto transition-all duration-300 relative z-[2] outline outline-[#CFBDB1] bg-[#F2E6DC]"
                :class="bundleSize >= {{ i }} ? '!outline-gold !bg-white' : 'outline-[#CFBDB1] bg-[#F2E6DC]'"
                >
                  <div class="flex items-center justify-center h-3.5 w-3.5 bg-[#CFBDB1] rounded-full bg-transparent"
                  :class="bundleSize >= {{ i }} ? '!bg-gold' : 'bg-transparent'"
                  ></div>
                 </div>
              </div>
              <div class="absolute {% if col_width == 121 %} right-[66px] left-[66px] {% else %} right-6 left-6 {% endif %} rounded-full mx-auto">
                <div class="relative h-[2px] bg-[#CFBDB1]">
                  <div class="absolute top-0 left-0 h-full max-w-full bg-gold transition-all duration-300"
                  :style="progressBarWidth"
                  ></div>
                </div>
              </div>
          {% endfor %}
        </div>
      </div>
      <div class="flex items-center justify-between text-[12px] w-full">
        {% for i in (1..bundle_products_count) %}
          <div data-tier="{{ i }}" class="col-width wb-flex gap-1 flex-col items-center justify-center" style="{{ col_width_styles }}">
            <div class="text-bear-black font-semibold font-kurdis-semi-condensed leading-[120%] normal-case inline-block whitespace-nowrap h-full">
              {%- case i -%}
                {%- when 1 -%}
                  {%- assign autoship_price = tier_one_unit_price_autoship -%}
                {%- when 2 -%}
                  {%- assign autoship_price = tier_two_unit_price_autoship -%}
                {%- when 3 -%}
                  {%- assign autoship_price = tier_three_unit_price_autoship -%}
               {%- endcase -%}
               {% if multi_unit_product %}
                {% assign calculated_qty = multi_unit_quantity | times: i %}
                {%- assign autoship_price_qty = autoship_price | divided_by: multi_unit_quantity -%}
                <span>{{ calculated_qty }} {{ multi_unit_product_unit }}</span>
                <span>·</span>
              {% else %}
                {% assign autoship_price_qty = autoship_price %}
              {% endif %}
              {% if discount_type == 'Percentage' %}
                {% assign difference = compare_at_price | minus: autoship_price %}
                {% assign savings = difference | times: 100.0 | divided_by: compare_at_price | round | append: '% off' %}
              {% else %}
                {% assign savings = compare_at_price | minus: autoship_price_qty | money %}
              {% endif %}
               <span data-tier-price>
                 {{- autoship_price_qty | money -}}
                </span>
                <span>/ea</span>
              </div>
              <div class="text-kraft font-semibold font-kurdis-semi-condensed leading-[120%] normal-case inline-block whitespace-nowrap">
              <span data-tier-savings>
                {{- savings -}}
              </span>
              </div>
            </div>
        {% endfor %}
    </div>
  </div>



<div class="{% if bundle_collection.products.size > 4 %} h-[436px] {% endif %} overflow-hidden relative">
    <div class="flavor-container flex flex-col gap-2
    {% if bundle_collection.products.size > 4 %} overflow-y-auto absolute {% endif %} top-0 left-0 w-full h-full py-2.5 pl-1 !pr-4">
        {% for child_product in bundle_collection.products %}
            {% liquid
            assign title = child_product.title | split: ' - ' | last
            assign image = child_product.metafields.custom.variant_selector_image
            assign flavor_description = child_product.metafields.airf.p_flavor | default: ''
            assign member_only = child_product.metafields.product.member_only | default: false

            assign product_badge = child_product.metafields.product.product_badge
            assign product_badge_text = product_badge.value.badge_text
            assign product_badge_color = product_badge.value.background_color
            assign product_badge_text_color = product_badge.value.text_color
            %}
               {% render 'product-selector', title: title, image: image, flavor_description: flavor_description, member_only: member_only, product_badge: product_badge, product_badge_text: product_badge_text, product_badge_color: product_badge_color, product_badge_text_color: product_badge_text_color, child_product: child_product %}
        {% endfor %}
    </div>
</div>
</div>

