            </svg>
          </div>
        <div class="col-start-2 wb-flex flex-col row-start-1 font-gothic_condensed uppercase">
          <span class="font-bold">Monthly with Autoship</span>
          </div>
          <div class="col-start-2 wb-flex flex-col row-start-2 col-end-4">
          <span>Skip, reschedule, cancel at anytime</span>
        </div>
        <div class="col-start-3 row-start-1 wb-flex justify-end gap-1">
            <span class="line-through text-[#1B1B1B80]" x-show="totalPrice.original !== totalPrice.autoship" x-text="totalPrice.original"></span>
            <span x-text="totalPrice.autoship"></span>
        </div>
        <div x-show="purchaseOption === 'autoship'"
        x-cloak
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 transform scale-95"
        x-transition:enter-end="opacity-100 transform scale-100"
    
        class="subscription-value-props mt-4 col-start-1 col-end-4 row-start-3">
            {{ section.settings.subscription_value_props }}
        </div>
        </label>
    </fieldset>
   
    <fieldset>
       <input x-model="purchaseOption" @change="onPurchaseOptionChange" type="radio" value="one_time" name="purchase_option" id="one_time" class="absolute top-0 left-0 w-0 h-0 opacity-0 hidden">
        <label 
        class="wb-grid !grid-cols-[20px_1fr_100px] !gap-x-3 w-full pl-[11px] pr-4 py-4 border cursor-pointer font-gothic_condensed rounded-[5px] mt-4 text-bear-black"
        :class="purchaseOption === 'one_time' ? 'border-kraft' : 'border-[#CFBDB1]'"
        for="one_time">
        <div class="col-start-1 h-5 w-5 rounded-full flex justify-center items-center bg-kraft  bg-transparent border border-[#CFBDB1]"
