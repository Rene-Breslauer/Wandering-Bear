</button>

<template x-if="currentSavingsAmount > 0">
  <span class="text-sm font-kurdis-semi-condensed font-semibold leading-[120%] text-kraft text-center mb-4 flex justify-center items-center" x-text="`You're saving ` + currentSavingsAmountFormatted + `!`"></span>
</template>

<script x-ref="bundleParentProducts" type="application/json">
  [
    {%- for bundle_product in bundle_products -%}
      {%- assign bundle_parent_variant = bundle_product.selected_or_first_available_variant -%}
      {
        "id": {{ bundle_product.id | json }},
        "handle": {{ bundle_product.handle | json }},
        "variant_id": {{ bundle_parent_variant.id | json }}{% if bundle_parent_variant.selling_plan_allocations.size > 0 %},{% endif %}
        {% for allocation in bundle_parent_variant.selling_plan_allocations %}
          {%- assign selling_plan_name = allocation.selling_plan.name -%}
          {%- if selling_plan_name contains '1 Month' -%}
              "selling_plan_id": {{ allocation.selling_plan.id | json }}
            {%- endif -%}
        {%- endfor -%}
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
</script>

<script x-ref="productObject" type="application/json">
  {
    {%- for child_product in bundle_collection.products -%}
        "{{- child_product.id -}}": {
            "id": {{- child_product.id -}},
            "title": "{{- child_product.title -}}",
            "handle": "{{- child_product.handle -}}",
            "variants": {
                {% for child_variant in child_product.variants %}
                    "{{- forloop.index0 -}}": {
                        {% liquid
                          assign product_object = child_product.metafields.custom.product_group

                          if product_object.value.discount_type == 'Percentage'
                            assign discount_type = 'Percentage'
                          else
                            assign discount_type = 'Fixed'
                          endif

                          if child_variant.compare_at_price > child_variant.price
                            assign compare_at_price = child_variant.compare_at_price
                          else
                            assign compare_at_price = child_variant.price
                          endif
                        %}

                        {% if child_product.metafields.custom.product_group.value.multi_unit_product_quantity != blank and child_product.metafields.custom.product_group.value.multi_unit_product_quantity > 0 %}
                          "multi_unit_product": true,
                          "multi_unit_product_unit": "{{- child_product.metafields.custom.product_group.value.multi_unit_product_unit -}}",
                          "multi_unit_quantity": {{- child_product.metafields.custom.product_group.value.multi_unit_product_quantity -}},
                        {% endif %}
                        "compare_at_price": {{- compare_at_price -}},
                        "discount_type": "{{- discount_type -}}",
                        "title": "{{- child_variant.title -}}",
                        "id": {{- child_variant.id -}},
                        "price": {{- child_variant.price -}},
                        {%- assign printed_allocation = false -%}
                        {%- for allocation in child_variant.selling_plan_allocations -%}
                          {%- assign selling_plan_name = allocation.selling_plan.name -%}
                          {%- if selling_plan_name contains '1 Month' -%}
                            {% if selling_plan_keywords != blank %}
                              {% for word in selling_plan_keywords %}
                                {% if selling_plan_name contains word %}
                                  {% continue %}
                                {% endif %}
                              {% endfor %}
                            {% endif %}
                            {%- if printed_allocation -%},{%- endif -%}
                              "selling_plan_id": {{ allocation.selling_plan.id | json }},
                              "selling_plan_name": {{ allocation.selling_plan.name | json }},
                              "selling_plan_price": {{ allocation.price | json }},
                              "selling_plan_savings": {{ child_product.variants[0].price | minus: allocation.price | json }}
                            {%- assign printed_allocation = true -%}
                          {%- endif -%}
                        {%- endfor -%}
                    }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
            }
        }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  }
</script>

{% stylesheet %}
  /* Variant picker container styles - unique to main variant picker */
  .variant-picker {
    width: 100%;
  }

  .variant-picker__form {
    width: 100%;
  }

  .variant-picker[data-shopify-visual-preview] {
    min-width: 300px;
    padding-inline-start: max(4px, var(--padding-inline-start));
  }

  /* Dropdown variant option styles */
  .variant-option__select-wrapper {
    display: flex;
    position: relative;
    border: var(--style-border-width-inputs) solid var(--color-border);
    border-radius: var(--style-border-radius-inputs);
    align-items: center;
    margin-top: var(--margin-2xs);
    overflow: clip;
  }

  .variant-option__select-wrapper:has(.swatch) {
    --variant-picker-swatch-width: 20px;
    --variant-picker-swatch-height: 20px;
  }

  .variant-option__select-wrapper:hover {
    border-color: var(--color-variant-hover-border);
  }

  .variant-option__select:focus-visible {
    outline: var(--focus-outline-width) solid currentcolor;
    outline-offset: var(--focus-outline-offset);
  }

  .variant-option__select {
    padding-block: var(--padding-md);
    padding-inline: var(--padding-lg) calc(var(--padding-lg) + var(--icon-size-2xs));
    appearance: none;
    border: 0;
    width: 100%;
    margin: 0;
    cursor: pointer;
  }

  .variant-option__select-wrapper .icon {
    position: absolute;
    right: var(--padding-md);
    top: 50%;
    transform: translateY(-50%);
    width: var(--icon-size-2xs);
    height: var(--icon-size-2xs);
    pointer-events: none;
  }

  .variant-option__select--has-swatch {
    padding-inline-start: calc((2 * var(--padding-sm)) + var(--variant-picker-swatch-width));
  }

  .variant-option__select-wrapper .swatch {
    position: absolute;
    top: 50%;
    left: var(--padding-md);
    transform: translateY(-50%);
  }

  /* Variant picker alignment modifiers */
  .variant-picker--center,
  .variant-picker--center .variant-option {
    text-align: center;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .variant-picker--right,
  .variant-picker--right .variant-option {
    text-align: right;
    justify-content: right;
  }
{% endstylesheet %}
