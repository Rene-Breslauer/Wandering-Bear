{% liquid
    assign flavor = product_resource.metafields.custom.flavor.value
    assign flavor_name = flavor.name
    assign flavor_color = flavor.color
    if flavor_color == blank
        assign flavor_color = "#D9D9D9"
    endif
    assign flavor_image = flavor.image
    assign product_resource_slug = product_resource.handle | handleize
    assign page_url = page.url | append: "?view=overview-2&product=" | append: product_resource_slug
%}
<fieldset>
    <label for="flavor-{{ product_resource_slug }}" @click="changeFlavor('{{ product_resource_slug }}')" class="flex flex-col gap-2 items-center cursor-pointer relative">
        <input type="radio" id="flavor-{{ product_resource_slug }}" name="flavor" value="{{ product_resource_slug }}" class="h-full w-full opacity-0 absolute top-0 left-0">
        <div class="flex w-12 h-12 flex-col justify-center items-center gap-2 rounded-full {% if selected %}outline outline-black outline-2{% endif %} bg-transparent">
            <div class="w-11 h-11 rounded-full flex items-center justify-center overflow-hidden">
                {% if flavor_image %}
                    {{ flavor_image | image_url: width: 100 | image_tag }}
                {% else %}
                    <div class="h-full w-full" style="background-color: {{ flavor_color }};"></div>
                {% endif %}
            </div>
        </div>
        <div class="leading-[100%] text-center">
            <span class="text-xs font-bod font-kurdis-semi-condensed">{{ flavor_name }}</span>
        </div>
    </label>
</fieldset>