<details @click="toggleAccordion($event)" data-accordion-item {{ open }} class=" {{ class }}">
    <summary class="wb-flex justify-between items-center w-full !pt-5">
        <span class="{{ title_class }}">
        {{ title }}
        </span>
        {% render 'icons' with icon: 'chevron-down' %}
    </summary>
    <div data-accordion-content class="accordion-content {{ content_class }}">
        {{ content }}
    </div>
</details>