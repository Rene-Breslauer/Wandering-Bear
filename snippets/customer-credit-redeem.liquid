{%- doc -%}
  Redeem Credits — trigger button + credit-redemption modal (Inveterate).

  The button opens the on-page redeem modal (Alpine `creditRedemption`): Fully / Partially redeem
  → the worker generates an Inveterate discount code → shown to copy + optional auto-apply to the
  cart (no checkout needed). Falls back to the /community/membership portal link when JS is off.
  Contract + flow: docs/tasks/09-redemption.md. Worker config is read from [data-wb-account].

  @param {string} label - button label (already translated)
  @param {string} link - no-JS fallback href (Inveterate portal link)
  @param {string} class - button classes
  @param {string} balance_formatted - current credit balance, formatted (e.g. "$4.20")
{%- enddoc -%}

<div class="wb-redeem-root"
     x-data="creditRedemption({ balanceFormatted: {{ balance_formatted | default: '' | json }}, currency: {{ shop.currency | json }} })"
     @click.prevent="open()"
     @keydown.escape.window="isOpen && close()">

  {%- render 'wb-button', style: 'secondary-gold', label: label, link: link, class: class -%}

  <template x-teleport="body">
    <div x-show="isOpen" x-cloak class="fixed inset-0 z-[99999] flex items-center justify-center px-4" role="dialog" aria-modal="true" aria-label="{{ 'customer.dashboard.redeem_title' | t }}" style="display:none">

      {%- comment -%} Backdrop {%- endcomment -%}
      <div class="absolute inset-0 bg-black/50" x-show="isShown" @click="close()" x-transition.opacity.duration.300ms></div>

      {%- comment -%} Panel {%- endcomment -%}
      <div class="relative z-10 w-full max-w-[440px] rounded-[10px] bg-foam shadow-[0px_4px_16px_0px_rgba(0,0,0,0.35)] p-6 md:!p-8"
           x-show="isShown" @click.stop
           x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0"
           x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0">

        <div class="flex items-start justify-between mb-5">
          <h2 class="font-kurdis-condensed font-extrabold text-espresso text-[22px] leading-none">{{ 'customer.dashboard.redeem_title' | t }}</h2>
          <button type="button" @click="close()" aria-label="{{ 'customer.dashboard.redeem_close' | t }}" class="shrink-0 -mt-1 -mr-1 p-1 text-espresso hover:opacity-70">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </button>
        </div>

        {%- comment -%} ---------- Step: select ---------- {%- endcomment -%}
        <div x-show="step === 'select'">
          <p class="font-kurdis-condensed font-extrabold text-espresso text-[18px] leading-none mb-3">{{ 'customer.dashboard.redeem_for' | t }}</p>

          <div class="rounded-[10px] border border-espresso/20 p-4 mb-5">
            <div class="flex items-center !gap-2 font-kurdis-semi-condensed font-bold text-espresso text-[14px] mb-3">
              <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 12v9H4v-9M2 7h20v5H2zM12 22V7M12 7S8 7 8 4.5 12 7 12 7zm0 0s4 0 4-2.5S12 7 12 7z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
              {{ 'customer.dashboard.redeem_single_order' | t }}
            </div>

            <label class="flex items-start !gap-3 py-2 cursor-pointer">
              <input type="radio" name="wb-redeem-mode" value="full" x-model="mode" class="mt-0.5 accent-dark-gold w-4 h-4">
              <span class="leading-tight">
                <span class="block font-kurdis-semi-condensed font-bold text-espresso text-[14px]">{{ 'customer.dashboard.redeem_fully' | t }}</span>
                <span class="block font-kurdis-semi-condensed text-espresso/60 text-[12px]"><span x-text="balanceFormatted"></span> {{ 'customer.dashboard.redeem_available_suffix' | t }}</span>
              </span>
            </label>

            <label class="flex items-start !gap-3 py-2 cursor-pointer">
              <input type="radio" name="wb-redeem-mode" value="partial" x-model="mode" class="mt-0.5 accent-dark-gold w-4 h-4">
              <span class="leading-tight w-full">
                <span class="block font-kurdis-semi-condensed font-bold text-espresso text-[14px]">{{ 'customer.dashboard.redeem_partially' | t }}</span>
                <span x-show="mode === 'partial'" x-cloak class="mt-2 block" style="display:none">
                  <label class="block font-kurdis-semi-condensed text-espresso/60 text-[11px] mb-1">{{ 'customer.dashboard.redeem_amount_label' | t }}</label>
                  <input type="number" min="0" step="0.01" x-model="amount" @click.stop
                         class="w-full rounded-[6px] border border-espresso/30 bg-white px-3 py-2 text-espresso text-[14px] focus:outline-none focus:border-dark-gold">
                </span>
              </span>
            </label>
          </div>

          <p x-show="error === 'invalid_amount'" x-cloak class="font-kurdis-semi-condensed text-[12px] text-[#BD2121] mb-3" style="display:none">{{ 'customer.dashboard.redeem_err_invalid_amount' | t }}</p>
          <p x-show="error && error !== 'invalid_amount'" x-cloak class="font-kurdis-semi-condensed text-[12px] text-[#BD2121] mb-3" style="display:none">{{ 'customer.dashboard.redeem_err_failed' | t }}</p>

          <button type="button" @click="submit()" :disabled="loading"
                  class="btn secondary-gold shadow-button !w-full !h-[44px] !text-[15px]"
                  :class="loading && 'opacity-60 pointer-events-none'">
            <span class="mt-0.5" x-text="loading ? '…' : '{{ 'customer.dashboard.redeem_generate' | t }}'"></span>
          </button>
        </div>

        {%- comment -%} ---------- Step: result ---------- {%- endcomment -%}
        <div x-show="step === 'result'" x-cloak style="display:none">
          <p class="font-kurdis-semi-condensed font-bold text-espresso text-[13px] mb-2">{{ 'customer.dashboard.redeem_your_code' | t }}</p>
          <div class="flex items-center !gap-2 mb-4">
            <code class="flex-1 rounded-[6px] border border-dashed border-espresso/40 bg-white px-3 py-3 font-kurdis-semi-condensed font-bold text-espresso text-[16px] tracking-wide break-all" x-text="result && result.code"></code>
            <button type="button" @click="copyCode()" class="shrink-0 rounded-[6px] border border-espresso/30 px-3 py-3 font-kurdis-semi-condensed font-bold text-espresso text-[12px] hover:bg-espresso/5">
              <span x-text="copied ? '{{ 'customer.dashboard.redeem_copied' | t }}' : '{{ 'customer.dashboard.redeem_copy' | t }}'"></span>
            </button>
          </div>

          <p class="font-kurdis-semi-condensed text-espresso/70 text-[12px] leading-snug mb-4">{{ 'customer.dashboard.redeem_note' | t }}</p>

          <p class="font-kurdis-semi-condensed text-espresso text-[12px] mb-4">{{ 'customer.dashboard.redeem_remaining' | t }} <span class="font-bold text-dark-gold" x-text="result && result.new_balance_formatted"></span></p>

          <button type="button" @click="applyToCart()" x-show="!isMock" class="btn secondary-gold shadow-button !w-full !h-[44px] !text-[15px]">
            <span class="mt-0.5">{{ 'customer.dashboard.redeem_apply' | t }}</span>
          </button>
        </div>

      </div>
    </div>
  </template>
</div>
