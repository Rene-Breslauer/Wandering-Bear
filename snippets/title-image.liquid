<picture>
    <source srcset="{{ image | image_url: width: 1920 }}" media="(min-width: 1920px)">
    <source srcset="{{ image | image_url: width: 1440 }}" media="(min-width: 1440px)">
    <source srcset="{{ image | image_url: width: 1200 }}" media="(min-width: 1200px)">
    <source srcset="{{ image | image_url: width: 1024 }}" media="(min-width: 1024px)">
    {% if image_mobile != blank %}
        <source srcset="{{ image_mobile | image_url: width: 480 }}" media="(min-width: 480px)">
        <source srcset="{{ image_mobile | image_url: width: 320 }}" media="(min-width: 320px)">
        <img src="{{ image_mobile | image_url: width: 365 }}" alt="{{ alt }}" class="{{ class }}">
    {% else %}
        <source srcset="{{ image | image_url: width: 768 }}" media="(min-width: 768px)">
        <source srcset="{{ image | image_url: width: 480 }}" media="(min-width: 480px)">
        <source srcset="{{ image | image_url: width: 320 }}" media="(min-width: 320px)">
        <img src="{{ image | image_url: width: 365 }}" alt="{{ alt }}" class="{{ class }}">
    {% endif %}
</picture>