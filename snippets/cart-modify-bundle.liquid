<div class="">
    <div x-ref="cartModifyBundleHeader" class="flex justify-between items-center pt-6 px-4.5 pb-1">
    <button class="cursor-pointer flex items-center gap-1 font-kurdis text-xs text-espresso font-bold" type="button" @click="backToCart()">
    {% render 'icons', icon: 'chevron-left', class: 'text-sm' %} 
    Back to Cart
    </button>

    <h2 class="h6 uppercase font-gothic_condensed font-bold text-bear-black text-lg">Modify <span x-text="activeBundleDetails.headline"></span> Bundle</h2>
    </div>
    <div class="p-3">

        {% comment %} 96oz Bundle Start {% endcomment %}
          <template x-if="activeBundleDetails && activeBundleDetails.bundle_products && Object.keys(activeBundleDetails.bundle_products).length > 0">
            <div x-ref="cartModifyBundleContent" class="wb-flex gap-1 flex-col w-full bg-white/50 p-4.5 rounded-[5px] font-kurdis relative button-shadow uppercase mb-2.5">
            <div class="flex items-center justify-between">
              <template x-for="(product, index) in Object.keys(activeBundleDetails.bundle_products)" :key="index">
                  <div 
                  :class="['items-start', 'items-center', 'items-end'][index] || 'items-start'"
                  class="col-width flex flex-col items-center justify-center font-gothic_condensed uppercase font-bold" style="{{ col_width_styles }} text-bear-black">
                      <span x-text="index + 1 + ' ' + activeBundleDetails.singular_label"></span>
                  </div>
              </template>
            </div>
              <div class="wb-flex items-center justify-between relative w-full">
                <template x-for="(product, index) in Object.keys(activeBundleDetails.bundle_products)" :key="index">
                    <div class="wb-flex items-center justify-between relative w-full"
                    :class="['justify-start', 'justify-center', 'justify-end'][index] || 'justify-start'">
                      <div :data-tier="index + 1" class="col-width flex items-center justify-center" style="{{ col_width_styles }}">
                        <div class="wb-flex items-center justify-center h-4.5 w-4.5 rounded-full mx-auto transition-all duration-300 relative z-[2] outline outline-[#CFBDB1] bg-[#F2E6DC]"
                        :class="activeBundleCount >= index + 1 ? '!outline-gold !bg-white' : 'outline-[#CFBDB1] bg-[#F2E6DC]'"
                        >
                          <div class="wb-flex items-center justify-center h-3.5 w-3.5 bg-[#CFBDB1] rounded-full bg-transparent"
                          :class="activeBundleCount >= index + 1 ? '!bg-gold' : 'bg-transparent'"
                          ></div>
                        </div>
                      </div>
                    </div>
                </template>
                <div class="absolute {% if col_width == 121 %} left-[50px] right-[50px] md:right-[66px] md:left-[66px] {% else %} right-0 left-0 {% endif %} rounded-full mx-auto">
                  <div class="relative h-[2px] bg-[#CFBDB1]">
                    <div class="absolute top-0 left-0 h-full max-w-full bg-gold transition-all duration-300"
                    :style="{ width: progressBarWidth }"
                    ></div>
                  </div>
                </div>
            </div>
            <div class="flex items-center justify-between text-[12px]">
              <template x-for="(product, index) in Object.keys(activeBundleDetails.bundle_products)" :key="index">
                <div :data-tier="index + 1"
                class="w-1/3 wb-flex gap-1 flex-col items-center justify-center"
                :class="['items-start', 'items-center', 'items-end'][index] || 'items-start'"            
                style="{{ col_width_styles }}">
                  <div
                  class="text-bear-black font-semibold font-kurdis-semi-condensed leading-[120%] normal-case inline-block whitespace-nowrap h-full">
                    <span x-text="tempBundle[0].variants[index].price + '/ea'"></span>
                  </div>
                </div>
              </template>
            </div>
          </div>
          </template>

          {% comment %} 96oz Bundle End {% endcomment %}

        <form @submit.prevent="updateBundle()" class="wb-flex">
            <div class="wb-flex flex-col gap-3 max-h-[calc(100vh-250px)] overflow-auto">
              <template x-for="item in tempBundle" :key="item.id">
                <div :data-key="item.id" class="wb-flex bg-[#FFFFFF80] rounded-[5px] p-3 gap-3">
                  <div class="w-[68px]">
                    <img :src="item.image" :alt="item.title" class="!w-full !h-full object-cover">
                  </div>
                  <div class="flex items-center justify-between w-full gap-3">
                    <div class="w-full wb-flex flex-col">
                      <h3 class="font-gothic_condensed uppercase font-bold text-bear-black text-lg" x-text="item.flavorName || item.title"></h3>
                      <span class="font-kurdis-semi-condensed text-xs text-kraft font-bold lowercase" x-text="item.price + ' per ' + activeBundleDetails.singular_label"></span>
                    </div>
            
                    <div x-show="item.quantity === 0" class="group relative flex items-center justify-center cursor-pointer shadow-button w-20 min-w-20" @click="bundleIncrement(item.id)">
                      <span class="absolute whitespace-nowrap text-cream uppercase font-kurdis-condensed text-sm font-bold">+ Add</span>
                      <svg class="text-kraft group-hover:text-gold" xmlns="http://www.w3.org/2000/svg" width="80" height="40" viewBox="0 0 80 40" fill="none">
                        <path d="M0.740482 4.15938C0.111533 6.47951 0.0863218 9.21376 0.0757066 11.8348C0.0504956 18.0724 0.0266114 24.3075 0.00140038 30.5451C-0.0052341 32.2401 -0.00390717 34.0047 0.38222 35.5249C1.31237 39.18 2.48668 39.9773 5.96049 39.9773C29.2608 39.9773 52.5624 40.1137 75.8641 39.7175C76.6907 39.7047 77.5983 39.787 78.2764 38.8687C80.1141 36.3814 79.9138 31.8363 79.858 28.4641C79.7545 22.1854 80 17.0255 80 10.7442C80 6.3509 79.7466 4.58636 78.9955 2.84755C78.0335 0.61745 76.0299 0.712621 74.5292 0.653461C64.6624 0.259913 54.7903 0.0567088 44.9195 0.0104091C34.985 -0.0384628 25.0506 0.0850031 15.1161 0.375662C12.3137 0.457973 9.5126 0.553144 6.71152 0.663749C4.59644 0.74606 1.91346 -0.159357 0.740482 4.15938Z" fill="currentColor"/>
                      </svg>
                    </div>
                    <div x-show="item.quantity > 0" class="w-fit wb-flex justify-end items-center">
                      <div class="wb-flex items-center gap-2 w-fit justify-end">
                        <button class="group relative cursor-pointer wb-flex justify-center items-center shadow-button w-[30px]" type="button" @click="bundleDecrement(item.id)">
                          <span class="absolute whitespace-nowrap text-cream uppercase font-kurdis text-sm font-bold">-</span>
                          <svg class="text-espresso group-hover:text-gold" xmlns="http://www.w3.org/2000/svg" width="30" height="40" viewBox="0 0 30 40" fill="none">
                            <path d="M0.277681 4.15938C0.0418248 6.47951 0.0323707 9.21376 0.02839 11.8348C0.0189358 18.0724 0.00997928 24.3075 0.000525143 30.5451C-0.00196279 32.2401 -0.0014652 34.0047 0.143332 35.5249C0.49214 39.18 0.932504 39.9773 2.23518 39.9773C10.9728 39.9773 19.7109 40.1137 28.449 39.7175C28.759 39.7047 29.0994 39.787 29.3536 38.8687C30.0428 36.3814 29.9677 31.8363 29.9468 28.4641C29.9079 22.1854 30 17.0256 30 10.7442C30 6.3509 29.905 4.58636 29.6233 2.84755C29.2626 0.617449 28.5112 0.712621 27.9485 0.653461C24.2484 0.259913 20.5464 0.0567088 16.8448 0.0104091C13.1194 -0.0384628 9.39396 0.0850031 5.66853 0.375662C4.61763 0.457973 3.56722 0.553144 2.51682 0.663749C1.72367 0.74606 0.717547 -0.159357 0.277681 4.15938Z" fill="currentColor"/>
                          </svg>
                        </button>
              
                        <span class="font-kurdis-semi-condensed text-lg text-espresso font-bold w-6 text-center" x-text="item.quantity"></span>
                
                        <div class="flex items-center gap-2">
                        <button class="group relative cursor-pointer wb-flex justify-center items-center shadow-button w-[30px]" type="button" @click="bundleIncrement(item.id)">
                          <span class="absolute whitespace-nowrap text-cream uppercase font-kurdis text-sm font-bold">+</span>
                          <svg class="text-espresso group-hover:text-gold" xmlns="http://www.w3.org/2000/svg" width="30" height="40" viewBox="0 0 30 40" fill="none">
                            <path d="M0.277681 4.15938C0.0418248 6.47951 0.0323707 9.21376 0.02839 11.8348C0.0189358 18.0724 0.00997928 24.3075 0.000525143 30.5451C-0.00196279 32.2401 -0.0014652 34.0047 0.143332 35.5249C0.49214 39.18 0.932504 39.9773 2.23518 39.9773C10.9728 39.9773 19.7109 40.1137 28.449 39.7175C28.759 39.7047 29.0994 39.787 29.3536 38.8687C30.0428 36.3814 29.9677 31.8363 29.9468 28.4641C29.9079 22.1854 30 17.0256 30 10.7442C30 6.3509 29.905 4.58636 29.6233 2.84755C29.2626 0.617449 28.5112 0.712621 27.9485 0.653461C24.2484 0.259913 20.5464 0.0567088 16.8448 0.0104091C13.1194 -0.0384628 9.39396 0.0850031 5.66853 0.375662C4.61763 0.457973 3.56722 0.553144 2.51682 0.663749C1.72367 0.74606 0.717547 -0.159357 0.277681 4.15938Z" fill="currentColor"/>
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              </template>
            </div>
          
            <div x-ref="cartModifyBundleFooter" class="fixed bottom-0 left-0 right-0 pt-3 pb-9 flex justify-center items-center bg-cream">
              <button type="submit" class="relative cursor-pointer wb-flex justify-center items-center"
              :class="{ 'opacity-50 !pointer-events-none': !bundleChanged }"
              :disabled="!bundleChanged">
                <span class="absolute whitespace-nowrap text-cream uppercase font-kurdis-condensed text-xl font-bold">Update bundle</span>
                <svg class="text-espresso" xmlns="http://www.w3.org/2000/svg" width="330" height="50" viewBox="0 0 330 50" fill="none">
                  <path d="M3.05449 5.19922C0.460073 8.09938 0.356077 11.5172 0.31229 14.7935C0.208294 22.5905 0.109772 30.3843 0.00577657 38.1813C-0.0215907 40.3002 -0.0161172 42.5059 1.57666 44.4061C5.41354 48.9749 10.2575 49.9717 24.587 49.9717C120.701 49.9717 216.82 50.1421 312.939 49.6469C316.349 49.6309 320.093 49.7337 322.89 48.5859C330.471 45.4767 329.644 39.7954 329.414 35.5802C328.987 27.7317 330 21.2819 330 13.4303C330 7.93862 328.955 5.73295 325.857 3.55944C321.888 0.771812 313.623 0.890777 307.433 0.816826C266.732 0.324891 226.01 0.070886 185.293 0.0130114C144.313 -0.0480785 103.334 0.106254 62.3538 0.469578C50.7939 0.572466 39.2395 0.691431 27.685 0.829687C18.9603 0.932575 7.89302 -0.199196 3.05449 5.19922Z" fill="currentColor"/>
                </svg>
              </button>
            </div>
          </form>
    </div>
</div>
