{%- doc -%}
    Renders a button with the given style and label.
    @param {string} style - The style of the button
    @param {string} label - The label of the button
    @param {string} link - The link of the button
    @param {string} class - The class of the button (optional)
    @param {number} width - The width of the button (optional)
    @param {number} height - The height of the button (optional)
    @param {string} button_bg - The background color of the button (optional)
    @param {string} button_text - The text color of the button (optional)
    @param {string} button_border - The border color of the button (optional)
    @param {string} button_hover_bg - The background color of the button on hover (optional)
    @param {string} button_hover_text - The text color of the button on hover (optional)
    @param {string} button_hover_border - The border color of the button on hover (optional)
{%- enddoc -%}

{%- if width -%}
    {%- assign width = width -%}
{%- else -%}
    {%- assign width = 213 -%}
{%- endif -%}

{%- if height -%}
    {%- assign height = height -%}
{%- else -%}
    {%- assign height = 51 -%}
{%- endif -%}

{% capture button_size %}
    --width: {{ width }}px;
    --height: {{ height }}px;
{% endcapture %}

{% if style == 'custom' %}
    {% capture custom_svg_styles %}
        --svg-fill: {{ button_bg }};
        --svg-hover-fill: {{ button_hover_bg }};
    {% endcapture %}
    {% capture custom_styles %}
       --button-text: {{ button_text }};
       --button-border: {{ button_border }};
       --button-hover-text: {{ button_hover_text }};
       --button-hover-border: {{ button_hover_border }};
    {% endcapture %}
{% endif %}


{%- capture svg_filter -%}
    {%- if style == 'primary' -%}
        <svg preserveAspectRatio="none" class="btn-svg w-full h-full drop-shadow-[4px_4px_4px_rgba(0,0,0,0.25)]"  width="280" height="47" viewBox="0 0 280 47" fill="none">
