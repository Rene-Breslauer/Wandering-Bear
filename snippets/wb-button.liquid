        </svg>
    {%- elsif style == 'custom' -%}
        <svg preserveAspectRatio="none" class="btn-svg w-full h-full drop-shadow-[4px_4px_4px_rgba(0,0,0,0.25)]"  width="280" height="47" viewBox="0 0 280 47" fill="none" style="{{ custom_svg_styles }}">
