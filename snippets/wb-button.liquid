        </svg>
    {%- endif -%}
{%- endcapture -%}


<a href="{{ link }}" class="btn {{ style }} {% if class %} {{ class }} {% endif %}" {% if custom_styles %} style="{{ custom_styles }}" {% endif %}>
    <span class="">{{ label }}</span>
    {{ svg_filter }}
</a>
