

{% if closest.product == blank %}
    {% assign text = 'placeholders.product_title' | t %}
    {% assign product_title = '<p role="heading" aria-level="3">' | append: text | append: '</p>' %}
    {% render 'text', fallback_text: product_title, block: block %}
  {% else %}
    {% assign product_title = '<p role="heading" aria-level="3">' | append: closest.product.title | append: '</p>' %}
    <a
      class="block user-select-text text-bear-black! md:flex! md:gap-2! md:whitespace-nowrap! md:items-end!"
      ref="productTitleLink"
      href="{{ closest.product.selected_or_first_available_variant.url }}"
    >
      <span class="font-gothic_condensed text-[35px] lg:text-[45px]! font-extrabold leading-[100%] uppercase">{{ block.settings.product_title }}</span>
      <span class="font-kurdis-semi-condensed text-base font-bold leading-[120%] whitespace-nowrap md:text-[20px]{% if template.suffix == 'gallon' %} ml-2.5 md:ml-1.5{% endif %}{% if template.suffix == '96oz' or template.suffix == '32oz' or template.suffix == 'concentrate' %} uppercase{% elsif template.suffix != 'single-serve' %} capitalize{% endif %}">
        {{ block.settings.product_title_small | replace: '8 oz', '8oz' }}
      </span>
    </a>
  {% endif %}

  {% schema %}
  {
    "name": "Product Title Bundle",
    "tag": null,
    "settings": [
       {
        "type": "text",
        "id": "product_title",
        "label": "Product Title",
        "default": "Product Title",
        "info": "Large text for the product title"
       },
       {
        "type": "text",
        "id": "product_title_small",
        "label": "Product Title Small",
        "default": "Product Title Small",
        "info": "Small text for the product title"
       }
    ],
    "presets": [
      {
        "name": "Product Title Bundle",
        "category": "t:categories.product"
      }
    ]
  }
  {% endschema %}
