{%  liquid 
    assign color_scheme = block.settings.color_scheme
    assign background_color = color_scheme.settings.background
    assign text_color = color_scheme.settings.foreground
    assign title = block.settings.title
    assign subtitle = block.settings.subtitle
    assign button_label = block.settings.button_label
    assign button_link = block.settings.button_link
    assign image = block.settings.image
 %}
<div class="wb-flex items-stretch relative w-full" style="background-color: {{ background_color }}">
  {% if image != blank %}
    <div class="!max-w-[130px] md:!max-w-[104px] w-full h-full wb-flex">
    {% render 'picture', source: image, class: 'w-full !h-full object-cover', alt: image.alt, width: 1920, height: 1080, preload: 'lazy', loading: 'lazy' %}
    </div>
  {% endif %}
  <div class="wb-flex flex-col gap-4 p-4">
    <h2 class="text-base font-gothic_condensed font-bold leading-[100%]" style="color: {{ text_color }}">{{ title }}</h2>
    <span class="text-[12px] font-semibold font-kurdis leading-[120%]" style="color: {{ text_color }}">{{ subtitle }}</span>
    {% if button_label != blank and button_link != blank %}
      {% render 'wb-button', style: 'primary', class: 'mt-4 z-[3] md:!ml-5 !w-[266px] !h-[51px]', width: 253, height: 49, label: button_label, link: button_link %}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Cross-sell Call-out",
  "tag": null,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Looking for cold brew on-the-go?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Try our new cold brew lattes, available in 3 flavors!"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Cross Sell Call-out",
      "category": "t:categories.custom"
    }
  ]
}
{% endschema %}
