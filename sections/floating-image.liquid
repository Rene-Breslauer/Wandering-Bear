{% liquid
    assign color_scheme = section.settings.color_scheme
    assign background_image = section.settings.background_image
    assign background_image_mobile = section.settings.background_image_mobile
    assign floating_image = section.settings.floating_image
    assign floating_image_mobile = section.settings.floating_image_mobile
    assign title_type = section.settings.title_type
    assign title = section.settings.title
    assign title_image = section.settings.title_image
    assign bulletpoints = section.blocks | where: "type", "bulletpoint"
%}

<div class="relative" style="background-color: {{ color_scheme.background }}">
    {% if background_image != blank %}
        {% render 'picture', source: background_image, class: 'w-full h-full object-cover absolute inset-0' %}
    {% endif %}
    {% if background_image_mobile != blank %}
        {% render 'picture', source: background_image_mobile, class: 'w-full h-full object-cover absolute inset-0' %}
    {% endif %}
    {% if floating_image != blank %}
        {% render 'picture', source: floating_image, class: 'w-full h-full object-cover absolute inset-0' %}
    {% endif %}
    {% if floating_image_mobile != blank %}
        {% render 'picture', source: floating_image_mobile, class: 'w-full h-full object-cover absolute inset-0' %}
    {% endif %}
    <div class="container mx-auto relative z-[2]">
        <div class="w-1/2 wb-flex flex-col">
            <div class="wb-flex flex-col">
                {% if title_type == 'text' %}
                    <h2 class="h2 text-gold">{{ title }}</h2>
                {% elsif title_type == 'image' %}
                    {% if title_image != blank %}
                        {{ title_image | image_url: width: 365 | image_tag: class: 'w-full max-h-full object-contain', alt: title_alt }}
                    {% endif %}
                {% endif %}
            </div>
            <div class="wb-flex flex-col">
            {% for bullet in bulletpoints %}
                <div class="wb-flex gap-2">
                    {{ bullet.settings.image | image_url: width: 20 | image_tag: class: '!h-2 !w-auto', alt: bullet.settings.title }}
                    <span class="body">{{ bullet.settings.title }}</span>
                </div>
            {% endfor %}
            </div>
        </div>
    </div>
</div>

{% schema %}
    {
        "name": "Floating Image",
        "settings": [
            {
                "type": "color_scheme",
                "id": "color_scheme",
                "label": "Color Scheme",
                "default": "scheme-1"
            },
            {
                "type": "image_picker",
                "id": "background_image",
                "label": "Background Image"
            },
            {
                "type": "image_picker",
                "id": "background_image_mobile",
                "label": "Background Image Mobile"
            },
            {
                "type": "image_picker",
                "id": "floating_image",
                "label": "Floating Image"
            },
            {
                "type": "image_picker",
                "id": "floating_image_mobile",
                "label": "Floating Image Mobile"
            },
            {
                "type": "select",
                "id": "title_type",
                "label": "Title Type",
                "options": [
                    {
                        "value": "text",
                        "label": "Text"
                    },
                    {
                        "value": "image",
                        "label": "Image"
                    }
                ],
                "default": "text"
            },
            {
                "type": "text",
                "id": "title",
                "label": "Title",
                "visible_if": "{{ section.settings.title_type == 'text' }}"
            },
            {
                "type": "image_picker",
                "id": "title_image",
                "label": "Title Image",
                "visible_if": "{{ section.settings.title_type == 'image' }}"
            },
            {
                "type": "text",
                "id": "title_alt",
                "label": "Title Alt",
                "visible_if": "{{ section.settings.title_type == 'image' }}"
            }
        ],
        "blocks": [
            {
                "type": "bulletpoint",
                "name": "Bulletpoint",
                "settings": [
                    {
                        "type": "image_picker",
                        "id": "image",
                        "label": "Image"
                    },
                    {
                        "type": "text",
                        "id": "title",
                        "label": "Title"
                    }
                ]
            }
        ],
        "presets": [
            {
                "name": "Floating Image"
            }
        ]
    }
{% endschema %}