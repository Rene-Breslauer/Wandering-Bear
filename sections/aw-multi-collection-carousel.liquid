{% liquid
    assign collection_list = section.settings.collection_list
    assign color_scheme = section.settings.color_scheme
    assign title_image = section.settings.title_image
    assign active_collection_title = section.blocks[0].settings.title
    assign active_collection_accent_text = section.blocks[0].settings.accent_text
    assign active_collection_handle = section.blocks[0].settings.collection.handle
%}

{% capture slide_styles %}
    width: calc(100% / 5.5);
{% endcapture %}

<div x-data="swiperSlider('{{ active_collection_title }}', '{{ active_collection_accent_text }}','{{ active_collection_handle }}')" class="relative z-1 pt-5 pb-[53px]" style="background-color: {{ color_scheme.settings.background }}">
    <div class="container mx-auto flex justify-start relative">
    {% if title_image != blank %}
        <div class="h-[100px] w-[263px] mb-8 relative z-[2]">
            {{ title_image | image_url: width: 365 | image_tag: class: 'w-full max-h-full object-contain', alt: title_alt }}
        </div>
    {% endif %}

       {% comment %} Custom Dropdown {% endcomment %}
        <div class="wb-flex flex-col">
            <span class="body uppercase mb-2">Select your size</span>
            <div class="w-[249px] relative">
                <div @click="toggleDropdown()" class="flex items-center justify-between relative rounded-[4px] cursor-pointer bg-white p-3 border border-espresso">
                    <div class="flex items-center whitespace-nowrap">
                        <span x-text="activeCollectionTitle" class="font-kurdis text-base font-bold whitespace-nowrap">{{ section.blocks[0].settings.title }}</span>
                        <span x-text="activeCollectionAccentText" class="font-parslay whitespace-nowrap text-gold">{{ section.blocks[0].settings.accent_text }}</span>
                    </div>
                    <span :class="{ 'rotate-180': dropdownOpen }" class="!min-w-4 transition-transform duration-300">
                        {% render 'icons', icon: 'chevron-down' %}
                    </span>
                </div>
                <div x-show="dropdownOpen"
                 @click.outside="dropdownOpen = false"
                 x-transition:enter="transition ease-out duration-300"
                 x-transition:enter-start="transform -translate-y-1"
                 x-transition:enter-end="opacity-100 transform translate-y-0"
                 x-transition:leave="transition ease-in duration-300"
                 x-transition:leave-start="opacity-100 transform translate-y-0"
                 x-transition:leave-end="transform -translate-y-1"
                 x-cloak class="absolute top-full left-0 w-full bg-white z-[2] overflow-hidden -mt-1 border-t border-espresso"
                 :class="{ 'rounded-b-[10px]': dropdownOpen }">
                    <ul class="custom-dropdown-list overflow-hidden !-mt-[2px] bg-white border border-espresso rounded-b-[10px]">
                    {% for block in section.blocks %}
                        {% liquid
                            assign collection = block.settings.collection
                        %}
                        <li x-cloak x-show="activeCollectionHandle !== '{{ collection.handle }}'" @click="changeCollection('{{ block.settings.title }}', '{{ block.settings.accent_text }}', '{{ collection.handle }}')"  
                        class="dropdown-item p-3 border-t border-espresso cursor-pointer"
                        :class="{ 'active': activeCollectionHandle === '{{ collection.handle }}' }"
                        >
                            <span class="font-kurdis text-base font-bold">{{ block.settings.title }}</span>
                            <span class="font-parslay text-gold">{{ block.settings.accent_text }}</span>
                        </li>
                    {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <div class="swiper multi-collection-slider -mt-10">
        <div class="swiper-wrapper">
            {% for product in section.blocks[0].settings.collection.products %}
                {% liquid
                    assign collection = block.settings.collection
                %}
                {% if product.metafields.custom.carousel_image != blank %}
                    {% render 'multi-coll-carousel-slide', product: product %}
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>

{% schema %}
    {
        "name": "AW Multi Coll Carousel",
        "settings": [
            {
                "type": "color_scheme",
                "id": "color_scheme",
                "label": "Color Scheme",
                "default": "scheme-1"
            },
            {
                "type": "image_picker",
                "id": "title_image",
                "label": "Title Image"
            }

        ],
        "blocks": [
            {
                "type": "collection",
                "name": "Collection",
                "settings": [
                    {
                        "type": "collection",
                        "id": "collection",
                        "label": "Collection"
                    },
                    {
                        "type": "text",
                        "id": "title",
                        "label": "Title"
                    },
                    {
                        "type": "text",
                        "id": "accent_text",
                        "label": "Accent Text"
                    }
                ]
            }
        ],
    "presets": [
        {
            "name": "AW Multi Coll Carousel"
        }
    ]
}
{% endschema %}