

<script
  src="{{ 'results-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% javascript %}
  const url = new URL(window.location.href);
  if (url.hash) {
    document.addEventListener(
      'DOMContentLoaded',
      () => {
        const card = document.getElementById(url.hash.slice(1));
        if (card) {
          card.scrollIntoView({ behavior: 'instant' });
        }
      },
      { once: true }
    );
  }
{% endjavascript %}

{% comment %} We always render this full-width, as the child blocks have width: page/full settings {% endcomment %}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<picture>
  <source srcset="{{ section.settings.image | image_url: width: 1920 }}" media="(min-width: 750px)">
  <source srcset="{{ section.settings.image | image_url: width: 750 }}" media="(max-width: 749px)">
  <img class="absolute top-0 left-0 w-full object-cover h-[400px] -z-[1]" src="{{ section.settings.image | image_url: width: 1920 }}" alt="{{ section.settings.image.alt }}" width="1920" height="1080" loading="lazy">
</picture>
<results-list
  class="section product-grid-container relative z-1 color-{{ section.settings.color_scheme }}"
  style="--padding-block-start: {{ section.settings.padding-block-start }}px; --padding-block-end: {{ section.settings.padding-block-end }}px;"
  section-id="{{ section.id }}"
  infinite-scroll="{{ section.settings.enable_infinite_scroll }}"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div class="w-full mt-[40px] mb-[50px] gap-2">
      <div class="mx-auto flex flex-col gap-2">
        <h1 class="display-lg font-gothic_condensed uppercase font-bold text-[60px] text-center leading-[1.1] !m-0">{{ section.settings.title }}</h1>
        {% if section.settings.description != blank %}
          <p class="body font-kurdis-semi-condensed font-semibold text-[12px] text-center leading-[1.6] !m-0">
            {{- section.settings.description -}}
          </p>
        {% endif %}
      </div>
  </div>
  {% content_for 'block',
      type: 'filter-pills',
      id: 'filter-pills'
    %}
    {% content_for 'block',
      type: 'filters',
      id: 'filters',
      results: collection,
      results_size: collection.products_count
    %}
  <div
    class="collection-wrapper !max-w-[970px] mx-auto grid gap-style{% if section.settings.product_grid_width == 'full-width' %} collection-wrapper--grid-full-width{% endif %}"
  >
    
   

 

    {% assign products_per_page = 24 %}

    {% if section.settings.enable_infinite_scroll == false %}
      {% assign products_per_page = section.settings.products_per_page %}
    {% endif %}

    {%- comment -%}
      Optional grouping. `custom.sort` is a list of `size` metaobjects; each one becomes
      a titled group holding the products whose own `custom.size` points at that same
      entry. Matching on the metaobject rather than a tag string means a renamed or
      re-cased label can't silently drop a product out of its group.

      The groups render as full-width items INSIDE the single product grid rather than
      as one `product-grid` per group: that snippet hardcodes `id="ResultsList"` and the
      `grid` / `viewMoreNext` refs that `results-list.js` binds to, so rendering it more
      than once would duplicate ids and break infinite scroll and pagination.
    {%- endcomment -%}
    {% assign sort_groups = collection.metafields.custom.sort.value %}

    {% paginate collection.products by products_per_page %}
      {% capture children %}
        {% assign card_index = 0 %}
        {% assign grouped_ids = '' %}

        {% for group in sort_groups %}
          {% assign group_handle = group.system.handle %}
          {% if group_handle == blank %}
            {% continue %}
          {% endif %}

          {%- comment -%}
            Capture first so an empty group renders no heading.

            The `grouped_ids` guard also feeds the leftover pass below, so every product
            is rendered exactly once no matter how the metafields are configured.
          {%- endcomment -%}
          {% capture group_items %}
            {% for product in collection.products %}
              {% assign product_token = ',' | append: product.id | append: ',' %}
              {% if product.metafields.custom.size.value.system.handle == group_handle %}
                {% unless grouped_ids contains product_token %}
                  <li
                    id="{{ section.id }}-{{ product.id }}"
                    class="product-grid__item product-grid__item--{{ card_index }}"
                    data-page="{{ paginate.current_page }}"
                    data-product-id="{{ product.id }}"
                    ref="cards[]"
                  >
                    {% # theme-check-disable %}
                    {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product, collection_image: true %}
                    {% # theme-check-enable %}
                  </li>
                  {% assign card_index = card_index | plus: 1 %}
                  {% assign grouped_ids = grouped_ids | append: product_token %}
                {% endunless %}
              {% endif %}
            {% endfor %}
          {% endcapture %}

          {%- comment -%}
            Strip before testing: the capture always holds the loop's whitespace, so an
            empty group would otherwise pass a bare `!= blank` and print a heading with
            no products under it.
          {%- endcomment -%}
          {% assign group_items = group_items | strip %}
          {% if group_items != blank %}
            {%- comment -%}
              role="presentation" keeps the list's items products only, while the h2
              stays in the heading order so screen readers can jump between groups.
            {%- endcomment -%}
            {%- comment -%}
              Per the design the rule sits UNDER the heading row, between the copy and
              that group's products — not above the heading.
            {%- endcomment -%}
            <li
              class="product-grid__group col-span-full flex flex-wrap items-baseline gap-x-3 gap-y-1 pb-2 border-b border-[#431A031A]{% unless forloop.first %} mt-6{% endunless %}"
              role="presentation"
            >
              <h2 class="font-gothic_condensed uppercase font-bold text-[25px] leading-[1.1] !m-0">
                {{- group.title | default: group.display_name -}}
              </h2>
              {% if group.description != blank %}
                <p class="font-kurdis-semi-condensed font-semibold text-[12px] leading-[1.6] !m-0">
                  {{- group.description -}}
                </p>
              {% endif %}
            </li>
            {{ group_items }}
          {% endif %}
        {% endfor %}

        {%- comment -%}
          Everything no group claimed. Also the whole grid when `custom.sort` is unset,
          so an unconfigured collection keeps rendering exactly as before, and a product
          missing its tag still shows up rather than silently vanishing.
        {%- endcomment -%}
        {% for product in collection.products %}
          {% assign product_token = ',' | append: product.id | append: ',' %}
          {% unless grouped_ids contains product_token %}
            <li
              id="{{ section.id }}-{{ product.id }}"
              class="product-grid__item product-grid__item--{{ card_index }}"
              data-page="{{ paginate.current_page }}"
              data-product-id="{{ product.id }}"
              ref="cards[]"
            >
              {% # theme-check-disable %}
              {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
              {% # theme-check-enable %}
            </li>
            {% assign card_index = card_index | plus: 1 %}
          {% endunless %}
        {% endfor %}
      {% endcapture %}

      {% render 'product-grid',
        section: section,
        children: children,
        products: collection.products,
        paginate: paginate,
        enable_infinite_scroll: section.settings.enable_infinite_scroll
      %}
    {% endpaginate %}
  </div>
</results-list>

{% schema %}
{
  "name": "t:names.collection_container",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Collection Title"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Collection Description"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "organic",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "product_card_size",
      "label": "t:settings.card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "medium",
          "label": "t:options.medium"
        },
        {
          "value": "large",
          "label": "t:options.large"
        },
        {
          "value": "extra-large",
          "label": "t:options.extra_large"
        }
      ],
      "default": "medium",
      "visible_if": "{{ section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "select",
      "id": "mobile_product_card_size",
      "label": "t:settings.mobile_card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "large",
          "label": "t:options.large"
        }
      ],
      "default": "small"
    },
    {
      "type": "checkbox",
      "id": "enable_infinite_scroll",
      "label": "t:settings.auto_load_products",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:settings.products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 24,
      "visible_if": "{{ section.settings.enable_infinite_scroll == false }}"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "product_grid_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "centered",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "centered"
    },
    {
      "type": "checkbox",
      "id": "full_width_on_mobile",
      "label": "t:settings.full_width_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.product_grid_width != 'full-width' }}"
    },
    {
      "type": "range",
      "id": "columns_gap_horizontal",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_gap_vertical",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": []
}
{% endschema %}
