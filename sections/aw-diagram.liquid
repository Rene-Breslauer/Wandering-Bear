{% liquid
    assign section_settings = section.settings
    assign color_scheme = section_settings.color_scheme
    assign text_color = color_scheme.text
    assign title_type = section_settings.title_type
    assign title = section_settings.title
    assign title_color = section_settings.title_color | default: text_color
    assign title_alt = section_settings.title_alt
    assign title_image = section_settings.title_image
    assign title_image_mobile = section_settings.title_image_mobile
    assign diagram_image = section_settings.diagram_image
    assign diagram_image_mobile = section_settings.diagram_image_mobile
    assign text_background_color = section_settings.text_background_color
    assign text_background_opacity = section_settings.text_background_opacity | default: 100
    assign text_background_alpha = text_background_opacity | times: 0.01

    assign min_mobile_order = 999999
    assign max_mobile_order = 0
    assign diagram_item_count = 0

    for block in section.blocks
        if block.type == 'diagram_item'
            assign diagram_item_count = diagram_item_count | plus: 1

            assign item_mobile_order = block.settings.order_mobile
            if item_mobile_order == blank
                assign item_mobile_order = diagram_item_count | plus: 1
            endif

            if item_mobile_order < min_mobile_order
                assign min_mobile_order = item_mobile_order
            endif

            if item_mobile_order > max_mobile_order
                assign max_mobile_order = item_mobile_order
            endif
        endif
    endfor

    assign diagram_items_total = diagram_item_count

%}

{% capture title_styles %}
    --font-size: {{ section.settings.font_size | default: 24 }}px;
    --font-size-mobile: {{ section.settings.font_size_mobile | default: 24 }}px;
{% endcapture %}

{% capture diagram_content %}
    {% assign class = '' %}
    {% assign diagram_item_count = 0 %}
    {% for block in section.blocks %}
        {% if block.type == 'diagram_item' %}
            {% assign diagram_item_count = diagram_item_count | plus: 1 %}
            {% case diagram_item_count %}
                {% when 1 %}
                    {% assign class = 'md:!mb-0 md:!mt-0 order-2 md:!w-[215px] md:absolute md:left-[75%] md:top-[5%] lg:top-[-2%] lg:left-[78%] xl:top-[-3%] xl:left-[71%]' %}
                    {% assign icon_class = '!w-[54px] !h-[54px] md:!ml-0 md:!mr-auto' %}
                {% when 2 %}
                    {% assign class = 'order-3 md:!mb-0 md:!mt-0 md:!w-[215px] md:absolute md:right-[82%] md:top-[38%] lg:right-[79%] lg:top-[24%] xl:right-[67%] xl:top-[27%]' %}
                    {% assign icon_class = '!w-[54px] !h-[54px] md:!ml-auto md:!mr-0 md:mr-12!'  %}
                {% when 3 %}
                    {% assign class = 'md:!mb-0 md:!mt-0 order-4 md:!w-[287px] md:absolute md:left-[75%] md:top-[58%] lg:top-[51%] lg:left-[75%] xl:left-[69%]' %}
                    {% assign icon_class = '!w-[54px] !h-[54px] md:!ml-0 md:!mr-auto md:-mt-3!' %}
                {% else %}
                    {% assign class = 'md:hidden' %}
                    {% assign icon_class = '!w-[54px] !h-[54px]' %}
            {% endcase %}
            {% liquid
                assign mobile_order = block.settings.order_mobile
                if mobile_order == blank
                    assign mobile_order = diagram_item_count | plus: 1
                endif

                assign diagram_item_index = diagram_item_count | minus: 1
                assign mobile_margin_role = 'middle'

                if diagram_items_total == 1 or mobile_order == min_mobile_order
                    assign mobile_margin_role = 'first'
                elsif mobile_order == max_mobile_order
                    assign mobile_margin_role = 'last'
                endif
            %}
            <div class="diagram-item wb-flex flex-row {% if diagram_item_count < diagram_items_total %} md:!flex-col {% endif %} gap-4 {{ class }}"
            style="--diagram-order-mobile: {{ mobile_order }};"
            data-callout
            data-mobile-margin="{{ mobile_margin_role }}"
            data-index="{{ diagram_item_index }}">
                {{ block.settings.icon | image_url: width: 100 | image_tag: class: icon_class, alt: block.settings.title }}
                <div class="wb-flex flex-col gap-2">
                    <span class="h2 text-xl! leading-none uppercase">{{ block.settings.title }}</span>
                    <span class="body">{{ block.settings.description }}</span>
                </div>
            </div>
        {% endif %}
    {% endfor %}
{% endcapture %}

<div class="aw-diagram wb-flex flex-col gap-4 relative spacing-style wb-section-bg{% if template.suffix == 'gallon' %} mt-5.5 md:mt-8{% endif %}" style="{% render 'section-background', settings: section.settings, part: 'style', fallback_color: color_scheme.background %} {% render 'spacing-style', settings: section.settings %}">
    {% render 'section-background', settings: section.settings, part: 'media', image_class: 'w-full !h-full object-cover !max-w-none absolute inset-0 md:!-top-[77px]' %}
   <div class="wb-flex flex-col mx-auto relative z-[1]">
    {% if title_type == 'image' %}
        {% if title_image != blank %}
            <div class="max-w-[300px] md:max-w-[442px] w-full mx-auto">
                {% render 'title-image', image: title_image, image_mobile: title_image_mobile, alt: title_alt, class: 'w-full max-h-full object-contain' %}
            </div>
        {% endif %}
    {% elsif title_type == 'text' %}
        {% if title != blank %}
            <span class="h1 mb-8 title-text leading-[1.2]" style="color: {{ title_color }}; {{ title_styles }}">{{ title }}</span>
        {% endif %}
    {% endif %}
   </div>

   <div x-data="diagram()" class="wb-flex flex-col md:flex-row mx-auto relative max-w-[84vw] w-full justify-center px-0{% if template.suffix == '96oz' %} mt-2 md:mt-0{% endif %}">

    <!-- SVG LINES -->
    <svg class="diagram-lines absolute inset-0 w-full h-full overflow-visible pointer-events-none z-[1]">
        <line
          x-show="lines[0]"
          :x1="lines[0]?.x1 || 0"
          :y1="lines[0]?.y1 || 0"
          :x2="lines[0]?.x2 || 0"
          :y2="lines[0]?.y2 || 0"
          stroke="#2f1a0f"
          stroke-width="1"
          stroke-dasharray="4 4"
        />
      
        <line
          x-show="lines[1]"
          :x1="lines[1]?.x1 || 0"
          :y1="lines[1]?.y1 || 0"
          :x2="lines[1]?.x2 || 0"
          :y2="lines[1]?.y2 || 0"
          stroke="#2f1a0f"
          stroke-width="1"
          stroke-dasharray="4 4"
        />
      
        <line
          x-show="lines[2]"
          :x1="lines[2]?.x1 || 0"
          :y1="lines[2]?.y1 || 0"
          :x2="lines[2]?.x2 || 0"
          :y2="lines[2]?.y2 || 0"
          stroke="#2f1a0f"
          stroke-width="1"
          stroke-dasharray="4 4"
        />
      </svg>

    {% if text_background_color != blank %}
      <div
        class="diagram-text-background w-full flex flex-col max-lg:order-2"
        style="background-color: {{ text_background_color | color_modify: 'alpha', text_background_alpha }};"
      >
        {{ diagram_content }}
      </div>
    {% else %}
      {{ diagram_content }}
    {% endif %}
        {% if diagram_image != blank %}
            <div class="max-w-[284px] -mt-3.5 sm:mt-0 sm:max-w-[511px] md:w-[40vw]! mx-auto lg:w-[34vw]! xl:w-[22vw]!" x-ref="diagramImage">
                {% render 'diagram-image',
                  image: diagram_image,
                  image_mobile: diagram_image_mobile,
                  alt: title_alt,
                  class: 'diagram-image !flex order-1 md:order-2 w-full max-h-full object-contain relative z-[2] mx-auto'
                %}
            </div>
        {% endif %}
    </div>
</div>

{% stylesheet %}
    .no-scroll .aw-diagram .diagram-image {
        z-index: 1;
    }

    .aw-diagram .title-text {
        font-size: var(--font-size) !important;
    }

    @media screen and (max-width: 1023px) {
        .aw-diagram .title-text {
            font-size: var(--font-size-mobile) !important;
        }

        .aw-diagram .diagram-lines {
            display: none !important;
        }

        .aw-diagram .diagram-item {
            order: var(--diagram-order-mobile) !important;
        }

        .aw-diagram .diagram-text-background {
            width: 100vw;
            max-width: 100vw;
            margin-left: calc(50% - 50vw);
            margin-right: calc(50% - 50vw);
            margin-top: -1.875rem;
            padding: 2.25rem 1rem 1.875rem;
            box-sizing: border-box;
        }

        .aw-diagram .diagram-text-background .diagram-item[data-mobile-margin='first'],
        .aw-diagram .diagram-text-background .diagram-item[data-mobile-margin='middle'],
        .aw-diagram .diagram-text-background .diagram-item[data-mobile-margin='last'] {
            margin-top: 0;
        }

        .aw-diagram .diagram-text-background .diagram-item[data-mobile-margin='last'] {
            margin-bottom: 0;
        }

        .aw-diagram .diagram-item[data-mobile-margin='first'] {
            margin-top: 3.313rem;
            margin-bottom: 1.25rem;
        }

        .aw-diagram .diagram-item[data-mobile-margin='middle'] {
            margin-bottom: 1.25rem;
        }

        .aw-diagram .diagram-item[data-mobile-margin='last'] {
            margin-top: 0;
            margin-bottom: 2.25rem;
        }
    }

    @media screen and (max-width: 749px) {
        .aw-diagram .diagram-item[data-mobile-margin='first'] > img {
            margin-top: 0.938rem;
        }

        .aw-diagram .diagram-item[data-mobile-margin='middle'] > img {
            margin-top: 1.625rem;
        }
    }

    @media screen and (min-width: 1024px) {
        .aw-diagram .diagram-lines {
            display: block;
        }

        .aw-diagram .diagram-text-background {
            display: contents;
        }
    }
{% endstylesheet %}

{% schema %}
{
  "name": "AW Diagram Section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "options": [
        {
          "value": "transparent",
          "label": "Transparent"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        },
        {
          "value": "image",
          "label": "Image"
        }
      ],
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "background_solid",
      "label": "Background color",
      "default": "#F2E6DC",
      "visible_if": "{{ section.settings.background_type == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient",
      "visible_if": "{{ section.settings.background_type == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "select",
      "id": "background_image_fit",
      "label": "Background image fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover (may crop)"
        },
        {
          "value": "natural",
          "label": "Natural (no crop)"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "checkbox",
      "id": "background_image_overflow",
      "label": "Allow background image overflow",
      "default": false,
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "header",
      "content": "Background mobile"
    },
    {
      "type": "select",
      "id": "background_type_mobile",
      "label": "Background type mobile",
      "options": [
        {
          "value": "same",
          "label": "Same as desktop"
        },
        {
          "value": "transparent",
          "label": "Transparent"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        },
        {
          "value": "image",
          "label": "Image"
        }
      ],
      "default": "same"
    },
    {
      "type": "color",
      "id": "background_solid_mobile",
      "label": "Background color mobile",
      "default": "#F2E6DC",
      "visible_if": "{{ section.settings.background_type_mobile == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient_mobile",
      "label": "Background gradient mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "select",
      "id": "background_image_fit_mobile",
      "label": "Background image fit mobile",
      "options": [
        {
          "value": "cover",
          "label": "Cover (may crop)"
        },
        {
          "value": "natural",
          "label": "Natural (no crop)"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "checkbox",
      "id": "background_image_overflow_mobile",
      "label": "Allow background image overflow",
      "default": false,
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "select",
      "id": "title_type",
      "label": "Title Type",
      "options": [
        {
          "value": "text",
          "label": "Text"
        },
        {
          "value": "image",
          "label": "Image"
        }
      ],
      "default": "text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "visible_if": "{{ section.settings.title_type == 'text' }}"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "info": "Leave empty to use the color scheme text color.",
      "visible_if": "{{ section.settings.title_type == 'text' }}"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font Size",
      "min": 16,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ section.settings.title_type == 'text' }}"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font Size Mobile",
      "min": 16,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ section.settings.title_type == 'text' }}"
    },
    {
      "type": "text",
      "id": "title_alt",
      "label": "Title Alt",
      "visible_if": "{{ section.settings.title_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "title_image",
      "label": "Title Image",
      "visible_if": "{{ section.settings.title_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "title_image_mobile",
      "label": "Title Image Mobile",
      "visible_if": "{{ section.settings.title_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "diagram_image",
      "label": "Diagram Image"
    },
    {
      "type": "image_picker",
      "id": "diagram_image_mobile",
      "label": "Diagram Image Mobile"
    },
    {
      "type": "color",
      "id": "text_background_color",
      "label": "Text Background Color",
      "info": "Optional background behind all callout text on mobile"
    },
    {
      "type": "range",
      "id": "text_background_opacity",
      "label": "Text background opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ section.settings.text_background_color != blank }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.mobile"
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "diagram_item",
      "name": "Diagram Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "number",
          "id": "order_mobile",
          "label": "Order Mobile"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AW Diagram Section"
    }
  ]
}
{% endschema %}