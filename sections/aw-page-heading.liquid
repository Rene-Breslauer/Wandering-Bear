{% comment %}
  Centred page heading. Split out of the locator section because Figma puts the logo band
  between the heading and the locator (heading y=169, logos y=289, locator y=387), so they
  cannot live in one section.

  Defaults to Display L — Gothic Condensed 60px desktop / 45px mobile, matching .display-lg.
{% endcomment %}

{% liquid
  assign s = section.settings
  assign color_scheme = s.color_scheme
  assign text_color = s.text_color | default: '#431A03'
%}

{% capture type_styles %}
  --font-size: {{ s.font_size | default: 60 }}px;
  --font-size-mobile: {{ s.font_size_mobile | default: 45 }}px;
{% endcapture %}

<div
  class="wb-page-heading relative overflow-hidden spacing-style wb-section-bg"
  style="{% render 'section-background', settings: s, part: 'style', fallback_color: color_scheme.settings.background %} {% render 'spacing-style', settings: s %} {{ type_styles }}"
  {{ section.shopify_attributes }}
>
  {% render 'section-background', settings: s, part: 'media' %}

  {% comment %}
    \b is a mobile-only break: Figma wraps the title after "FIND US" at 45px on mobile and keeps
    it on one line at 60px on desktop. smd is min-width:750, which would already switch at 750
    itself, so the desktop single line starts at 751.
  {% endcomment %}
  {% if s.title != blank %}
    <h1
      class="wb-page-heading__title {{ s.style_class | default: 'display-lg' }} relative z-[1] text-center uppercase leading-[1.05] px-6"
      style="color: {{ text_color }};"
    >
      {{ s.title | replace: '\b', '<br class="min-[751px]:!hidden">' }}
    </h1>
  {% endif %}
</div>

{% stylesheet %}
  .wb-page-heading__title {
    font-size: var(--font-size) !important;
  }

  @media screen and (max-width: 1023px) {
    .wb-page-heading__title {
      font-size: var(--font-size-mobile) !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "AW Page Heading",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "info": "Use \\b to force a line break.",
      "default": "FIND US IN STORES"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#431A03"
    },
    {
      "type": "select",
      "id": "style_class",
      "label": "Type style",
      "options": [
        { "value": "display-lg", "label": "Display L (Gothic Condensed)" },
        { "value": "display-md", "label": "Display M (Kurdis Condensed)" },
        { "value": "h1", "label": "H1" }
      ],
      "default": "display-lg"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Title size",
      "min": 20,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Title size mobile",
      "min": 20,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 45
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "options": [
        { "value": "transparent", "label": "Transparent" },
        { "value": "color", "label": "Color" },
        { "value": "gradient", "label": "Gradient" },
        { "value": "image", "label": "Image" }
      ],
      "default": "color"
    },
    {
      "type": "color",
      "id": "background_solid",
      "label": "Background color",
      "default": "#F2E6DC",
      "visible_if": "{{ section.settings.background_type == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient",
      "visible_if": "{{ section.settings.background_type == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.mobile"
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 29
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "AW Page Heading"
    }
  ]
}
{% endschema %}
