{% comment %}
  Bundle Editor (Section Rendering)

  Rendered on demand by `bundle-editor.js` via:
    GET /collections/{collection_handle}?section_id=bundle-editor

  Because it renders in the flavor collection's context, `collection.products`
  is the editable flavor list. The matching `product_group` metaobject provides
  the tier / price / selling-plan data server-side and is resolved from the
  flavor product's `custom.product_group` metafield (the theme's canonical link;
  the metaobject's own `collection_handle` field is not populated). Current cart
  quantities are hydrated client-side by the component (the cart bundle id cannot
  be passed to Liquid through the Section Rendering API).
{% endcomment %}

{% liquid
  assign block_settings = block.settings
  assign is_member = false
  assign member_tier = ''

  for tag in customer.tags
    case tag
      when 'inveterate-tier#72ccf378'
        assign member_tier = 'VIP'
      when 'inveterate-tier#dc38b982'
        assign member_tier = 'Elite'
      when 'inveterate-tier#99a431e2'
        assign member_tier = 'Elite'
    endcase
  endfor
  
  for item in cart.items
    if item.title contains 'Membership'
      assign is_member = true
      assign member_tier = 'Elite'
      break
    endif
  endfor
%}

{% style %}
  button[data-bundle-increment][disabled] {
    opacity: 0.5;
    pointer-events: none;
  }
  button[data-bundle-decrement][disabled] {
    opacity: 0.5;
    pointer-events: none;
  }
  button[data-bundle-add][disabled] {
    opacity: 0.5;
    pointer-events: none;
  }
{% endstyle %}

{%- liquid
  assign group = collection.products.first.metafields.custom.product_group.value

  if group == blank
    for object in shop.metaobjects.product_group.values
      assign object_collection_handle = object.collection_handle | handleize
      if object_collection_handle == collection.handle
        assign group = object
        break
      endif
    endfor
  endif

  assign bundle_products = group.bundle_products.value
  assign bundle_products_count = bundle_products.size
  assign tier_count = bundle_products.size
  assign singular = group.singular_label.value | default: group.singular_label | default: 'item'
  assign plural = group.plural_label.value | default: group.plural_label | default: 'items'
  assign singular_label = singular
  assign plural_label = plural
  assign headline = group.headline.value | default: group.headline
  assign headline_size = group.headline_size.value | default: group.headline_size | default: 'lg'
  assign group_name = group.display_name | handleize
  assign selling_plan_keywords = group.selling_plan_keywords.value
  assign discount_type = group.discount_type.value | default: group.discount_type | default: 'percentage'
  assign col_width = 70
  assign multi_unit_product = false
  assign multi_unit_quantity = 0
  assign multi_unit_product_unit = ''

  if group.multi_unit_product_quantity != blank and group.multi_unit_product_quantity > 1
    assign multi_unit_product = true
    assign multi_unit_quantity = group.multi_unit_product_quantity
    assign multi_unit_product_unit = group.multi_unit_product_unit
    assign col_width = 121
  endif

  if collection.products.first.selected_or_first_available_variant.compare_at_price > collection.products.first.selected_or_first_available_variant.price
    assign compare_at_price = collection.products.first.selected_or_first_available_variant.compare_at_price
  else
    assign compare_at_price = collection.products.first.selected_or_first_available_variant.price
  endif

   ## Prices ##
   assign tier_one_unit_price_otp = collection.products.first.variants[0].price
   assign tier_two_unit_price_otp = collection.products.first.variants[1].price
   assign tier_three_unit_price_otp = collection.products.first.variants[2].price

   for selling_plan in collection.products.first.selling_plan_groups
    for selling_plan_allocation in selling_plan.selling_plan_allocations
      if selling_plan_allocation.selling_plan.name contains '1 Month'
        assign tier_one_unit_price_autoship = selling_plan_allocation.selling_plan.price
      endif
    endfor
   endfor

   for variant in collection.products.first.variants
    assign variant_title = variant.title | downcase | split: ' discount' | first
    assign variant_title = variant_title | split: ' ' | first
  
    for allocation in variant.selling_plan_allocations
      assign plan = allocation.selling_plan
      assign plan_name = plan.name | downcase
  
      if plan_name contains '1 month' and plan_name contains variant_title
     
        unless plan_name contains 'bundle'
          assign adjustment = plan.price_adjustments[0]
          assign discount_amount = adjustment.value
          assign autoship_price = variant.price | minus: discount_amount
  
          case variant_title
            when '1'
              assign tier_one_unit_price_autoship = autoship_price
            when '2'
              assign tier_two_unit_price_autoship = autoship_price
            when '3'
              assign tier_three_unit_price_autoship = autoship_price
          endcase
        endunless
      endif
    endfor
  endfor

-%}

{%- capture tiers_json -%}
[
{%- for tier_product in bundle_products -%}
  {%- assign tier_variant = tier_product.variants.first -%}
  {%- assign tier_selling_plan = null -%}
  {%- for allocation in tier_variant.selling_plan_allocations -%}
    {%- if allocation.selling_plan.name contains '1 month' or allocation.selling_plan.name contains '1 Month' -%}
      {%- assign tier_selling_plan = allocation.selling_plan.id -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
  {"variant_id":{{ tier_variant.id | json }},"selling_plan_id":{% if tier_selling_plan %}{{ tier_selling_plan | json }}{% else %}null{% endif %}}{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
{%- endcapture -%}

{% capture col_width_styles %}
  --col-width: {{ col_width }}px;
{% endcapture %}

{% style %}
  .col-width {
    width: var(--col-width);
  }
{% endstyle %}

<div
  data-bundle-editor-root
  data-collection-handle="{{ collection.handle }}"
  data-bundle-name="{{ group_name }}"
  data-singular-label="{{ singular }}"
  data-tier-count="{{ tier_count }}"
  data-tiers="{{ tiers_json | strip | escape }}"
>
  <div data-bundle-editor-header class="flex flex-col pt-6 px-4.5 pb-1">
    <div class="flex justify-between items-center {% if collection.handle == '32oz-bundle' %} mb-6.5 {% endif %}">
      <button
        type="button"
        class="cursor-pointer flex items-center gap-3 font-kurdis-semi-condensed text-xs text-espresso font-bold hover:!text-gold"
        on:click="bundle-editor-component/backToCart"
      >
        {% render 'icons', icon: 'chevron-left', class: 'text-sm' %}
        Back to Cart
      </button>

      <h2 class="h6 uppercase font-gothic_condensed font-bold text-bear-black text-lg">
        Modify {{ headline }}
      </h2>
    </div>
    <div>
      {% comment %} Progress / tier indicator {% endcomment %}
      {% if tier_count > 0 and collection.handle != '32oz-bundle' %}
        <div class="mt-5.5 mb-4 relative">
        {% render 'progress-indicator', 
          multi_unit_product: multi_unit_product,
          multi_unit_quantity: multi_unit_quantity,
          multi_unit_product_unit: multi_unit_product_unit,
          tier_one_unit_price_autoship: tier_one_unit_price_autoship,
          tier_two_unit_price_autoship: tier_two_unit_price_autoship,
          tier_three_unit_price_autoship: tier_three_unit_price_autoship,
          tier_one_unit_price_otp: tier_one_unit_price_otp,
          tier_two_unit_price_otp: tier_two_unit_price_otp,
          tier_three_unit_price_otp: tier_three_unit_price_otp,
          discount_type: discount_type,
          compare_at_price: compare_at_price,
          bundle_products: bundle_products,
          product_object: group,
          bundle_products_count: bundle_products_count,
          singular_label: singular_label,
          plural_label: plural_label,
          col_width: col_width,
          col_width_styles: col_width_styles,
          cart_editor: true,
          collection: collection
        %}
        </div>
      {% endif %}

      {% comment %} 32oz Multi-Serve Variety Indicator — populated client-side by
        bundle-editor.js in mix mode (one carton card per selected serving). {% endcomment %}
      {% if tier_count > 0 and collection.handle == '32oz-bundle' %}
        <div
          data-32oz-multi-serve-container
          class="justify-center gap-2 flex-wrap mb-5.5"
          style="display: none;"
        ></div>
      {% endif %}
    </div>
  </div>

  <div class="px-5 mb-5">
    {% comment %} Editable flavor list {% endcomment %}
    <form on:submit="bundle-editor-component/update" class="wb-flex"
    data-is-member="{{ is_member }}"
    data-member-tier="{{ member_tier }}"
    >
      <div data-bundle-editor-content class="w-full flex flex-col gap-3 overflow-auto">
        {% paginate collection.products by 50 %}
          {% for product in collection.products %}
            {% assign member_only = product.metafields.product.member_only | default: false %}
            {%- capture variants_json -%}
              [
              {%- for variant in product.variants -%}
                {%- assign variant_selling_plan_price = null -%}
                {%- assign variant_selling_plan_id = null -%}
                {%- for allocation in variant.selling_plan_allocations -%}
                  {%- if allocation.selling_plan.name contains '1 month' or allocation.selling_plan.name contains '1 Month' -%}
                    {%- assign variant_selling_plan_price = allocation.per_delivery_price -%}
                    {%- assign variant_selling_plan_id = allocation.selling_plan.id -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
                {"id":{{ variant.id | json }},"price":{{ variant.price | money | json }},"price_cents":{{ variant.price | json }},"selling_plan_price":{% if variant_selling_plan_price %}{{ variant_selling_plan_price | money | json }}{% else %}null{% endif %},"selling_plan_price_cents":{% if variant_selling_plan_price %}{{ variant_selling_plan_price | json }}{% else %}null{% endif %},"selling_plan_id":{% if variant_selling_plan_id %}{{ variant_selling_plan_id | json }}{% else %}null{% endif %}}{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
              ]
            {%- endcapture -%}
            {% assign cart_image = product.metafields.custom.cart_bundle_image | default: product.featured_image %}
            <div
              data-bundle-row
              data-product-id="{{ product.id }}"
              data-variant-id="{{ product.variants.first.id }}"
              data-variants="{{ variants_json | strip | escape }}"
              data-flavor-name="{{ product.metafields.custom.flavor_name | default: product.title | split: '- ' | last | escape }}"
              data-quantity="0"
              data-bundle-image="{{ product.metafields.custom.bundle_image | image_url: width: 200 }}"
              class="wb-flex bg-[#FFFFFF80] rounded-[5px] gap-1"
            >
              <div class="w-[78px]">
                {%- if cart_image -%}
                  {{
                    cart_image
                    | image_url: width: 200
                    | image_tag: width: 200, height: 67, alt: product.title, class: '!w-full !h-full object-contain min-w-[78px] min-h-[67px]'
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: '!w-full !h-full object-cover' }}
                {%- endif -%}
              </div>
              <div class="flex items-center justify-between w-full gap-3 p-3">
                <div class="w-full wb-flex flex-col">
                  {% if product.metafields.product.product_badge.value.badge_text != blank %}
                    <span class="font-kurdis-semi-condensed text-[10px] text-espresso font-bold uppercase">{{ product.metafields.product.product_badge.value.badge_text }}</span>
                  {% endif %}
                  <h3 class="font-gothic_condensed leading-[1.2] uppercase font-bold text-bear-black text-lg">{{ product.title | split: '- ' | last }}</h3>

                  {% unless group.display_name == 'Single Serve' %}
                    <span class="font-kurdis-semi-condensed text-xs text-kraft font-bold lowercase">
                      <span data-bundle-price>{{ product.variants.first.price | money }}</span> per {{ singular }}
                    </span>
                  {% endunless %}
                </div>

                {% comment %} Add button (quantity 0 / unselected) {% endcomment %}
              
                {% if member_only and member_tier != 'Elite' and member_tier != 'VIP' %}
                  <button
                    on:click="bundle-editor-component/openMembershipModal"
                    type="button"
                    class="group relative flex items-center justify-center cursor-pointer shadow-button w-20 min-w-20"
                  >
                    <span class="absolute whitespace-nowrap text-cream uppercase font-kurdis-condensed text-sm font-bold">
                    {% render 'icons', icon: 'unlock', class: 'mr-1' %}
                     Locked
                    </span>
                    <svg class="text-kraft group-hover:!text-gold" xmlns="http://www.w3.org/2000/svg" width="80" height="40" viewBox="0 0 80 40" fill="none">
                      <path d="M0.740482 4.15938C0.111533 6.47951 0.0863218 9.21376 0.0757066 11.8348C0.0504956 18.0724 0.0266114 24.3075 0.00140038 30.5451C-0.0052341 32.2401 -0.00390717 34.0047 0.38222 35.5249C1.31237 39.18 2.48668 39.9773 5.96049 39.9773C29.2608 39.9773 52.5624 40.1137 75.8641 39.7175C76.6907 39.7047 77.5983 39.787 78.2764 38.8687C80.1141 36.3814 79.9138 31.8363 79.858 28.4641C79.7545 22.1854 80 17.0255 80 10.7442C80 6.3509 79.7466 4.58636 78.9955 2.84755C78.0335 0.61745 76.0299 0.712621 74.5292 0.653461C64.6624 0.259913 54.7903 0.0567088 44.9195 0.0104091C34.985 -0.0384628 25.0506 0.0850031 15.1161 0.375662C12.3137 0.457973 9.5126 0.553144 6.71152 0.663749C4.59644 0.74606 1.91346 -0.159357 0.740482 4.15938Z" fill="currentColor"/>
                    </svg>
                  </button>
                {% else %}
                  <button
                    data-bundle-add
                    type="button"
                    class="group relative flex items-center justify-center cursor-pointer shadow-button w-20 min-w-20"
                    on:click="bundle-editor-component/increment"
                  >
                    <span class="absolute whitespace-nowrap text-cream uppercase font-kurdis-condensed text-sm font-bold">+ Add {% if group.display_name == 'Single Serve' %} {{ singular }} {% endif %}</span>
                    <svg class="{% if group.display_name == 'Single Serve' %}text-espresso{% else %}text-kraft{% endif %} group-hover:!text-gold" xmlns="http://www.w3.org/2000/svg" width="80" height="40" viewBox="0 0 80 40" fill="none">
                      <path d="M0.740482 4.15938C0.111533 6.47951 0.0863218 9.21376 0.0757066 11.8348C0.0504956 18.0724 0.0266114 24.3075 0.00140038 30.5451C-0.0052341 32.2401 -0.00390717 34.0047 0.38222 35.5249C1.31237 39.18 2.48668 39.9773 5.96049 39.9773C29.2608 39.9773 52.5624 40.1137 75.8641 39.7175C76.6907 39.7047 77.5983 39.787 78.2764 38.8687C80.1141 36.3814 79.9138 31.8363 79.858 28.4641C79.7545 22.1854 80 17.0255 80 10.7442C80 6.3509 79.7466 4.58636 78.9955 2.84755C78.0335 0.61745 76.0299 0.712621 74.5292 0.653461C64.6624 0.259913 54.7903 0.0567088 44.9195 0.0104091C34.985 -0.0384628 25.0506 0.0850031 15.1161 0.375662C12.3137 0.457973 9.5126 0.553144 6.71152 0.663749C4.59644 0.74606 1.91346 -0.159357 0.740482 4.15938Z" fill="currentColor"/>
                    </svg>
                  </button>
                {% endif %}

                {% comment %} Selected state (single-flavor mode) — shown by
                   bundle-editor.js on the chosen flavor. {% endcomment %}
                <button
                  data-bundle-selected
                  type="button"
                  class="group relative flex items-center justify-center cursor-default shadow-button w-20 min-w-20"
                  aria-disabled="true"
                  style="display: none;"
                >
                  <span class="absolute whitespace-nowrap text-cream uppercase font-kurdis-condensed text-xs font-bold">&#10003; Selected</span>
                  <svg class="text-gold" xmlns="http://www.w3.org/2000/svg" width="80" height="40" viewBox="0 0 80 40" fill="none">
                    <path d="M0.740482 4.15938C0.111533 6.47951 0.0863218 9.21376 0.0757066 11.8348C0.0504956 18.0724 0.0266114 24.3075 0.00140038 30.5451C-0.0052341 32.2401 -0.00390717 34.0047 0.38222 35.5249C1.31237 39.18 2.48668 39.9773 5.96049 39.9773C29.2608 39.9773 52.5624 40.1137 75.8641 39.7175C76.6907 39.7047 77.5983 39.787 78.2764 38.8687C80.1141 36.3814 79.9138 31.8363 79.858 28.4641C79.7545 22.1854 80 17.0255 80 10.7442C80 6.3509 79.7466 4.58636 78.9955 2.84755C78.0335 0.61745 76.0299 0.712621 74.5292 0.653461C64.6624 0.259913 54.7903 0.0567088 44.9195 0.0104091C34.985 -0.0384628 25.0506 0.0850031 15.1161 0.375662C12.3137 0.457973 9.5126 0.553144 6.71152 0.663749C4.59644 0.74606 1.91346 -0.159357 0.740482 4.15938Z" fill="currentColor"/>
                  </svg>
                </button>

                {% comment %} Stepper (quantity > 0) {% endcomment %}
                <div data-bundle-stepper class="w-fit wb-flex justify-end items-center hidden">
                  <div class="wb-flex items-center gap-2 w-fit justify-end">
                    <button
                      data-bundle-decrement
                      type="button"
                      class="group relative cursor-pointer wb-flex justify-center items-center shadow-button w-[30px]"
                      on:click="bundle-editor-component/decrement"
                    >
                      <span class="absolute whitespace-nowrap text-cream uppercase font-kurdis text-sm font-bold">-</span>
                      <svg class="text-espresso group-hover:!text-gold" xmlns="http://www.w3.org/2000/svg" width="30" height="40" viewBox="0 0 30 40" fill="none">
                        <path d="M0.277681 4.15938C0.0418248 6.47951 0.0323707 9.21376 0.02839 11.8348C0.0189358 18.0724 0.00997928 24.3075 0.000525143 30.5451C-0.00196279 32.2401 -0.0014652 34.0047 0.143332 35.5249C0.49214 39.18 0.932504 39.9773 2.23518 39.9773C10.9728 39.9773 19.7109 40.1137 28.449 39.7175C28.759 39.7047 29.0994 39.787 29.3536 38.8687C30.0428 36.3814 29.9677 31.8363 29.9468 28.4641C29.9079 22.1854 30 17.0256 30 10.7442C30 6.3509 29.905 4.58636 29.6233 2.84755C29.2626 0.617449 28.5112 0.712621 27.9485 0.653461C24.2484 0.259913 20.5464 0.0567088 16.8448 0.0104091C13.1194 -0.0384628 9.39396 0.0850031 5.66853 0.375662C4.61763 0.457973 3.56722 0.553144 2.51682 0.663749C1.72367 0.74606 0.717547 -0.159357 0.277681 4.15938Z" fill="currentColor"/>
                      </svg>
                    </button>

                    <span data-bundle-qty class="font-kurdis-semi-condensed text-lg text-espresso font-bold w-6 text-center">0</span>

                    <button
                      data-bundle-increment
                      type="button"
                      class="group relative cursor-pointer wb-flex justify-center items-center shadow-button w-[30px]"
                      on:click="bundle-editor-component/increment"
                    >
                      <span class="absolute whitespace-nowrap text-cream uppercase font-kurdis text-sm font-bold">+</span>
                      <svg class="text-espresso group-hover:!text-gold" xmlns="http://www.w3.org/2000/svg" width="30" height="40" viewBox="0 0 30 40" fill="none">
                        <path d="M0.277681 4.15938C0.0418248 6.47951 0.0323707 9.21376 0.02839 11.8348C0.0189358 18.0724 0.00997928 24.3075 0.000525143 30.5451C-0.00196279 32.2401 -0.0014652 34.0047 0.143332 35.5249C0.49214 39.18 0.932504 39.9773 2.23518 39.9773C10.9728 39.9773 19.7109 40.1137 28.449 39.7175C28.759 39.7047 29.0994 39.787 29.3536 38.8687C30.0428 36.3814 29.9677 31.8363 29.9468 28.4641C29.9079 22.1854 30 17.0256 30 10.7442C30 6.3509 29.905 4.58636 29.6233 2.84755C29.2626 0.617449 28.5112 0.712621 27.9485 0.653461C24.2484 0.259913 20.5464 0.0567088 16.8448 0.0104091C13.1194 -0.0384628 9.39396 0.0850031 5.66853 0.375662C4.61763 0.457973 3.56722 0.553144 2.51682 0.663749C1.72367 0.74606 0.717547 -0.159357 0.277681 4.15938Z" fill="currentColor"/>
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        {% endpaginate %}
      </div>

      <div data-bundle-editor-footer class="fixed bottom-0 left-0 right-0 bg-cream pt-3">
        {% comment %} Autoship & Bundling Savings — amount updated by bundle-editor.js. {% endcomment %}
        <div
          data-is-member="{{ is_member }}"
          data-member-tier="{{ member_tier }}"
          data-bundle-savings-row
          class="items-center justify-between px-6 py-3.5 border-t border-b border-[#431A031A] font-kurdis-semi-condensed text-gold text-xs font-bold"
          style="display: none;"
        >
          <span data-savings-selling-plan class="hidden">Autoship &amp; Bundling Savings</span>
          <span data-savings-otp class="hidden">Bundling Savings</span>
          <span data-bundle-savings>-$0.00</span>
        </div>
        <div class="pt-3 pb-9 flex justify-center items-center">
        <button
          type="submit"
          data-bundle-update
          class="relative cursor-pointer flex justify-center items-center opacity-50 !pointer-events-none"
          disabled
        >
          <span data-no-load class="absolute left-1/2 -translate-x-1/2 whitespace-nowrap text-cream uppercase font-kurdis-condensed text-xl font-bold">Update bundle</span>
          <span data-loading class="hidden absolute flex items-center justify-center animate-spin rounded-full h-4 w-4 border-2 border-dashed border-dash-offset-5 border-cream"></span>
          <svg class="text-espresso" xmlns="http://www.w3.org/2000/svg" width="330" height="50" viewBox="0 0 330 50" fill="none">
            <path d="M3.05449 5.19922C0.460073 8.09938 0.356077 11.5172 0.31229 14.7935C0.208294 22.5905 0.109772 30.3843 0.00577657 38.1813C-0.0215907 40.3002 -0.0161172 42.5059 1.57666 44.4061C5.41354 48.9749 10.2575 49.9717 24.587 49.9717C120.701 49.9717 216.82 50.1421 312.939 49.6469C316.349 49.6309 320.093 49.7337 322.89 48.5859C330.471 45.4767 329.644 39.7954 329.414 35.5802C328.987 27.7317 330 21.2819 330 13.4303C330 7.93862 328.955 5.73295 325.857 3.55944C321.888 0.771812 313.623 0.890777 307.433 0.816826C266.732 0.324891 226.01 0.070886 185.293 0.0130114C144.313 -0.0480785 103.334 0.106254 62.3538 0.469578C50.7939 0.572466 39.2395 0.691431 27.685 0.829687C18.9603 0.932575 7.89302 -0.199196 3.05449 5.19922Z" fill="currentColor"/>
          </svg>
        </button>
        </div>
      </div>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Bundle editor",
  "settings": []
}
{% endschema %}
