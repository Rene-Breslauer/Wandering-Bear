{% comment %}
  Review carousel — speech-bubble cards over a dark gradient.
  Figma: WB x AW Landing Pages, Listicle_Desktop 1:17 (band 1280×297), mobile 1:133.

  Desktop shows 3 cards, mobile 1. Arrows and dots come from the design (4 dots vs 3 visible
  cards — there are more reviews than fit), driven by frontend/scripts/components/reviewCarousel.ts.

  Title uses .h1 with a local size override: the global .h1 goes to 28px under 768px, but the
  design keeps this at 25px on mobile, and .h1 is used in 34 files.
{% endcomment %}

{% liquid
  assign s = section.settings
  assign color_scheme = s.color_scheme
  assign card_bg = s.card_background | default: '#E6CDB7'
  assign card_text = s.card_text_color | default: '#431A03'
  # Figma: arrows are Foam #FEF8F3, not the card colour, with their own drop shadow.
  assign arrow_bg = s.arrow_background | default: '#FEF8F3'
  assign arrow_icon = s.arrow_icon_color | default: '#431A03'
%}

{% capture type_styles %}
  --font-size: {{ s.font_size | default: 25 }}px;
  --font-size-mobile: {{ s.font_size_mobile | default: 25 }}px;
  --card-bg: {{ card_bg }};
{% endcapture %}

<div
  class="wb-reviews relative overflow-hidden spacing-style wb-section-bg"
  style="{% render 'section-background', settings: s, part: 'style', fallback_color: color_scheme.settings.background %} {% render 'spacing-style', settings: s %} {{ type_styles }}"
  {{ section.shopify_attributes }}
>
  {% render 'section-background', settings: s, part: 'media' %}

  <div
    class="relative z-[1] w-full"
    x-data="reviewCarousel"
    data-slides-mobile="1"
    data-slides-tablet="2"
    data-slides-desktop="3"
    data-space-mobile="0"
    data-space-desktop="0"
  >
    {% if s.title != blank %}
      {% comment %} Extra breathing room above the title on mobile only; desktop keeps the Figma spacing. {% endcomment %}
      <h2 class="wb-reviews__title h1 text-center px-6 pt-12 smd:!pt-0 mb-6" style="color: {{ s.title_color | default: '#F4ECE5' }};">
        {{ s.title }}
      </h2>
    {% endif %}

    <div class="relative max-w-[1092px] mx-auto px-6 smd:!px-16">
      {% comment %}
        Clip at every width: exactly 3 cards on desktop, 1 on mobile, with no neighbour
        peeking in. Tails and the rotated corners live in the track's vertical padding, so
        hiding overflow costs nothing.
      {% endcomment %}
      <div class="review-carousel__swiper swiper !overflow-hidden">
        <div class="swiper-wrapper items-stretch">
          {% for block in section.blocks %}
            <div class="swiper-slide wb-reviews__slide !h-auto" {{ block.shopify_attributes }}>
              <div class="wb-reviews__bubble relative rounded-[10px] px-5 py-4 text-center h-full wb-flex items-center justify-center">
                <p class="body" style="color: {{ card_text }};">{{ block.settings.quote }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      {% if s.show_navigation %}
        {% comment %}
          Figma overlaps the arrows onto the cards — prev by 17px, next by 19px. The track starts
          at the container's 64px padding, so the arrow sits 25px before it: 64 − 25 = 39.
        {% endcomment %}
        <button
          type="button"
          class="review-carousel__arrow review-carousel__prev absolute left-0 smd:!left-[39px] top-1/2 -translate-y-1/2 z-[2] w-11 h-11 rounded-full wb-flex items-center justify-center transition-opacity hover:!opacity-80"
          style="background-color: {{ arrow_bg }};"
          aria-label="{{ 'general.slider.previous' | t | default: 'Previous' }}"
        >
          <svg class="w-[9px] h-[15px]" viewBox="0 0 9 15" fill="none" aria-hidden="true">
            <path d="M8 1L1.5 7.5L8 14" stroke="{{ arrow_icon }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          type="button"
          class="review-carousel__arrow review-carousel__next absolute right-0 smd:!right-[41px] top-1/2 -translate-y-1/2 z-[2] w-11 h-11 rounded-full wb-flex items-center justify-center transition-opacity hover:!opacity-80"
          style="background-color: {{ arrow_bg }};"
          aria-label="{{ 'general.slider.next' | t | default: 'Next' }}"
        >
          <svg class="w-[9px] h-[15px]" viewBox="0 0 9 15" fill="none" aria-hidden="true">
            <path d="M1 1L7.5 7.5L1 14" stroke="{{ arrow_icon }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      {% endif %}
    </div>

    {% if s.show_dots %}
      <div class="review-carousel__dots wb-flex items-center justify-center !gap-2 mt-6"></div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .wb-reviews__title {
    font-size: var(--font-size) !important;
  }

  @media screen and (max-width: 1023px) {
    .wb-reviews__title {
      font-size: var(--font-size-mobile) !important;
    }
  }

  /* Figma DROP_SHADOW on the arrows: 0 4px 4px #000 25% — lifts them off the band. */
  .review-carousel__arrow {
    box-shadow: 0 4px 4px rgba(0, 0, 0, 0.25);
  }

  .wb-reviews__bubble {
    background-color: var(--card-bg);
    min-height: 132px;
    /* Figma DROP_SHADOW: x -2, y 4, blur 4, #000 25%. The offset points left on purpose —
       cards overlap left-to-right with the right one on top, so the shadow has to fall onto
       the card underneath or the two merge into one shape.
       drop-shadow (not box-shadow) so it traces the tail too. */
    filter: drop-shadow(-2px 4px 4px rgba(0, 0, 0, 0.25));
  }

  /* Tail sits in a bottom corner and overhangs the card — not centred.
     Figma draws each bubble by hand: tails alternate right/left/right and every card is
     tilted a degree or two and nudged on Y. Cycle of 3 so the pattern repeats as the
     carousel advances rather than being pinned to specific review text. */
  /* Size taken from the bubble's own vector path in Figma (node 1:97): the tail spans
     x 1.45→23.10 and drops from y≈107 to y=118.8 — a 22×12 wedge, wide and flat.
     Figma's is hand-drawn and scalene (legs 17.9 / 13.8, tip off-centre); this is the same
     footprint drawn isosceles. */
  .wb-reviews__bubble::after {
    content: '';
    position: absolute;
    bottom: -15px;
    width: 0;
    height: 0;
    border-left: 14px solid transparent;
    border-right: 14px solid transparent;
    border-top: 15px solid var(--card-bg);
  }

  /* Figma sits the tail hard in the corner — its outer vertex clears the card edge by ~3px.
     The corner the tail meets is square: a radius there would leave a notch between the
     rounded edge and the triangle. */
  .wb-reviews__slide:nth-child(3n + 1) .wb-reviews__bubble::after,
  .wb-reviews__slide:nth-child(3n + 3) .wb-reviews__bubble::after {
    right: 0;
  }

  .wb-reviews__slide:nth-child(3n + 1) .wb-reviews__bubble,
  .wb-reviews__slide:nth-child(3n + 3) .wb-reviews__bubble {
    border-bottom-right-radius: 0;
  }

  .wb-reviews__slide:nth-child(3n + 2) .wb-reviews__bubble::after {
    left: 0;
  }

  .wb-reviews__slide:nth-child(3n + 2) .wb-reviews__bubble {
    border-bottom-left-radius: 0;
  }

  /* Cards overlap by ~17-19px in Figma; later slides paint over earlier ones.
     The overlap lives inside the slide, not in spaceBetween: a negative gap makes every
     following slide start before the previous one ends, so slide 4 always leaked ~18px into
     the window no matter how wide the track was. With slides tiling exactly, slide 4 lands
     fully outside and gets clipped, while the bubble still bleeds left over its neighbour. */
  /* Tilting a ~130px-tall card by 3° pushes its corners ~3.2px sideways. Inset the card inside
     its slide by more than that and the tilt stays within the slide box — so the track can clip
     flush at its edges without ever cutting a card or revealing the one before it. */
  .wb-reviews__slide {
    position: relative;
    padding-left: 5px;
    padding-right: 5px;
  }

  /* Alpine (and Swiper with it) is imported lazily on first interaction — see main.js. Until it
     runs, .swiper-slide is 100% wide and the row reads as one giant card, then snaps to three.
     Pre-sizing the slides makes the pre-init paint match the initialised layout, so there is
     nothing to snap. Swiper overwrites these with inline widths once it boots. */
  @media screen and (min-width: 768px) and (max-width: 1023px) {
    .wb-reviews__slide {
      width: 50%;
    }
  }

  @media screen and (min-width: 1024px) {
    .wb-reviews__slide {
      width: 33.3333%;
    }
  }

  /* Overlap only where three cards share the row. Below 1024 the track shows 2 or 1 card, and
     a bleeding neighbour would just poke into the frame with nothing to overlap.
     Cycle of 3 matches the tails and tilts, and keeps card 4 flush with the track edge. */
  @media screen and (min-width: 1024px) {
    .wb-reviews__slide:nth-child(3n + 2) .wb-reviews__bubble,
    .wb-reviews__slide:nth-child(3n + 3) .wb-reviews__bubble {
      width: calc(100% + 18px);
      margin-left: -18px;
    }

  }

  .wb-reviews__slide:nth-child(3n + 2) {
    z-index: 2;
  }

  .wb-reviews__slide:nth-child(3n + 3) {
    z-index: 3;
  }

  /* Figma rotations: -2.8° / +2.3° / +3.3°, Y offsets 701 / 711 / 697. */
  .wb-reviews__slide:nth-child(3n + 1) .wb-reviews__bubble {
    transform: rotate(-2.8deg) translateY(4px);
  }

  .wb-reviews__slide:nth-child(3n + 2) .wb-reviews__bubble {
    transform: rotate(2.3deg) translateY(14px);
  }

  .wb-reviews__slide:nth-child(3n + 3) .wb-reviews__bubble {
    transform: rotate(3.3deg);
  }

  /* Tails overhang below, so the track needs vertical room. Horizontally it clips flush:
     each card is inset inside its own slide (see .wb-reviews__slide padding) so the tilt never
     reaches the track edge. Any horizontal slack here would show the previous card's edge once
     the carousel advances — the neighbour can't hide it, since the Y stagger leaves its top
     strip uncovered. */
  .review-carousel__swiper {
    padding-top: 18px;
    padding-bottom: 30px;
  }

  .review-carousel__dots .swiper-pagination-bullet {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background-color: var(--card-bg);
    opacity: 0.4;
    transition: opacity 0.3s ease;
    cursor: pointer;
  }

  .review-carousel__dots .swiper-pagination-bullet-active {
    opacity: 1;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "AW Review Carousel",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Over 16,000 5 Star Reviews"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#F4ECE5"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Title size",
      "min": 14,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Title size mobile",
      "min": 14,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 25
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#E6CDB7"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text color",
      "default": "#431A03"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show arrows",
      "default": true
    },
    {
      "type": "color",
      "id": "arrow_background",
      "label": "Arrow background",
      "default": "#FEF8F3"
    },
    {
      "type": "color",
      "id": "arrow_icon_color",
      "label": "Arrow icon color",
      "default": "#431A03"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dots",
      "default": true
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "options": [
        { "value": "transparent", "label": "Transparent" },
        { "value": "color", "label": "Color" },
        { "value": "gradient", "label": "Gradient" },
        { "value": "image", "label": "Image" }
      ],
      "default": "gradient"
    },
    {
      "type": "color",
      "id": "background_solid",
      "label": "Background color",
      "default": "#431A03",
      "visible_if": "{{ section.settings.background_type == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient",
      "default": "linear-gradient(180deg, #391704 0%, #955325 100%)",
      "visible_if": "{{ section.settings.background_type == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "header",
      "content": "Background mobile"
    },
    {
      "type": "select",
      "id": "background_type_mobile",
      "label": "Background type mobile",
      "options": [
        { "value": "same", "label": "Same as desktop" },
        { "value": "transparent", "label": "Transparent" },
        { "value": "color", "label": "Color" },
        { "value": "gradient", "label": "Gradient" },
        { "value": "image", "label": "Image" }
      ],
      "default": "same"
    },
    {
      "type": "color",
      "id": "background_solid_mobile",
      "label": "Background color mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient_mobile",
      "label": "Background gradient mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "t:content.mobile"
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AW Review Carousel",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
