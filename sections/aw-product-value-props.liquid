{% liquid
    assign section_settings = section.settings
    assign color_scheme = section_settings.color_scheme
    assign text_color = color_scheme.text
    assign title = section_settings.title
    assign subtitle = section_settings.subtitle
    assign crown_icon = section_settings.crown_icon
    assign product_image = section_settings.product_image
    assign line_color = section_settings.line_color
    assign arc = section_settings.arc_strength | default: 16

    assign left_blocks = section.blocks | where: 'type', 'value_prop_left'
    assign right_blocks = section.blocks | where: 'type', 'value_prop_right'
%}

<div class="relative overflow-hidden spacing-style wb-section-bg" style="{% render 'section-background', settings: section.settings, part: 'style', fallback_color: color_scheme.background %} {% render 'spacing-style', settings: section.settings %}; color: {{ text_color }}">
  {% render 'section-background', settings: section.settings, part: 'media' %}
  {%- comment -%} ── DESKTOP ── {%- endcomment -%}
  <div class="hidden md:!block relative z-[2]">
    <div class="max-w-[803px] mx-auto px-6">

      <div class="wb-flex flex-col items-center text-center mb-10 gap-3">
        {% if crown_icon != blank %}
          {{ crown_icon | image_url: width: 60 | image_tag: class: '!w-[32px] !h-auto', alt: '' }}
        {% endif %}
        {% if title != blank %}
          <h2 class="font-bold text-[45px] font-gothic_condensed" style="color: {{ text_color }}">{{ title }}</h2>
        {% endif %}
        {% if subtitle != blank %}
          <p class="body text-base/[120%]! max-w-[460px] font-kurdis-semi-condensed! text-bear-black! font-semibold! md:text-lg/[120%]!" style="color: {{ text_color }}">{{ subtitle }}</p>
        {% endif %}
      </div>

      <div class="relative" x-data="productValueProps({{ arc }})">
        <svg class="absolute inset-0 w-full h-full overflow-visible pointer-events-none z-[1]">
          <path
            :d="path"
            fill="none"
            stroke="{{ line_color | default: '#75BDF4' }}"
            stroke-width="2"
            stroke-dasharray="2 2"
          />
        </svg>

        <div class="wb-grid [grid-template-columns:1fr_auto_1fr] items-stretch relative z-[2]">

          {%- comment -%} Left column {%- endcomment -%}
          <div class="wb-flex flex-col justify-between py-7" data-col="left">
            {% for block in left_blocks %}
              <div class="wb-flex flex-col items-center gap-2 mr-auto w-[150px]" data-prop {{ block.shopify_attributes }}>
                {% if block.settings.icon != blank %}
                  <div class="wb-flex items-center justify-center !w-[72px] !h-[72px] rounded-full bg-[#f0ebe3] shrink-0" data-icon data-side="left">
                    {{ block.settings.icon | image_url: width: 80 | image_tag: class: '!w-[36px] !h-[36px] object-contain md:w-18! md:h-18!' , alt: block.settings.label }}
                  </div>
                {% endif %}
                <span class="font-extrabold uppercase text-base font-gothic_condensed leading-tight text-center max-w-[150px]">{{ block.settings.label }}</span>
                {% if block.settings.subtext != blank %}
                  <span class="uppercase text-xs/[120%] font-semibold! text-center font-kurdis-semi-condensed">{{ block.settings.subtext }}</span>
                {% endif %}
              </div>
            {% endfor %}
          </div>

          {%- comment -%} Center product image {%- endcomment -%}
          <div class="wb-flex items-center justify-center w-[300px] max-w-[32vw]">
            {% if product_image != blank %}
              <img x-ref="bottle" src="{{ product_image | image_url: width: 600 }}" alt="{{ product_image.alt }}" loading="lazy" class="w-full h-auto object-contain">
            {% endif %}
          </div>

          {%- comment -%} Right column {%- endcomment -%}
          <div class="wb-flex flex-col justify-between py-7" data-col="right">
            {% for block in right_blocks %}
              <div class="wb-flex flex-col items-center gap-2 ml-auto w-[150px]" data-prop {{ block.shopify_attributes }}>
                {% if block.settings.icon != blank %}
                  <div class="wb-flex items-center justify-center !w-[72px] !h-[72px] rounded-full bg-[#f0ebe3] shrink-0" data-icon data-side="right">
                    {{ block.settings.icon | image_url: width: 80 | image_tag: class: '!w-[36px] !h-[36px] object-contain md:w-18! md:h-18!' , alt: block.settings.label }}
                  </div>
                {% endif %}
                <span class="font-extrabold uppercase text-base font-gothic_condensed leading-tight text-center max-w-[150px]">{{ block.settings.label }}</span>
                {% if block.settings.subtext != blank %}
                  <span class="uppercase text-xs/[120%] font-semibold! text-center font-kurdis-semi-condensed">{{ block.settings.subtext }}</span>
                {% endif %}
              </div>
            {% endfor %}
          </div>

        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ── MOBILE ── {%- endcomment -%}
  <div class="block md:!hidden relative z-[2]">
    <div class="wb-flex flex-col items-center text-center px-6 gap-2 mb-6">
      {% if crown_icon != blank %}
        {{ crown_icon | image_url: width: 60 | image_tag: class: '!w-[28px] !h-auto', alt: '' }}
      {% endif %}
      {% if title != blank %}
        <h2 class="h1 text-[35px]/none! font-extrabold md:text-[45px]/none!" style="color: {{ text_color }}">{{ title }}</h2>
      {% endif %}
      {% if subtitle != blank %}
        <p class="body text-bear-black! font-kurdis-semi-condensed! font-semibold! text-base/[120%]! md:text-lg/[120%]!" style="color: {{ text_color }}">{{ subtitle }}</p>
      {% endif %}
    </div>

    {% if product_image != blank %}
      <div class="wb-flex justify-center lg:!mb-8 px-6">
        <img src="{{ product_image | image_url: width: 560 }}" alt="{{ product_image.alt }}" loading="lazy" class="w-full h-auto object-contain mx-auto max-w-[40vw] md:!max-w-[280px]">
      </div>
    {% endif %}

    <div class="wb-flex flex-col gap-5 px-8 bg-[#F2E6DCCC] lg:!bg-transparent pt-8 pb-10 lg:!py-0">
      {% for block in section.blocks %}
        <div class="wb-flex items-center gap-4" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="wb-flex items-center justify-center w-11! h-11! rounded-full bg-[#f0ebe3] shrink-0">
              {{ block.settings.icon | image_url: width: 60 | image_tag: class: 'w-11! h-11! object-contain', alt: block.settings.label }}
            </div>
          {% endif %}
          <div class="wb-flex flex-col">
            <span class="font-extrabold uppercase text-xl/none font-gothic_condensed leading-snug">{{ block.settings.label }}</span>
            {% if block.settings.subtext != blank %}
              <span class="uppercase text-base/none font-semibold font-kurdis-condensed">{{ block.settings.subtext }}</span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "AW Product Value Props",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "options": [
        {
          "value": "transparent",
          "label": "Transparent"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        },
        {
          "value": "image",
          "label": "Image"
        }
      ],
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "background_solid",
      "label": "Background color",
      "default": "#F2E6DC",
      "visible_if": "{{ section.settings.background_type == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient",
      "visible_if": "{{ section.settings.background_type == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "select",
      "id": "background_image_fit",
      "label": "Background image fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover (may crop)"
        },
        {
          "value": "natural",
          "label": "Natural (no crop)"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "checkbox",
      "id": "background_image_overflow",
      "label": "Allow background image overflow",
      "default": false,
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "header",
      "content": "Background mobile"
    },
    {
      "type": "select",
      "id": "background_type_mobile",
      "label": "Background type mobile",
      "options": [
        {
          "value": "same",
          "label": "Same as desktop"
        },
        {
          "value": "transparent",
          "label": "Transparent"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        },
        {
          "value": "image",
          "label": "Image"
        }
      ],
      "default": "same"
    },
    {
      "type": "color",
      "id": "background_solid_mobile",
      "label": "Background color mobile",
      "default": "#F2E6DC",
      "visible_if": "{{ section.settings.background_type_mobile == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient_mobile",
      "label": "Background gradient mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "select",
      "id": "background_image_fit_mobile",
      "label": "Background image fit mobile",
      "options": [
        {
          "value": "cover",
          "label": "Cover (may crop)"
        },
        {
          "value": "natural",
          "label": "Natural (no crop)"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "checkbox",
      "id": "background_image_overflow_mobile",
      "label": "Allow background image overflow",
      "default": false,
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Connector line color",
      "default": "#75BDF4"
    },
    {
      "type": "range",
      "id": "arc_strength",
      "label": "Icon arc strength",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "image_picker",
      "id": "crown_icon",
      "label": "Crown Icon"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.mobile"
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "value_prop_left",
      "name": "Value Prop (Left)",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext (optional)"
        }
      ]
    },
    {
      "type": "value_prop_right",
      "name": "Value Prop (Right)",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AW Product Value Props"
    }
  ]
}
{% endschema %}
