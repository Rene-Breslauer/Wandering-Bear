{% liquid
    assign section_settings = section.settings
    assign color_scheme = section_settings.color_scheme
    assign text_color = color_scheme.text
    assign title_type = section_settings.title_type
    assign title = section_settings.title
    assign title_color = section_settings.title_color | default: text_color
    assign title_alt = section_settings.title_alt
    assign title_image = section_settings.title_image
    assign title_image_mobile = section_settings.title_image_mobile
    assign large_image = section_settings.large_image
    assign large_image_tablet = section_settings.large_image_tablet
    assign large_image_mobile = section_settings.large_image_mobile
%}

{% capture title_styles %}
    --font-size: {{ section.settings.font_size | default: 24 }}px;
    --font-size-mobile: {{ section.settings.font_size_mobile | default: 24 }}px;
{% endcapture %}

{% capture value_props %}
    <div class="wb-flex flex-col gap-5.5 md:gap-3">
        {% for block in section.blocks %}
            <div class="wb-flex gap-6 items-center md:gap-5">
                {{ block.settings.icon | image_url: width: 100 | image_tag: class: '!w-[54px] !h-[54px]', alt: block.settings.text }}
                <span class="body text-bear-black">{{ block.settings.text }}</span>
            </div>
        {% endfor %}
    </div>
{% endcapture %}

<div class="wb-flex relative overflow-hidden spacing-style wb-section-bg" style="{% render 'section-background', settings: section.settings, part: 'style', fallback_color: color_scheme.background %} {% render 'spacing-style', settings: section.settings %}">
    {% render 'section-background', settings: section.settings, part: 'media' %}
    <div class="grid smd:!grid-cols-2 max-w-[1092px] w-full mx-auto relative z-[1]">
        <div class="wb-flex mx-auto relative z-[2] justify-center order-2 md:!order-1 pt-[30px] md:!pt-0 px-6 md:!px-0 md:pb-14">
            <div class="wb-flex flex-col justify-center items-start mx-auto max-w-[440px]">
                {% if title_type == 'image' %}
                    {% if title_image != blank %}
                        <div class="max-w-[442px] w-full{% if template.suffix == '96oz' %} mb-0.5! md:mb-5!{% else %} mb-5!{% endif %}">
                            {% render 'title-image', image: title_image, image_mobile: title_image_mobile, alt: title_alt, class: 'w-full max-h-full object-contain' %}
                        </div>
                    {% endif %}
                {% elsif title_type == 'text' %}
                    {% if title != blank %}
                        <span class="h1 mb-8 title-text text-center leading-[1.2]" style="color: {{ title_color }}; {{ title_styles }}">{{ title | replace: '\n', '<br/>' }}</span>
                    {% endif %}
                {% endif %}

                {{ value_props }}
            </div>
            </div>
            <div class="order-1 smd:order-2! smd:pr-7.5 lg:pr-0 md:max-w-[500px] md:ml-auto">
                {% if large_image != blank %}
                    {% render 'picture', source: large_image, tablet_source: large_image_tablet, mobile_source: large_image_mobile, class: 'w-full h-full rounded-[5px]', alt: large_image.alt, width: 1920, height: 1080, preload: 'lazy', loading: 'lazy' %}
                {% endif %}
            </div>
    </div>
</div>

{% stylesheet %}
    .title-text {
        font-size: var(--font-size) !important;
    }

    @media screen and (max-width: 1023px) {
        .title-text {
            font-size: var(--font-size-mobile) !important;
        }
    }
{% endstylesheet %}

{% schema %}
{
  "name": "AW Image + Text Icons",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "options": [
        {
          "value": "transparent",
          "label": "Transparent"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        },
        {
          "value": "image",
          "label": "Image"
        }
      ],
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "background_solid",
      "label": "Background color",
      "default": "#F2E6DC",
      "visible_if": "{{ section.settings.background_type == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient",
      "visible_if": "{{ section.settings.background_type == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "select",
      "id": "background_image_fit",
      "label": "Background image fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover (may crop)"
        },
        {
          "value": "natural",
          "label": "Natural (no crop)"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "checkbox",
      "id": "background_image_overflow",
      "label": "Allow background image overflow",
      "default": false,
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "header",
      "content": "Background mobile"
    },
    {
      "type": "select",
      "id": "background_type_mobile",
      "label": "Background type mobile",
      "options": [
        {
          "value": "same",
          "label": "Same as desktop"
        },
        {
          "value": "transparent",
          "label": "Transparent"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        },
        {
          "value": "image",
          "label": "Image"
        }
      ],
      "default": "same"
    },
    {
      "type": "color",
      "id": "background_solid_mobile",
      "label": "Background color mobile",
      "default": "#F2E6DC",
      "visible_if": "{{ section.settings.background_type_mobile == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient_mobile",
      "label": "Background gradient mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "select",
      "id": "background_image_fit_mobile",
      "label": "Background image fit mobile",
      "options": [
        {
          "value": "cover",
          "label": "Cover (may crop)"
        },
        {
          "value": "natural",
          "label": "Natural (no crop)"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "checkbox",
      "id": "background_image_overflow_mobile",
      "label": "Allow background image overflow",
      "default": false,
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "select",
      "id": "title_type",
      "label": "Title Type",
      "options": [
        {
          "value": "text",
          "label": "Text"
        },
        {
          "value": "image",
          "label": "Image"
        }
      ],
      "default": "text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "info": "Use \\n to add a line break.",
      "visible_if": "{{ section.settings.title_type == 'text' }}"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "info": "Leave empty to use the color scheme text color.",
      "visible_if": "{{ section.settings.title_type == 'text' }}"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font Size",
      "min": 16,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ section.settings.title_type == 'text' }}"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font Size Mobile",
      "min": 16,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ section.settings.title_type == 'text' }}"
    },
    {
      "type": "text",
      "id": "title_alt",
      "label": "Title Alt",
      "visible_if": "{{ section.settings.title_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "title_image",
      "label": "Title Image",
      "visible_if": "{{ section.settings.title_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "title_image_mobile",
      "label": "Title Image Mobile",
      "visible_if": "{{ section.settings.title_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "large_image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "large_image_tablet",
      "label": "Image Tablet"
    },
    {
      "type": "image_picker",
      "id": "large_image_mobile",
      "label": "Image Mobile"
    },

    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.mobile"
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "icon_item",
      "name": "Icon Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AW Image + Text Icons"
    }
  ]
}
{% endschema %}