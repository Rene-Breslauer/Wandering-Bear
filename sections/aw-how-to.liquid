{% liquid
    assign section_settings = section.settings
    assign title = section_settings.title
    assign image = section_settings.image
    assign icon = section_settings.icon

    for block in section.blocks
        if block.type == 'how-to-mix' and forloop.first
            assign metaobject = block.settings.metaobject
            assign title = block.settings.title
            assign title_handleize = block.settings.title | handleize
            assign active_title = title_handleize
        endif
    endfor
%}
{% style %}
    [data-step-title].active {
        background: var(--color-beige);
    }
{% endstyle %}

{% capture menu %}
    <div class="wb-flex gap-0.5 bg-foam border-2 border-espresso rounded-[30px] p-1.5 w-fit mb-9">
        {% for block in section.blocks %}
            {% if block.type == 'how-to-mix' %}
                {% liquid 
                    assign metaobject = block.settings.metaobject
                    assign title = block.settings.title
                    assign title_handleize = block.settings.title | handleize
                %}

                <div
                    @click="setActive('{{ title_handleize }}')" data-step-title class="{% if forloop.first %} active {% endif %} px-4 py-3 rounded-[25px] cursor-pointer font-gothic_condensed font-bold text-base leading-[22px] tracking-[1%] text-center uppercase min-w-[140px]"
                    :class="{ 'active': activeTitle === '{{ title_handleize }}' }" data-title="{{ title_handleize }}">
                    <span>{{ title }}</span>
                </div>
                
            {% endif %}
        {% endfor %}
    </div>
{% endcapture %}

<div x-data="howToMix('{{ active_title }}')" class="w-full max-w-[1099px] mx-auto smd:pt-10 lg:pt-[64px] pb-5">
    <div class="wb-flex flex-col-reverse items-center lg:flex-row justify-between">
        <div class="wb-flex flex-col gap-4 mt-6 px-6 w-full max-w-[440px] md:px-0">
            <div class="wb-flex items-center justify-center gap-4">
                <h2 class="text-[35px]/none font-extrabold text-center uppercase font-gothic_condensed md:text-[45px]/none leading-[61px] tracking-[1%] whitespace-nowrap">{{ section.settings.title }}</h2>
                {{ icon | image_url: width: 60 | image_tag: class: '!h-11 !w-fit' }}
            </div>
            <div class="wb-flex flex-col items-center">
                {{ menu }}
                {% for block in section.blocks %}
                    {% if block.type == 'how-to-mix' %}
                        {% liquid 
                            assign metaobject = block.settings.metaobject
                            assign title_handleize = block.settings.title | handleize
                        %}

                        <div x-cloak x-show="activeTitle === '{{ title_handleize }}'" class="wb-flex flex-col gap-5">
                            {% for step in metaobject.steps.value %}
                                {% liquid
                                    assign index = forloop.index
                                    assign description = step.content | metafield_tag
                                    assign step_title = 'Step ' | append: index
                                    assign icon = step.icon | image_url: width: 100 | image_tag
                                    assign title = step.title | handleize
                                %}

                                <div class="wb-flex gap-4 items-center">
                                    <div class="w-[54px] h-[54px] min-w-[54px] min-h-[54px]">
                                        {{ icon }}
                                    </div>
                                    <div class="wb-flex flex-col gap-1">
                                        <h3 class="body font-bold text-lg font-bold text-bear-black">{{ step_title }}</h3>
                                        <div class="body text-bear-black">{{ description }}</div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
        <div class="w-full h-full mx-auto smd:max-w-[500px] lg:mx-0">
            {{ image | image_url: width: 1000 | image_tag }}
        </div>
    </div>
</div>


{% schema %}
    {
      "name": "AW How To Prepare",
      "settings": [
        {
            "type": "text",
            "id": "title",
            "label": "Title"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
        },
        {
            "type": "image_picker",
            "id": "icon",
            "label": "Icon"
        }
      ],
      "blocks": [
        {
          "type": "how-to-mix",
          "name": "How To Mix",
          "settings": [
            {
              "type": "text",
              "id": "title",
              "label": "Title"
            },
            {
               "type": "metaobject",
               "id": "metaobject",
               "label": "Instructions",
               "metaobject_type": "how_to_mix"
            }
          ]
        }
      ],
      "presets": [
        { "name": "AW How To Prepare" }
      ]
    }
    {% endschema %}