{% liquid
    assign section_settings = section.settings
    assign color_scheme = section_settings.color_scheme
    assign foreground_image = section_settings.foreground_image
    assign background_image = section_settings.background_image
    assign title_type = section_settings.title_type
    assign title_image = section_settings.title_image
    assign title_text = section_settings.title_text
    assign subtitle = section_settings.subtitle
    assign buttons = section.blocks | where: "type", "button"
%}

{% capture hero_content %}
    <div class="flex justify-center items-center">
        <div class="w-full h-full absolute inset-0">
            {% render 'picture', 
                loading: 'eager', 
                preload: true, 
                source: background_image, 
                class: 'w-full h-full object-cover',
                alt: background_image.alt,
                width: 1920,
                height: 1080
            %}
        </div>
        <div class="relative flex flex-col gap-4 z-1">
            {% if title_image != blank %}
                {{ title_image | image_url: width: 1920 | image_tag: class: 'w-full h-full object-contain' }}
            {% elsif title_text != blank %}
                <h1 class="h1">{{ title_text }}</h1>
            {% endif %}
            {% if subtitle != blank %}
                <span class="h3">{{ subtitle }}</span>
            {% endif %}
            {% if buttons != blank %}
                <div class="flex gap-4">
                    {% for button in buttons %}
                        {% render 'wb-button', style: button.settings.style, label: button.settings.label, link: button.settings.link %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
{% endcapture %}

<div class="flex justify-center items-center aspect-[1920/1080]">
        {{ hero_content }}
</div>

{% schema %}
{
    "name": "AW Hero",
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Color Scheme",
            "default": "scheme-1"
        },
        {
            "type": "image_picker",
            "id": "foreground_image",
            "label": "Foreground Image"
        },
        {
            "type": "image_picker",
            "id": "background_image",
            "label": "Background Image"
        },
        {
            "type": "select",
            "id": "title_type",
            "label": "Title Type",
            "options": [
                {
                    "value": "image",
                    "label": "Image"
                },
                {
                    "value": "text",
                    "label": "Text"
                }
            ],
            "default": "image"
        },
        {
            "type": "image_picker",
            "id": "title_image",
            "label": "Title Image",
            "visible_if": "{{ section.settings.title_type == 'image' }}"
        },
        {
            "type": "text",
            "id": "title_text",
            "label": "Title Text",
            "visible_if": "{{ section.settings.title_type == 'text' }}"
        },
        {
            "type": "text",
            "id": "subtitle",
            "label": "Subtitle"
        }
    ],
    "blocks": [
        {
            "type": "button",
            "name": "Button",
            "limit": 2,
            "settings": [
                {
                    "type": "select",
                    "id": "style",
                    "label": "Style",
                    "options": [
                        {
                            "value": "primary",
                            "label": "Primary"
                        },
                        {
                            "value": "secondary",
                            "label": "Secondary"
                        }
                    ],
                    "default": "primary"
                },
                {
                    "type": "text",
                    "id": "label",
                    "label": "Label"
                },
                {
                    "type": "url",
                    "id": "link",
                    "label": "Link"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "AW Hero"
        }
    ]
}
{% endschema %}