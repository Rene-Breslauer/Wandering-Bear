{% liquid
    assign section_settings = section.settings
    assign color_scheme = section_settings.color_scheme
    assign foreground_image = section_settings.foreground_image
    assign foreground_image_mobile = section_settings.foreground_image_mobile
    assign background_image = section_settings.background_image
    assign background_image_tablet = section_settings.background_image_tablet
    assign background_image_mobile = section_settings.background_image_mobile
    assign title_type = section_settings.title_type
    assign title_image = section_settings.title_image
    assign title_image_mobile = section_settings.title_image_mobile
    assign title_text = section_settings.title_text
    assign subtitle = section_settings.subtitle
    assign buttons = section.blocks | where: "type", "button"
    assign badge = section_settings.badge
%}

{% capture title_styles %}
    --font-size: {{ section.settings.font_size }}px;
    --font-size-mobile: {{ section.settings.font_size_mobile }}px;
{% endcapture %}

{% capture hero_content %}
        {% render 'picture', source: background_image, tablet_source: background_image_tablet, mobile_source: background_image_mobile, class: 'w-full !h-full object-cover object-left sm:!object-[center_bottom] md:!object-center !max-w-none absolute inset-0 2xl:!object-[0%_30%]', alt: background_image.alt, width: 1920, height: 1080, preload: 'eager', loading: 'eager' %}
        {% if title_image != blank or title_text != blank or subtitle != blank %}
            <div class="container relative wb-flex pt-8 pb-[64px] smd:py-0
            justify-center smd:justify-between w-full max-w-none smd:max-w-[700px] md:max-w-[970px] mx-0 md:mx-auto h-full pb-10 max-h-[528px]">
                {% if foreground_image != blank or foreground_image_mobile != blank %}
                    {% render 'picture', source: foreground_image, mobile_source: foreground_image_mobile, class: 'absolute min-h-full -left-5 sm:left-0 bottom-0 smd:static w-fit h-full object-cover z-1 !max-w-[375px] object-top', alt: foreground_image.alt, width: 1920, height: 1080, preload: 'eager', loading: 'eager' %}
                {% endif %}
                <div class="relative wb-flex flex-col items-center justify-center sm:items-start md:items-start gap-4 z-1 w-fit max-w-full">
                    {% if title_image != blank and title_type == 'image' %}
                        {% render 'title-image', image: title_image, image_mobile: title_image_mobile, alt: title_image.alt, class: 'relative sm:left-0 w-full h-full object-contain !max-w-[270px] md:!max-w-full mx-auto', preload: 'eager', loading: 'eager' %}
                    {% elsif title_text != blank and title_type == 'text'%}
                        <h1 class="h1 title-text leading-[1.2] text-center md:!text-left" style="color: {{ color_scheme.settings.foreground }}; {{ title_styles }}">{{ title_text | replace: '\b', '<br>' }}</h1>
                    {% endif %}
                    {% if subtitle != blank %}
                        <span class="h3 text-center md:!text-xl title-text" style="color: {{ color_scheme.settings.foreground }};">{{ subtitle }}</span>
                    {% endif %}
                    {% if buttons != blank %}
                        <div class="wb-flex flex-col md:!flex-row gap-4 w-fit mx-auto md:!mx-0">
                            {% for button in buttons %}
                                <div class="relative mx-auto md:!mx-0">
                                    {% if button.settings.badge != blank %}
                                        {{ button.settings.badge | image_url: width: 100 | image_tag: class: 'absolute z-[2] -top-5 -left-10 !w-[59px] !h-auto shadow-button', loading: 'eager', preload: 'eager' }}
                                    {% endif %}
                                    {% render 'wb-button', style: button.settings.style, label: button.settings.label, link: button.settings.link %}
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endif %}
{% endcapture %}

{% if hero_content != blank %}
<div class="flex relative justify-center items-center relative overflow-hidden 
{% comment %} py-8 md:py-20 lg:py-8 lg:h-[560px] {% endcomment %}
">
    {% comment %} {% if foreground_image != blank or foreground_image_mobile != blank %}
        {% render 'picture', source: foreground_image, mobile_source: foreground_image_mobile, class: 'relative w-fit h-full object-contain z-1', alt: foreground_image.alt, width: 1920, height: 1080, preload: 'eager', loading: 'eager' %}
    {% endif %} {% endcomment %}
    <div class="flex justify-center items-center w-full">
      {{ hero_content }}
    </div>
    {% if badge != blank %}
        {{ badge | image_url: width: 100 | image_tag: class: 'absolute z-[2] -bottom-5 right-[20vw] !w-[85px] !h-auto', loading: 'eager', preload: 'eager' }}
    {% endif %}
    <svg preserveAspectRatio="none" class="absolute -bottom-0.5 left-0 w-full z-[2]" xmlns="http://www.w3.org/2000/svg" width="1290" height="30" viewBox="0 0 1290 30" fill="none">
        <path d="M0 0.952156L320 0L938 7.63188L1290 5.2564V30H0V0.952156Z" fill="{{ color_scheme.settings.background }}"/>
    </svg>
</div>
{% endif %}

{% style %}
    .title-text {
        font-size: var(--font-size);
    }

    @media (max-width: 1024px) {
        .title-text {
            font-size: var(--font-size-mobile);
        }
    }
{% endstyle %}

{% schema %}
{
    "name": "AW Hero",
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Color Scheme",
            "default": "scheme-1"
        },
        {
            "type": "image_picker",
            "id": "foreground_image",
            "label": "Foreground Image"
        },
        {
            "type": "image_picker",
            "id": "foreground_image_mobile",
            "label": "Foreground Image Mobile"
        },
        {
            "type": "image_picker",
            "id": "background_image",
            "label": "Background Image"
        },
        {
            "type": "image_picker",
            "id": "background_image_tablet",
            "label": "Background Image Tablet"
        },
        {
            "type": "image_picker",
            "id": "background_image_mobile",
            "label": "Background Image Mobile"
        },
        {
            "type": "select",
            "id": "title_type",
            "label": "Title Type",
            "options": [
                {
                    "value": "image",
                    "label": "Image"
                },
                {
                    "value": "text",
                    "label": "Text"
                }
            ],
            "default": "image"
        },
        {
            "type": "image_picker",
            "id": "title_image",
            "label": "Title Image",
            "visible_if": "{{ section.settings.title_type == 'image' }}"
        },
        {
            "type": "image_picker",
            "id": "title_image_mobile",
            "label": "Title Image Mobile",
            "visible_if": "{{ section.settings.title_type == 'image' }}"
        },
        {
            "type": "text",
            "id": "title_text",
            "label": "Title",
            "visible_if": "{{ section.settings.title_type == 'text' }}",
            "info": "Add '\\b' for line breaks"
        },
        {
            "type": "range",
            "id": "font_size",
            "label": "Font Size",
            "min": 16,
            "max": 100,
            "step": 1,
            "unit": "px",
            "default": 24,
            "visible_if": "{{ section.settings.title_type == 'text' }}"
        },
        {
            "type": "range",
            "id": "font_size_mobile",
            "label": "Font Size Mobile",
            "min": 16,
            "max": 100,
            "step": 1,
            "unit": "px",
            "default": 24,
            "visible_if": "{{ section.settings.title_type == 'text' }}"
        },
        {
            "type": "text",
            "id": "subtitle",
            "label": "Subtitle"
        },
        {
            "type": "image_picker",
            "id": "badge",
            "label": "Badge"
        }
    ],
    "blocks": [
        {
            "type": "button",
            "name": "Button",
            "limit": 2,
            "settings": [
                {
                    "type": "select",
                    "id": "style",
                    "label": "Style",
                    "options": [
                        {
                            "value": "primary",
                            "label": "Primary"
                        },
                        {
                            "value": "secondary-gold",
                            "label": "Secondary Gold"
                        },
                        {
                            "value": "secondary-cream",
                            "label": "Secondary Cream"
                        }
                    ],
                    "default": "primary"
                },
                {
                    "type": "text",
                    "id": "label",
                    "label": "Label"
                },
                {
                    "type": "url",
                    "id": "link",
                    "label": "Link"
                },
                {
                    "type": "image_picker",
                    "id": "badge",
                    "label": "Badge"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "AW Hero"
        }
    ]
}
{% endschema %}