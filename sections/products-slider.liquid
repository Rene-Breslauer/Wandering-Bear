{% liquid
  assign section_settings = section.settings
  assign color_scheme = section_settings.color_scheme
  assign layout_type = section_settings.layout_type
  assign show_navigation = section_settings.show_navigation
  assign section_width = section_settings.section_width

  assign product_block_count = 0
  assign has_content_blocks = false
  assign fallback_cols_mobile = section_settings.slides_per_view_mobile | ceil | at_least: 1
  assign fallback_cols_tablet = section_settings.slides_per_view_tablet | ceil | at_least: 1
  assign fallback_cols_desktop = section_settings.slides_per_view_desktop | ceil | at_least: 1

  for block in section.blocks
    if block.id contains 'cart_product_slider'
      assign product_block_count = product_block_count | plus: 1
    else
      assign has_content_blocks = true
    endif
  endfor

  assign inner_width_class = 'w-full'
  if section_width == 'page-width'
    assign inner_width_class = 'container mx-auto max-w-[1092px]'
  endif
%}

<div
  class="section-background wb-section-bg color-{{ color_scheme }}"
  style="{% render 'section-background', settings: section.settings, part: 'style', fallback_color: color_scheme.settings.background %}"
>
  {% render 'section-background', settings: section.settings, part: 'media' %}
</div>
<div
  class="section section--{{ section_width }} color-{{ color_scheme }} products-slider products-slider--{{ layout_type }} spacing-style relative"
  style="{% render 'spacing-style', settings: section.settings %}"
  {{ section.shopify_attributes }}
>
  {% if has_content_blocks %}
    <div class="products-slider__content {{ inner_width_class }} relative z-[1] flex flex-col items-center text-center gap-2 w-full">
      {% for block in section.blocks %}
        {% unless block.id contains 'cart_product_slider' %}
          {% render block %}
        {% endunless %}
      {% endfor %}
    </div>
  {% endif %}

  {% if product_block_count > 0 %}
    {% if layout_type == 'grid' %}
      <div class="products-slider__inner {{ inner_width_class }} relative z-[1]">
        <div
          class="products-slider__grid"
          style="
            --products-slider-cols-mobile: {{ section_settings.columns_mobile }};
            --products-slider-cols-desktop: {{ section_settings.columns_desktop }};
            --products-slider-gap-mobile: {{ section_settings.grid_gap_mobile }}px;
            --products-slider-gap-desktop: {{ section_settings.grid_gap_desktop }}px;
          "
        >
          {% for block in section.blocks %}
            {% if block.id contains 'cart_product_slider' %}
              {% render block %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div
        class="products-slider__track relative z-[1] w-full max-w-[100vw] overflow-x-hidden"
        x-data="productsSlider"
        data-products-slider
        data-layout="{{ layout_type }}"
        data-slides-mobile="{{ section_settings.slides_per_view_mobile }}"
        data-slides-tablet="{{ section_settings.slides_per_view_tablet }}"
        data-slides-desktop="{{ section_settings.slides_per_view_desktop }}"
        data-space-mobile="{{ section_settings.space_between_mobile }}"
        data-space-tablet="{{ section_settings.space_between_tablet }}"
        data-space-desktop="{{ section_settings.space_between_desktop }}"
        data-offset-mobile="{{ section_settings.slide_offset_mobile }}"
        data-offset-desktop="{{ section_settings.slide_offset_desktop }}"
        data-show-navigation="{{ show_navigation }}"
      >
        <div
          class="swiper products-slider__swiper products-slider__swiper--fallback products-slider__swiper--fallback-mobile-{{ fallback_cols_mobile }} products-slider__swiper--fallback-tablet-{{ fallback_cols_tablet }} products-slider__swiper--fallback-desktop-{{ fallback_cols_desktop }}"
          style="
            --products-slider-fallback-cols-mobile: {{ fallback_cols_mobile }};
            --products-slider-fallback-cols-tablet: {{ fallback_cols_tablet }};
            --products-slider-fallback-cols-desktop: {{ fallback_cols_desktop }};
            --products-slider-fallback-gap-mobile: {{ section_settings.space_between_mobile }}px;
            --products-slider-fallback-gap-tablet: {{ section_settings.space_between_tablet }}px;
            --products-slider-fallback-gap-desktop: {{ section_settings.space_between_desktop }}px;
          "
        >
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              {% if block.id contains 'cart_product_slider' %}
                <div class="swiper-slide h-auto">
                  {% render block %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {% if show_navigation %}
          <div class="products-slider__button-prev hidden md:flex swiper-button-prev group transition-all duration-300 absolute z-[2] -translate-y-1/2">
            {% render 'icons', icon: 'chevron-left' with class: '-translate-x-[10%] group-hover:!text-gold transition-all duration-300' %}
          </div>
          <div class="products-slider__button-next hidden md:flex swiper-button-next group transition-all duration-300 absolute z-[2] -translate-y-1/2">
            {% render 'icons', icon: 'chevron-right' with class: 'translate-x-[10%] group-hover:!text-gold transition-all duration-300' %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  {% endif %}
</div>

{% stylesheet %}
  .products-slider-section .products-slider {
    background-color: transparent;
  }
{% endstylesheet %}


