{% liquid
    assign button_text = section.settings.button_text
    assign button_url = section.settings.button_url
%}

{%- comment -%}
  Background, padding and grayscale all default to the section's previous hard-coded behaviour
  (transparent, 50/6 desktop, 20/6 mobile, full colour) so the existing homepage placement is
  unchanged. The listicle overrides them per-section.
{%- endcomment -%}
{% capture wall_styles %}
    --logo-pt: {{ section.settings.padding_top | default: 50 }}px;
    --logo-pb: {{ section.settings.padding_bottom | default: 6 }}px;
    --logo-pt-mobile: {{ section.settings.padding_top_mobile | default: 20 }}px;
    --logo-pb-mobile: {{ section.settings.padding_bottom_mobile | default: 6 }}px;
{% endcapture %}

<div class="relative overflow-hidden wb-section-bg" style="{% render 'section-background', settings: section.settings, part: 'style' %} {{ wall_styles }}">
    {% render 'section-background', settings: section.settings, part: 'media' %}
    <div class="container aw-logo-wall__inner relative z-[1] max-w-[1132px] flex flex-col mx-auto !gap-[30px]{% if section.settings.grayscale %} aw-logo-wall--grayscale{% endif %}{% if section.settings.mobile_per_row == '3' %} aw-logo-wall--mobile-3{% endif %}">
        <div class="aw-logo-wall__row max-w-[380px] sm:max-w-[450px] mx-auto md:!max-w-full flex items-center justify-center lg:!justify-between flex-wrap w-full gap-7 smd:!gap-0">
            {% for block in section.blocks %}          
                <div class="aw-logo-wall__cell
                {% if block.settings.hide_on_mobile %} hidden md:flex {% endif %} w-[128px] sm:w-[200px] h-[58px] md:!h-[72px] flex items-center justify-center">
                    {% assign class = 'object-contain !max-h-full !w-auto !h-auto  logo-' | append: block.id %}
                    {{ block.settings.image | image_url: width: 400 | image_tag: class: class, alt: block.settings.image.alt }}
                </div>
                {% style %}
                    .logo-{{ block.id }} {
                        max-width: {{ block.settings.max_width }}px;
                    }

                    @media (max-width: 768px) {
                        .logo-{{ block.id }} {
                            max-width: {{ block.settings.max_width_mobile }}px;
                        }
                    }
                {% endstyle %}
            {% endfor %}
        </div>

        {% if button_text != blank and button_url != blank %}
            {% render 'wb-button', style: 'secondary-gold', class: 'mx-auto !w-[280px]', label: button_text, link: button_url %}
        {% endif %}
    </div>
</div>

{% stylesheet %}
    .aw-logo-wall__inner {
        padding-top: var(--logo-pt-mobile);
        padding-bottom: var(--logo-pb-mobile);
    }

    @media screen and (min-width: 1024px) {
        .aw-logo-wall__inner {
            padding-top: var(--logo-pt);
            padding-bottom: var(--logo-pb);
        }
    }

    /* Three per row below 480px. The default cell is 128px and the gap 28px, so three would
       need 440px and wrap to 2+2+1. Narrowing the gap and sizing the cell off the row lets the
       logos sit three-up AND grow. Opt-in, because the homepage and listicle want the 2-up default. */
    @media screen and (max-width: 479px) {
        .aw-logo-wall--mobile-3 .aw-logo-wall__row {
            gap: 12px;
            /* The row runs edge to edge at 375, so without this the outer logos touch the
               screen. Figma insets them (row spans 33…344). */
            padding-left: 16px;
            padding-right: 16px;
        }

        .aw-logo-wall--mobile-3 .aw-logo-wall__cell {
            width: calc((100% - 24px) / 3);
        }
    }


    /* Figma renders the press logos monochrome; the homepage keeps them in brand colour. */
    .aw-logo-wall--grayscale img {
        filter: grayscale(1);
    }
{% endstylesheet %}

{% schema %}
{
  "name": "AW Logo Wall",
  "settings": [
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "checkbox",
      "id": "grayscale",
      "label": "Grayscale logos",
      "info": "Figma shows the press logos monochrome on the listicle. Off keeps brand colour.",
      "default": false
    },
    {
      "type": "select",
      "id": "mobile_per_row",
      "label": "Logos per row on mobile",
      "info": "Under 480px. Three-up needs a tighter gap, so the logos also get a little more room.",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "options": [
        { "value": "transparent", "label": "Transparent" },
        { "value": "color", "label": "Color" },
        { "value": "gradient", "label": "Gradient" },
        { "value": "image", "label": "Image" }
      ],
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "background_solid",
      "label": "Background color",
      "default": "#BFD7E9",
      "visible_if": "{{ section.settings.background_type == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient",
      "visible_if": "{{ section.settings.background_type == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "header",
      "content": "Background mobile"
    },
    {
      "type": "select",
      "id": "background_type_mobile",
      "label": "Background type mobile",
      "options": [
        { "value": "same", "label": "Same as desktop" },
        { "value": "transparent", "label": "Transparent" },
        { "value": "color", "label": "Color" },
        { "value": "gradient", "label": "Gradient" },
        { "value": "image", "label": "Image" }
      ],
      "default": "same"
    },
    {
      "type": "color",
      "id": "background_solid_mobile",
      "label": "Background color mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient_mobile",
      "label": "Background gradient mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "checkbox",
          "id": "hide_on_mobile",
          "label": "Hide on mobile",
          "default": false
        },
        {
            "type": "text",
            "id": "max_width",
            "label": "Max Width"
        },
        {
          "type": "text",
          "id": "max_width_mobile",
          "label": "Max Width (Mobile)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AW Logo Wall"
    }
  ]
}
{% endschema %}