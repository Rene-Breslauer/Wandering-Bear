{% liquid
    assign section_settings = section.settings
    assign color_scheme = section_settings.color_scheme
    assign text_color = color_scheme.settings.foreground
    assign image = section_settings.image
    assign badge = section_settings.badge
    assign subtitle = section_settings.subtitle
    assign title = section_settings.title
    assign description = section_settings.description
%}

<div class="wb-flex flex-col lg:!flex-row relative overflow-hidden spacing-style wb-section-bg" style="{% render 'section-background', settings: section.settings, part: 'style', fallback_color: color_scheme.settings.background %} {% render 'spacing-style', settings: section.settings %}">
    {% render 'section-background', settings: section.settings, part: 'media' %}
    {% if image != blank %}
        <div class="wb-flex w-full lg:!w-1/2 relative z-[1] items-center justify-center">
            <div class="w-full h-full wb-flex items-stretch justify-stretch lg:[&_picture]:w-full">
              {% render 'picture', source: image, class: '!w-[100vw] lg:!w-auto !h-auto object-cover !min-h-full !min-w-full ', alt: image.alt, width: 1920, height: 1080, preload: 'lazy', loading: 'lazy' %}
            </div>
            {{ badge | image_url: width: 100 | image_tag: class: 'absolute z-[2] -bottom-10 lg:!bottom-auto lg:-right-10 !w-[188px] !h-auto', loading: 'eager', preload: 'eager' }}
        </div>
    {% endif %}
    <div class="wb-flex justify-start items-center w-full lg:!w-1/2 relative z-[1]" style="color: {{ text_color }}">
        <div class="wb-flex flex-col gap-1.5! max-w-full w-1/2 py-[43px] px-[30px] md:!px-[77px] w-full text-center lg:!text-left lg:max-w-[645px]">
        {% if title != blank %}
            <span class="h2 text-[28px]/none! font-gothic_condensed font-extrabold! text-[#F2E6DC] md:text-[25px]/none!{% if subtitle == blank and description != blank %} mb-3!{% else %} mb-0.5!{% endif %}" style="color: {{ text_color }}">{{ title }}</span>
        {% endif %}
        {% if subtitle != blank %}
            <span class="h3 text-[20px]/none! font-extrabold! font-gothic_condensed text-[#F2E6DC] md:text-base/none!{% if description != blank %} mb-3!{% endif %}" style="color: {{ text_color }}">{{ subtitle }}</span>
        {% endif %}
        {% if description != blank %}
            <span class="body max-w-[422px] font-normal! font-kurdis-semi-condensed text-[#F2E6DC] mx-auto lg:mx-0" style="color: {{ text_color }}">{{ description }}</span>
        {% endif %}
        </div>
    </div>
</div>

{% schema %}
{
  "name": "AW Guarantee Banner",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "options": [
        {
          "value": "transparent",
          "label": "Transparent"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        },
        {
          "value": "image",
          "label": "Image"
        }
      ],
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "background_solid",
      "label": "Background color",
      "default": "#F2E6DC",
      "visible_if": "{{ section.settings.background_type == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient",
      "visible_if": "{{ section.settings.background_type == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "select",
      "id": "background_image_fit",
      "label": "Background image fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover (may crop)"
        },
        {
          "value": "natural",
          "label": "Natural (no crop)"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "checkbox",
      "id": "background_image_overflow",
      "label": "Allow background image overflow",
      "default": false,
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "header",
      "content": "Background mobile"
    },
    {
      "type": "select",
      "id": "background_type_mobile",
      "label": "Background type mobile",
      "options": [
        {
          "value": "same",
          "label": "Same as desktop"
        },
        {
          "value": "transparent",
          "label": "Transparent"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        },
        {
          "value": "image",
          "label": "Image"
        }
      ],
      "default": "same"
    },
    {
      "type": "color",
      "id": "background_solid_mobile",
      "label": "Background color mobile",
      "default": "#F2E6DC",
      "visible_if": "{{ section.settings.background_type_mobile == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient_mobile",
      "label": "Background gradient mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "select",
      "id": "background_image_fit_mobile",
      "label": "Background image fit mobile",
      "options": [
        {
          "value": "cover",
          "label": "Cover (may crop)"
        },
        {
          "value": "natural",
          "label": "Natural (no crop)"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "checkbox",
      "id": "background_image_overflow_mobile",
      "label": "Allow background image overflow",
      "default": false,
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.mobile"
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "badge",
      "label": "Badge"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description"
    }
  ],
  "presets": [
    {
      "name": "AW Guarantee Banner"
    }
  ]
}
{% endschema %}