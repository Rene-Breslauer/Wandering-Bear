                    },
                    {
                        "type": "image_picker",
                        "id": "title_image",
                        "label": "Title Image",
                        "visible_if": "{{ block.settings.title_type == 'image' }}"
                    },
                    {
                        "type": "image_picker",
                        "id": "title_image_mobile",
