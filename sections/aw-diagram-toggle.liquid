                    },
                    {
                        "type": "image_picker",
                        "id": "diagram_image",
                        "label": "Diagram Image"
                    },
                    {
                        "type": "image_picker",
                        "id": "icon_1",
                        "label": "Icon 1"
                    },
                    {
                        "type": "text",
                        "id": "title_1",
                        "label": "Title 1"
                    },
                    {
                        "type": "text",
                        "id": "description_1",
                        "label": "Description 1"
                    },
                    {
                        "type": "image_picker",
                        "id": "icon_2",
                        "label": "Icon 2"
                    },
                    {
                        "type": "text",
                        "id": "title_2",
                        "label": "Title 2"
                    },
                    {
                        "type": "text",
                        "id": "description_2",
                        "label": "Description 2"
                    },
                    {
                        "type": "image_picker",
                        "id": "icon_3",
