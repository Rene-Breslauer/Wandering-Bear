{%- doc -%}
  Individual order detail (classic accounts). Rendered by templates/customers/order.liquid.
  Figma: Account_Dashboard_IndividualOrder (+ _Mobile). The Figma card *contents* are
  screenshots, so content follows the native `order` object + dashboard style tokens
  (foam cards #FEF8F3 r10, espresso text, Kurdis). Container matches the dashboard.
{%- enddoc -%}
{%- liquid
  assign card = 'rounded-[10px] bg-foam shadow-[0px_4px_4px_0px_rgba(0,0,0,0.25)]'
  assign fulfillment = order.fulfillments.first
-%}

<section class="w-full" style="background-color: var(--color-brand-beige);">
  <div class="account-container py-8 md:!py-12">

    {%- comment -%} ---------- Back link ---------- {%- endcomment -%}
    <a href="{{ routes.account_url }}" class="inline-flex items-center !gap-2 font-kurdis-condensed font-extrabold uppercase text-[14px] leading-none text-espresso hover-underline mb-5">
      <svg class="w-[14px] h-[10px] shrink-0" viewBox="0 0 14 10" fill="none" aria-hidden="true"><path d="M5 1 1 5l4 4M1 5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      {{ 'customer.order.back_to_account' | t }}
    </a>

    {%- comment -%} ---------- Header: order name + meta ---------- {%- endcomment -%}
    <div class="flex flex-col smd:!flex-row smd:!items-end smd:!justify-between !gap-2 mb-6">
      <h1 class="font-kurdis-condensed font-extrabold text-espresso text-[25px] md:!text-[32px] leading-none">{{ 'customer.order.title' | t: name: order.name }}</h1>
      <p class="font-kurdis-semi-condensed font-bold text-[12px] leading-none text-espresso">
        {{ order.created_at | date: '%B %-d, %Y' }}
        <span class="mx-1 text-espresso/40">·</span>{{ order.financial_status_label }}
        <span class="mx-1 text-espresso/40">·</span>{{ order.fulfillment_status_label }}
      </p>
    </div>

    {%- comment -%} ---------- Card 1: items + summary ---------- {%- endcomment -%}
    <div class="{{ card }} p-5 md:!p-6 mb-4">
      <ul class="flex flex-col divide-y divide-espresso/10">
        {%- for line_item in order.line_items -%}
          <li class="flex items-start !gap-4 py-4 first:pt-0">
            <div class="shrink-0 w-[64px] h-[64px] rounded-[8px] overflow-hidden bg-(--color-brand-light_cream)">
              {%- if line_item.image -%}
                {{ line_item.image | image_url: width: 128 | image_tag: loading: 'lazy', class: 'w-full h-full object-cover', alt: line_item.title }}
              {%- endif -%}
            </div>
            <div class="flex-1 min-w-0">
              <div class="body font-bold text-espresso">{{ line_item.product.title | default: line_item.title }}</div>
              {%- unless line_item.variant.title contains 'Default' -%}
                <div class="font-kurdis-semi-condensed font-bold text-[12px] leading-none text-espresso/70 mt-1">{{ line_item.variant.title }}</div>
              {%- endunless -%}
              {%- if line_item.selling_plan_allocation -%}
                <div class="inline-flex items-center h-[18px] px-[8px] mt-2 rounded-[9px] font-kurdis-semi-condensed font-bold text-[10px] leading-none text-espresso bg-sky-blue">{{ line_item.selling_plan_allocation.selling_plan.name }}</div>
              {%- endif -%}
              <div class="font-kurdis-semi-condensed font-bold text-[12px] leading-none text-espresso/70 mt-2">{{ 'customer.order.qty' | t: count: line_item.quantity }}</div>
            </div>
            <div class="shrink-0 text-right body font-bold text-espresso whitespace-nowrap">{{ line_item.final_line_price | money }}</div>
          </li>
        {%- endfor -%}
      </ul>

      {%- comment -%} Totals {%- endcomment -%}
      <dl class="flex flex-col !gap-2 pt-4 mt-4 border-t border-espresso/15 body text-espresso">
        <div class="flex items-center justify-between"><dt>{{ 'customer.order.subtotal' | t }}</dt><dd class="font-bold">{{ order.line_items_subtotal_price | money }}</dd></div>
        {%- for discount in order.cart_level_discount_applications -%}
          <div class="flex items-center justify-between text-dark-gold"><dt>{{ 'customer.order.discount' | t }} ({{ discount.title }})</dt><dd class="font-bold">-{{ discount.total_allocated_amount | money }}</dd></div>
        {%- endfor -%}
        <div class="flex items-center justify-between"><dt>{{ 'customer.order.shipping' | t }}</dt><dd class="font-bold">{{ order.shipping_price | money }}</dd></div>
        {%- for tax_line in order.tax_lines -%}
          <div class="flex items-center justify-between"><dt>{{ 'customer.order.tax' | t }} ({{ tax_line.title }})</dt><dd class="font-bold">{{ tax_line.price | money }}</dd></div>
        {%- endfor -%}
        <div class="flex items-center justify-between pt-2 mt-1 border-t border-espresso/15 text-[18px]"><dt class="font-bold">{{ 'customer.order.total' | t }}</dt><dd class="font-kurdis-condensed font-extrabold text-dark-gold">{{ order.total_price | money }}</dd></div>
      </dl>
    </div>

    {%- comment -%} ---------- Cards 2 + 3: delivery + payment ---------- {%- endcomment -%}
    <div class="flex flex-col md:!flex-row !gap-4">

      {%- comment -%} Delivery: shipping address + tracking {%- endcomment -%}
      <div class="flex-1 {{ card }} p-5 md:!p-6">
        <div class="tag text-espresso uppercase mb-3">{{ 'customer.order.delivery' | t }}</div>
        {%- if order.shipping_address -%}
          <address class="body text-espresso not-italic leading-[1.5]">
            {{ order.shipping_address.name }}<br>
            {{ order.shipping_address.street }}<br>
            {{ order.shipping_address.city }}, {{ order.shipping_address.province_code }} {{ order.shipping_address.zip }}<br>
            {{ order.shipping_address.country }}
          </address>
        {%- endif -%}
        {%- if fulfillment.tracking_number -%}
          <div class="mt-4">
            {%- if fulfillment.tracking_url -%}
              {%- render 'wb-button', style: 'secondary-gold', label: 'customer.order.track' | t, link: fulfillment.tracking_url, class: '!h-[40px] !text-[15px]' -%}
            {%- else -%}
              <div class="font-kurdis-semi-condensed font-bold text-[12px] text-espresso">{{ 'customer.order.tracking' | t }}: {{ fulfillment.tracking_number }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Payment: billing address + status {%- endcomment -%}
      <div class="flex-1 {{ card }} p-5 md:!p-6">
        <div class="tag text-espresso uppercase mb-3">{{ 'customer.order.payment' | t }}</div>
        <div class="body font-bold text-espresso mb-2">{{ order.financial_status_label }}</div>
        {%- if order.billing_address -%}
          <address class="body text-espresso not-italic leading-[1.5]">
            {{ order.billing_address.name }}<br>
            {{ order.billing_address.street }}<br>
            {{ order.billing_address.city }}, {{ order.billing_address.province_code }} {{ order.billing_address.zip }}<br>
            {{ order.billing_address.country }}
          </address>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>
