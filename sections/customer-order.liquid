{%- doc -%}
  Individual order detail (classic accounts). Rendered by templates/customers/order.liquid.
  Figma: Account_Dashboard_IndividualOrder (+ _Mobile). Layout = title + back/tracking row,
  then a foam card with an items TABLE (Product / SKU / Price / Quantity / Total) + order
  summary, then Billing Address and Shipping Address foam cards. Dashboard style tokens
  (foam cards #FEF8F3 r10, espresso text, Kurdis). Container matches the dashboard.
{%- enddoc -%}
{%- liquid
  assign card = 'rounded-[10px] bg-foam shadow-[0px_4px_4px_0px_rgba(0,0,0,0.25)]'
  assign fulfillment = order.fulfillments.first
  assign tracking_number = fulfillment.tracking_number
  assign tracking_url = fulfillment.tracking_url
-%}

<section class="w-full" style="background-color: var(--color-brand-beige);">
  <div class="account-container py-8 md:!py-12">

    {%- comment -%} ---------- Title ---------- {%- endcomment -%}
    <h1 class="font-kurdis-condensed font-extrabold text-espresso text-[25px] md:!text-[32px] leading-none mb-4">{{ 'customer.order.title' | t: name: order.name }}</h1>

    {%- comment -%} ---------- Back link + Tracking Number ---------- {%- endcomment -%}
    <div class="flex items-center justify-between !gap-3 mb-6">
      <a href="{{ routes.account_url }}" class="inline-flex items-center !gap-2 font-kurdis-condensed font-extrabold uppercase text-[14px] leading-none text-espresso hover-underline">
        <svg class="w-[14px] h-[10px] shrink-0" viewBox="0 0 14 10" fill="none" aria-hidden="true"><path d="M5 1 1 5l4 4M1 5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {{ 'customer.order.back_to_account' | t }}
      </a>
      {%- if tracking_number -%}
        <a href="{{ tracking_url | default: '#' }}"{% if tracking_url %} target="_blank" rel="noopener"{% endif %} class="font-gothic_condensed font-extrabold text-[16px] leading-none text-right underline text-espresso">{{ 'customer.order.tracking_number' | t }}: {{ tracking_number }}</a>
      {%- endif -%}
    </div>

    {%- comment -%} ---------- Card 1: order meta + items table + summary ---------- {%- endcomment -%}
    <div class="{{ card }} p-5 md:!p-8 mb-6">
      <div class="body font-bold text-espresso">{{ 'customer.order.title' | t: name: order.name }}</div>
      <div class="font-kurdis-semi-condensed font-bold text-[12px] leading-none text-espresso/70 mt-2 mb-6">{{ 'customer.order.placed_on' | t: date: order.created_at | date: '%B %d, %Y' }}</div>

      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-left">
          <thead>
            <tr class="font-kurdis-semi-condensed font-bold text-[12px] uppercase text-espresso align-bottom">
              <th class="font-bold pb-3 pr-4">{{ 'customer.order.col_product' | t }}</th>
              <th class="font-bold pb-3 px-4 whitespace-nowrap">{{ 'customer.order.col_sku' | t }}</th>
              <th class="font-bold pb-3 px-4 text-right whitespace-nowrap">{{ 'customer.order.col_price' | t }}</th>
              <th class="font-bold pb-3 px-4 text-right whitespace-nowrap">{{ 'customer.order.col_quantity' | t }}</th>
              <th class="font-bold pb-3 pl-4 text-right whitespace-nowrap">{{ 'customer.order.total' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {%- for line_item in order.line_items -%}
              <tr class="border-t border-espresso body text-espresso align-top">
                <td class="py-4 pr-4 font-bold uppercase">{{ line_item.title }}</td>
                <td class="py-4 px-4 whitespace-nowrap">{{ line_item.sku }}</td>
                <td class="py-4 px-4 text-right whitespace-nowrap">{{ line_item.price | money }}</td>
                <td class="py-4 px-4 text-right whitespace-nowrap">{{ line_item.quantity }}</td>
                <td class="py-4 pl-4 text-right whitespace-nowrap">{{ line_item.final_line_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>

      {%- comment -%} Order summary (right-aligned) {%- endcomment -%}
      <div class="border-t border-espresso pt-5 flex flex-col items-end !gap-4 body text-espresso">
        <div class="flex w-full max-w-[360px] justify-between"><span>{{ 'customer.order.subtotal' | t }}</span><span>{{ order.line_items_subtotal_price | money }}</span></div>
        {%- for discount in order.cart_level_discount_applications -%}
          <div class="flex w-full max-w-[360px] justify-between text-dark-gold"><span>{{ 'customer.order.discount' | t }} ({{ discount.title }})</span><span>-{{ discount.total_allocated_amount | money }}</span></div>
        {%- endfor -%}
        {%- for method in order.shipping_methods -%}
          <div class="flex w-full max-w-[360px] justify-between"><span>{{ method.title }}</span><span>{{ method.price | money }}</span></div>
        {%- else -%}
          <div class="flex w-full max-w-[360px] justify-between"><span>{{ 'customer.order.shipping' | t }}</span><span>{{ order.shipping_price | money }}</span></div>
        {%- endfor -%}
        {%- for tax_line in order.tax_lines -%}
          <div class="flex w-full max-w-[360px] justify-between"><span>{{ 'customer.order.tax' | t }} ({{ tax_line.title }})</span><span>{{ tax_line.price | money }}</span></div>
        {%- endfor -%}
        <div class="flex w-full max-w-[360px] justify-between font-kurdis-condensed font-extrabold"><span>{{ 'customer.order.total' | t }}</span><span>{{ order.total_price | money }}</span></div>
      </div>
    </div>

    {%- comment -%} ---------- Card 2: Billing Address ---------- {%- endcomment -%}
    <div class="{{ card }} p-5 md:!p-8 mb-6">
      <h2 class="font-kurdis-condensed font-extrabold text-espresso text-[18px] leading-none mb-3">{{ 'customer.order.billing_address' | t }}</h2>
      <div class="text-espresso text-[20px] leading-[1.3] mb-6">{{ 'customer.order.payment_status' | t }}: {{ order.financial_status_label }}</div>
      {%- if order.billing_address -%}
        <address class="font-kurdis-semi-condensed font-bold text-[14px] leading-[1.6] text-espresso not-italic">
          {{ order.billing_address.address1 }}<br>
          {%- if order.billing_address.address2 != blank %}{{ order.billing_address.address2 }}<br>{% endif -%}
          {{ order.billing_address.city }},<br>
          {{ order.billing_address.zip }} {{ order.billing_address.country }}
        </address>
      {%- endif -%}
    </div>

    {%- comment -%} ---------- Card 3: Shipping Address ---------- {%- endcomment -%}
    <div class="{{ card }} p-5 md:!p-8">
      <h2 class="font-kurdis-condensed font-extrabold text-espresso text-[18px] leading-none mb-3">{{ 'customer.order.shipping_address' | t }}</h2>
      <div class="text-espresso text-[20px] leading-[1.3] mb-6">{{ 'customer.order.fulfillment_status' | t }}: {{ order.fulfillment_status_label }}</div>
      {%- if order.shipping_address -%}
        <address class="font-kurdis-semi-condensed font-bold text-[14px] leading-[1.6] text-espresso not-italic">
          {{ order.shipping_address.address1 }}<br>
          {%- if order.shipping_address.address2 != blank %}{{ order.shipping_address.address2 }}<br>{% endif -%}
          {{ order.shipping_address.city }},<br>
          {{ order.shipping_address.zip }} {{ order.shipping_address.country }}
        </address>
      {%- endif -%}
    </div>

  </div>
</section>
