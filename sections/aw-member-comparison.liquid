{% liquid
    assign section_settings = section.settings
    assign color_scheme = section_settings.color_scheme
    assign background_color = color_scheme.background
    assign text_color = color_scheme.text
    assign title_type = section_settings.title_type
    assign title = section_settings.title
    assign title_alt = section_settings.title_alt
    assign title_image = section_settings.title_image
    assign title_image_mobile = section_settings.title_image_mobile
    assign background_image = section_settings.background_image
    assign button_label = section_settings.button_label
    assign button_link = section_settings.button_link
    assign tier_items = section.blocks
%}


<div class="wb-flex justify-center relative" style="background-color: {{ background_color }}">
    {% if background_image != blank %}
        {% render 'picture', source: background_image, class: 'w-full !h-full object-cover !max-w-none absolute inset-0', alt: background_image.alt, width: 1920, height: 1080, preload: 'eager', loading: 'eager' %}
    {% endif %}
    <div class="max-w-[1290px] w-full mx-auto wb-flex justify-end relative pt-10 pb-5 px-4">
    <div class="wb-flex flex-col gap-4 max-w-[601px] w-full">
        <div class="wb-flex flex-col gap-4 mx-auto relative z-[2] justify-center">
            <div class="wb-flex flex-col justify-center items-start mx-auto">
                {% if title_type == 'image' %}
                    {% if title_image != blank %}
                        <div class="max-w-[442px] w-full md:!mb-5">
                            {% render 'title-image', image: title_image, image_mobile: title_image_mobile, alt: title_alt, class: 'w-full max-h-full object-contain' %}
                        </div>
                    {% endif %}
                {% elsif title_type == 'text' %}
                    {% if title != blank %}
                        <span class="h1 mb-8" style="color: {{ text_color }}">{{ title }}</span>
                    {% endif %}
                {% endif %}
            </div>

            <div class="wb-flex flex-col gap-4">
                {% for tier_item in tier_items %}
                    <div class="grid !grid-cols-2 gap-4 px-6.5 py-4 rounded-[3px] shadow-button" style="background: {{ tier_item.settings.background_color }}">
                        <div class="wb-flex flex-col">
                            <span class="h1">{{ tier_item.settings.title }}</span>
                            <span class="body">{{ tier_item.settings.subtitle }}</span>
                            {% if tier_item.settings.button_label != blank %}
                                {% render 'wb-button', style: 'secondary-gold', label: tier_item.settings.button_label, link: tier_item.settings.button_link, class: 'mt-3 !text-[15px]' %}
                                {% comment %} <a href="{{ tier_item.settings.button_link }}" class="button">{{ tier_item.settings.button_label }}</a> {% endcomment %}
                            {% endif %}
                        </div>
                        <div>
                            <span class="body">{{ tier_item.settings.description }}</span>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
    </div>
</div>

{% schema %}
    {
        "name": "AW Member Comparison",
        "settings": [
            {
                "type": "color_scheme",
                "id": "color_scheme",
                "label": "Color Scheme",
                "default": "scheme-1"
            },
            {
                "type": "image_picker",
                "id": "background_image",
                "label": "Background Image"
            },
            {
                "type": "select",
                "id": "title_type",
                "label": "Title Type",
                "options": [
                    {
                        "value": "text",
                        "label": "Text"
                    },
                    {
                        "value": "image",
                        "label": "Image"
                    }
                ],
                "default": "text"
            },
            {
                "type": "text",
                "id": "title",
                "label": "Title",
                "visible_if": "{{ section.settings.title_type == 'text' }}"
            },
            {
                "type": "text",
                "id": "title_alt",
                "label": "Title Alt",
                "visible_if": "{{ section.settings.title_type == 'image' }}"
            },
            {
                "type": "image_picker",
                "id": "title_image",
                "label": "Title Image",
                "visible_if": "{{ section.settings.title_type == 'image' }}"
            },
            {
                "type": "image_picker",
                "id": "title_image_mobile",
                "label": "Title Image Mobile",
                "visible_if": "{{ section.settings.title_type == 'image' }}"
            },
            {
                "type": "text",
                "id": "button_label",
                "label": "Button Label"
            },
            {
                "type": "url",
                "id": "button_link",
                "label": "Button Link"
            }
        ],
        "blocks": [
            {
                "type": "tier_item",
                "name": "Tier Item",
                "settings": [
                    {
                        "type": "text",
                        "id": "title",
                        "label": "Title"
                    },
                    {
                        "type": "text",
                        "id": "subtitle",
                        "label": "Subtitle"
                    },
                    {
                        "type": "richtext",
                        "id": "description",
                        "label": "Description"
                    },
                    {
                        "type": "color_background",
                        "id": "background_color",
                        "label": "Background Color"
                    },
                    {
                        "type": "text",
                        "id": "button_label",
                        "label": "Button Label"
                    },
                    {
                        "type": "url",
                        "id": "button_link",
                        "label": "Button Link"
                    }
                ]
            }
        ],
        "presets": [
            {
                "name": "AW Member Comparison"
            }
        ]
    }
{% endschema %}