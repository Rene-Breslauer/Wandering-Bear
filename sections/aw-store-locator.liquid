{% comment %}
  Store locator — an empty container for the locator widget. The heading lives in
  aw-page-heading, because Figma puts the logo band between the two.
  Figma: WB x AW Ancillary Pages, Find Us In Stores 123:5 (title y=169, container 1074×758
  at y=387) and mobile 123:55 (title 2 lines, container 372×599).

  The locator itself is a third-party widget, so this section only owns the frame. Three ways
  to fill it, in order of precedence:
    1. App block  — add it inside this section in the theme editor ({% content_for 'blocks' %})
    2. Custom code — the `custom_code` setting, for a script or embed snippet
    3. Nothing     — the container renders empty at the right size, so layout can be checked

  The container also carries an id so a widget that mounts by selector has something to target.
{% endcomment %}

{% liquid
  assign s = section.settings
  assign color_scheme = s.color_scheme
  assign has_blocks = false
  if section.blocks.size > 0
    assign has_blocks = true
  endif
%}

{% capture type_styles %}
  --locator-height: {{ s.height | default: 758 }}px;
  --locator-height-mobile: {{ s.height_mobile | default: 599 }}px;
  --locator-max-width: {{ s.max_width | default: 1074 }}px;
{% endcapture %}

<div
  class="wb-store-locator relative overflow-hidden spacing-style wb-section-bg"
  style="{% render 'section-background', settings: s, part: 'style', fallback_color: color_scheme.settings.background %} {% render 'spacing-style', settings: s %} {{ type_styles }}"
  {{ section.shopify_attributes }}
>
  {% render 'section-background', settings: s, part: 'media' %}

  <div class="relative z-[1]">
    <div
      id="{{ s.container_id | default: 'wb-store-locator' }}"
      class="wb-store-locator__frame mx-auto w-full"
    >
      {% if has_blocks %}
        {% content_for 'blocks' %}
      {% elsif s.custom_code != blank %}
        {{ s.custom_code }}
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .wb-store-locator__frame {
    max-width: var(--locator-max-width);
    min-height: var(--locator-height-mobile);
  }

  /* The widget is a third party's markup — make sure it actually fills the frame. */
  .wb-store-locator__frame > * {
    width: 100%;
  }

  /* The Store Locators app pads its own root by 28px, which eats into the frame. The app has
     paddingTop/Bottom/Left/Right settings for this — zeroing them in the theme editor is the
     tidy fix; this override just makes the frame the single source of width either way. */
  .wb-store-locator__frame #storelocators_root {
    padding: 0 !important;
  }

  .wb-store-locator__frame iframe {
    width: 100%;
    min-height: inherit;
    border: 0;
    display: block;
  }

  @media screen and (min-width: 750px) {
    .wb-store-locator__frame {
      min-height: var(--locator-height);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "AW Store Locator",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Locator container"
    },
    {
      "type": "paragraph",
      "content": "Add the locator app block inside this section, or paste its embed code below."
    },
    {
      "type": "liquid",
      "id": "custom_code",
      "label": "Custom code",
      "info": "Used only when no app block is added."
    },
    {
      "type": "text",
      "id": "container_id",
      "label": "Container id",
      "info": "For widgets that mount by selector.",
      "default": "wb-store-locator"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 600,
      "max": 1200,
      "step": 6,
      "unit": "px",
      "default": 1074
    },
    {
      "type": "range",
      "id": "height",
      "label": "Min height",
      "min": 300,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "default": 760
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Min height mobile",
      "min": 300,
      "max": 1200,
      "step": 10,
      "unit": "px",
      "default": 600
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "options": [
        {
          "value": "transparent",
          "label": "Transparent"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        },
        {
          "value": "image",
          "label": "Image"
        }
      ],
      "default": "color"
    },
    {
      "type": "color",
      "id": "background_solid",
      "label": "Background color",
      "default": "#F2E6DC",
      "visible_if": "{{ section.settings.background_type == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient",
      "visible_if": "{{ section.settings.background_type == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.mobile"
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "AW Store Locator"
    }
  ]
}
{% endschema %}
